{% extends "layout.twig" %}

{% block title %}System Dashboard | MarwaPHP{% endblock %}

{% block content %}
  <section id="overview" class="admin-page-header">
    <div class="admin-page-header__copy">
      <span class="admin-eyebrow">Operations workspace</span>
      <h1 class="admin-page-title">Server and application health.</h1>
      <p class="admin-page-lead">
        Compact status cards for the current application, runtime, memory, disk, and theme.
      </p>
    </div>
  </section>

  <section class="admin-panel" id="system-status" aria-labelledby="system-status-title">
    <div class="admin-panel__header">
      <div>
        <h2 id="system-status-title" class="admin-section-title">Server and application status</h2>
        <p class="admin-section-subtitle">Generated by the status module.</p>
      </div>
      <span class="admin-pill">Module driven</span>
    </div>

    <div class="admin-kpi-grid">
      {% for card in status_cards %}
        {% include "components/status-card.twig" with card only %}
      {% endfor %}
    </div>
  </section>
{% endblock %}
