{% extends "layout.twig" %}

{% block title %}System Dashboard | MarwaPHP{% endblock %}

{% block content %}
  <section id="overview" class="admin-page-header">
    <div class="admin-page-header__copy">
      <span class="admin-eyebrow">Operations workspace</span>
      <h1 class="admin-page-title">Server and application health.</h1>
      <p class="admin-page-lead">
        Compact status cards for the current application, runtime, memory, disk, and theme.
      </p>
    </div>
  </section>

  <section class="admin-panel" id="system-status" aria-labelledby="system-status-title">
    <div class="admin-panel__header">
      <div>
        <h2 id="system-status-title" class="admin-section-title">Server and application status</h2>
        <p class="admin-section-subtitle">Generated by the status module.</p>
      </div>
      <span class="admin-pill">Module driven</span>
    </div>

    <div class="admin-kpi-grid">
      {% for card in status_cards %}
        {% include "components/status-card.twig" with card only %}
      {% endfor %}
    </div>
  </section>

  <section class="admin-table-shell" id="recent-activity" aria-labelledby="recent-activity-title">
    <div class="admin-table-shell__header">
      <div>
        <h2 id="recent-activity-title" class="admin-section-title">Recent activity</h2>
        <p class="admin-section-subtitle">Live feed from the Activity module.</p>
      </div>
      <a class="admin-btn admin-btn--ghost" href="/admin/activity">View all</a>
    </div>

    {% if activities is empty %}
      <div class="admin-alert admin-alert--info">
        <p class="admin-alert__title">No activity yet</p>
        <p class="admin-alert__body">Sign in, manage users, or restore a record to populate the feed.</p>
      </div>
    {% else %}
      <table class="admin-table">
        <thead>
          <tr>
            <th>Action</th>
            <th>Description</th>
            <th>Details</th>
            <th>Actor</th>
          </tr>
        </thead>
        <tbody>
          {% for activity in activities %}
            <tr>
              <td><span class="admin-badge admin-badge--neutral">{{ activity.getAttribute('action') }}</span></td>
              <td>{{ activity.getAttribute('description') }}</td>
              <td>{{ activity.readableDetails() }}</td>
              <td>{{ activity.getAttribute('actor_email')|default('System') }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </section>
{% endblock %}
