{% extends "layout.twig" %}

{% block title %}System Dashboard | MarwaPHP{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-full border px-5 py-3 text-sm font-semibold transition hover:-translate-y-0.5' %}
  {% set button_ghost = button_base ~ ' border-white/10 bg-white/5 text-slate-100 hover:bg-white/10' %}
  {% set badge_neutral = 'inline-flex items-center rounded-full border border-cyan-300/20 bg-cyan-400/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-cyan-100' %}

  <section id="overview" class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-3">
      <span class="inline-flex w-fit items-center rounded-full border border-cyan-300/20 bg-cyan-400/10 px-4 py-1.5 text-[0.7rem] font-extrabold uppercase tracking-[0.22em] text-cyan-100">Operations workspace</span>
      <h1 class="text-3xl font-black tracking-tight text-white sm:text-4xl">Server and application health.</h1>
      <p class="max-w-2xl text-sm leading-6 text-slate-300 sm:text-base">
        Compact status cards for the current application, runtime, memory, disk, and theme.
      </p>
    </div>
  </section>

  <section id="system-status" aria-labelledby="system-status-title" class="mt-8 overflow-hidden rounded-[2rem] border border-white/10 bg-white/5 p-5 shadow-[0_30px_80px_rgba(2,6,23,0.45)] backdrop-blur-xl sm:p-6">
    <div class="flex flex-col gap-3 border-b border-white/10 pb-5 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2 id="system-status-title" class="text-2xl font-bold tracking-tight text-white">Server and application status</h2>
        <p class="mt-1 text-sm text-slate-400">Generated by the status module.</p>
      </div>
      <span class="{{ badge_neutral }}">Module driven</span>
    </div>

    <div class="mt-5 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {% for card in status_cards %}
        {% include "components/status-card.twig" with card only %}
      {% endfor %}
    </div>
  </section>

  <section id="recent-activity" aria-labelledby="recent-activity-title" class="mt-8 overflow-hidden rounded-[2rem] border border-white/10 bg-white/5 p-5 shadow-[0_30px_80px_rgba(2,6,23,0.45)] backdrop-blur-xl sm:p-6">
    <div class="flex flex-col gap-3 border-b border-white/10 pb-5 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2 id="recent-activity-title" class="text-2xl font-bold tracking-tight text-white">Recent activity</h2>
        <p class="mt-1 text-sm text-slate-400">Live feed from the Activity module.</p>
      </div>
      <a class="{{ button_ghost }}" href="/admin/activity">View all</a>
    </div>

    {% if activities is empty %}
      <div class="mt-5 rounded-2xl border border-cyan-300/20 bg-cyan-400/10 p-4 text-cyan-100">
        <p class="text-sm font-semibold">No activity yet</p>
        <p class="mt-1 text-sm text-cyan-100/80">Sign in, manage users, or restore a record to populate the feed.</p>
      </div>
    {% else %}
      <div class="mt-5 overflow-hidden rounded-[1.5rem] border border-white/10">
      <table class="w-full border-collapse">
        <thead>
          <tr class="bg-white/5">
            <th class="border-b border-white/10 px-3 py-3 text-left text-xs font-extrabold uppercase tracking-[0.12em] text-slate-300">Action</th>
            <th class="border-b border-white/10 px-3 py-3 text-left text-xs font-extrabold uppercase tracking-[0.12em] text-slate-300">Description</th>
            <th class="border-b border-white/10 px-3 py-3 text-left text-xs font-extrabold uppercase tracking-[0.12em] text-slate-300">Details</th>
            <th class="border-b border-white/10 px-3 py-3 text-left text-xs font-extrabold uppercase tracking-[0.12em] text-slate-300">Actor</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/10">
          {% for activity in activities %}
            <tr class="align-top">
              <td class="px-3 py-3">
                <span class="inline-flex rounded-full border border-cyan-300/20 bg-cyan-400/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-cyan-100">{{ activity.getAttribute('action') }}</span>
              </td>
              <td class="px-3 py-3 text-sm text-slate-200">{{ activity.getAttribute('description') }}</td>
              <td class="px-3 py-3 text-sm text-slate-300">{{ activity.readableDetails() }}</td>
              <td class="px-3 py-3 text-sm text-slate-300">{{ activity.getAttribute('actor_email')|default('System') }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
      </div>
    {% endif %}
  </section>
{% endblock %}
