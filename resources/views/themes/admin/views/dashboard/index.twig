{% extends "layout.twig" %}

{% block title %}System Dashboard | MarwaPHP{% endblock %}

{% block content %}
  {% set status_cards = status_cards|default([]) %}
  {% set activities = activities|default([]) %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-xl border px-3.5 py-2 text-[0.82rem] font-semibold transition' %}
  {% set button_ghost = button_base ~ ' border-white/10 bg-white/5 text-slate-100 hover:bg-white/10' %}
  {% set badge_neutral = 'inline-flex items-center rounded-xl border border-cyan-300/20 bg-cyan-400/10 px-2.5 py-1 text-[0.68rem] font-bold uppercase tracking-[0.14em] text-cyan-100' %}

  {% embed 'components/card.twig' with {
    shell_class: 'mt-6 overflow-hidden rounded-[1.25rem] border border-white/10 bg-white/5 p-4 shadow-[0_30px_80px_rgba(2,6,23,0.45)] backdrop-blur-xl sm:p-5',
    body_class: 'grid gap-4'
  } only %}
    {% block header %}
      <div class="flex flex-col gap-2 border-b border-white/10 pb-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 id="system-status-title" class="text-xl font-bold tracking-tight text-white">Server and application status</h2>
          <p class="mt-1 text-sm text-slate-400">Generated by the status module.</p>
        </div>
        <span class="{{ badge_neutral }}">Module driven</span>
      </div>
    {% endblock %}

    {% block body %}
      <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
        {% for card in status_cards %}
          {% include "components/status-card.twig" with card only %}
        {% endfor %}
      </div>
    {% endblock %}
  {% endembed %}

  {% embed 'components/card.twig' with {
    shell_class: 'mt-6 overflow-hidden rounded-[1.25rem] border border-white/10 bg-white/5 p-4 shadow-[0_30px_80px_rgba(2,6,23,0.45)] backdrop-blur-xl sm:p-5',
    body_class: 'grid gap-4'
  } only %}
    {% block header %}
      <div class="flex flex-col gap-2 border-b border-white/10 pb-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 id="recent-activity-title" class="text-xl font-bold tracking-tight text-white">Recent activity</h2>
          <p class="mt-1 text-sm text-slate-400">Live feed from the Activity module.</p>
        </div>
        <a class="{{ button_ghost }}" href="/admin/activity">View all</a>
      </div>
    {% endblock %}

    {% block body %}
      {% if activities is empty %}
        <div class="rounded-xl border border-cyan-300/20 bg-cyan-400/10 p-3.5 text-cyan-100">
          <p class="text-sm font-semibold">No activity yet</p>
          <p class="mt-1 text-sm text-cyan-100/80">Sign in, manage users, or restore a record to populate the feed.</p>
        </div>
      {% else %}
        <div class="overflow-hidden rounded-[1rem] border border-white/10">
          <table class="admin-table w-full border-collapse">
            <thead>
              <tr class="bg-white/5">
                <th class="border-b border-white/10 px-3 py-3 text-left text-xs font-extrabold uppercase tracking-[0.12em] text-slate-300">Action</th>
                <th class="border-b border-white/10 px-3 py-3 text-left text-xs font-extrabold uppercase tracking-[0.12em] text-slate-300">Description</th>
                <th class="border-b border-white/10 px-3 py-3 text-left text-xs font-extrabold uppercase tracking-[0.12em] text-slate-300">Details</th>
                <th class="border-b border-white/10 px-3 py-3 text-left text-xs font-extrabold uppercase tracking-[0.12em] text-slate-300">Actor</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/10">
              {% for activity in activities %}
                <tr class="align-top">
                  <td class="px-3 py-3">
                    <span class="inline-flex rounded-full border border-cyan-300/20 bg-cyan-400/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-cyan-100">{{ activity.getAttribute('action') }}</span>
                  </td>
                  <td class="px-3 py-3 text-sm text-slate-200">{{ activity.getAttribute('description') }}</td>
                  <td class="px-3 py-3 text-sm text-slate-300">{{ activity.readableDetails() }}</td>
                  <td class="px-3 py-3 text-sm text-slate-300">{{ activity.getAttribute('actor_email')|default('System') }}</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% endif %}
    {% endblock %}
  {% endembed %}
{% endblock %}
