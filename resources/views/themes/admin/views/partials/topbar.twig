<div class="flex items-center justify-between gap-3 px-4 py-2.5 sm:px-5 lg:px-6">
  <div class="flex items-center gap-3">
    <!-- Mobile Burger Menu Button -->
    <button 
      type="button" 
      class="inline-flex items-center justify-center rounded-xl border border-app-border bg-app-surface/60 p-2 text-app-muted transition hover:bg-app-surface-2/70 hover:text-app-text lg:hidden"
      @click="toggleMobile()"
      aria-label="Toggle menu"
    >
      {% include 'components/icon.twig' with { name: 'menu', class: 'h-5 w-5' } only %}
    </button>

    <div class="flex flex-col gap-0.5">
      <p class="inline-flex w-fit items-center rounded-full border border-app-border bg-app-accent/10 px-2.5 py-0.5 text-[0.62rem] font-extrabold uppercase tracking-[0.18em] text-app-accent">
        Operations console
      </p>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-0.5">
        <h1 class="text-lg font-black tracking-tight text-app-text sm:text-xl">Dashboard</h1>
        <strong class="ml-4">
        {% if user_name|default('') %}
          <span class="text-xs text-app-muted">Welcome, {{ user_name }}</span>
        {% endif %}
        {% if server_datetime|default('') %}
          <span class="text-xs text-app-muted">Server: {{ server_datetime }}</span>
        {% endif %}
        </strong>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-3">
    {% if is_authenticated|default(false) %}
      {% include '@notifications/partials/bell.twig' %}
    {% endif %}

    <button
      class="inline-flex items-center justify-center rounded-xl border border-app-border bg-app-surface/60 p-2 text-app-muted transition hover:bg-app-surface hover:text-app-text"
      type="button"
      @click="toggle()"
      aria-label="Toggle theme"
      title="Toggle theme"
    >
      {% include 'components/icon.twig' with { name: 'moon', class: 'h-4 w-4 shrink-0 dark:hidden' } only %}
      {% include 'components/icon.twig' with { name: 'sun', class: 'h-4 w-4 shrink-0 hidden dark:block' } only %}
    </button>

    {% if is_authenticated|default(false) %}
      <div class="relative" x-data="{ profileOpen: false }">
        <button
          type="button"
          class="inline-flex items-center justify-center rounded-full border border-app-border bg-app-surface/60 p-2 text-app-text transition hover:bg-app-surface-2/60 hover:text-app-text"
          @click="profileOpen = !profileOpen"
          @click.outside="profileOpen = false"
          aria-label="Profile menu"
          title="Profile"
        >
          {% include 'components/icon.twig' with { name: 'user', class: 'h-4 w-4 shrink-0' } only %}
        </button>

        <div
          x-show="profileOpen"
          x-cloak
          x-transition:enter="transition ease-out duration-150"
          x-transition:enter-start="opacity-0 scale-95"
          x-transition:enter-end="opacity-100 scale-100"
          x-transition:leave="transition ease-in duration-100"
          x-transition:leave-start="opacity-100 scale-100"
          x-transition:leave-end="opacity-0 scale-95"
          class="absolute right-0 top-full mt-2 w-56 overflow-hidden rounded-2xl border border-app-border bg-app-surface shadow-xl"
        >
          <div class="border-b border-app-border px-4 py-3">
            <p class="text-sm font-semibold text-app-text">{{ user_name|default('Admin') }}</p>
            <p class="text-xs text-app-muted truncate">{{ user_email|default('') }}</p>
          </div>
          <div class="py-2">
            <a href="/admin/profile" class="flex items-center gap-3 px-4 py-2 text-sm text-app-text transition hover:bg-app-surface-2/60 hover:text-app-text">
              {% include 'components/icon.twig' with { name: 'user', class: 'h-4 w-4 shrink-0' } only %}
              <span>My Profile</span>
            </a>
          </div>
          <div class="border-t border-app-border py-2">
            <form method="get" action="/admin/logout">
              {{ csrf_field() }}
              <button type="submit" class="flex w-full items-center gap-3 px-4 py-2 text-sm text-app-text transition hover:bg-app-surface-2/60 hover:text-app-text">
                {% include 'components/icon.twig' with { name: 'log-out', class: 'h-4 w-4 shrink-0' } only %}
                <span>Sign out</span>
              </button>
            </form>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</div>
