<div class="flex items-center justify-between gap-3 px-4 py-3 sm:px-5 lg:px-6">
  <div class="flex items-center gap-3">
    <!-- Mobile Burger Menu Button -->
    <button 
      type="button" 
      class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 p-2 text-slate-300 transition hover:bg-white/10 hover:text-white lg:hidden"
      @click="toggleMobile()"
      aria-label="Toggle menu"
    >
      {% include 'components/icon.twig' with { name: 'menu', class: 'h-5 w-5' } only %}
    </button>

    <div class="space-y-1">
      <p class="inline-flex w-fit items-center rounded-full border border-cyan-300/20 bg-cyan-400/10 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.18em] text-cyan-100">
        Operations console
      </p>
      <h1 class="text-xl font-black tracking-tight text-white">Dashboard</h1>
    </div>
  </div>

  <div class="flex items-center gap-3">
    {% if is_authenticated|default(false) %}
      {% include '@notifications/partials/bell.twig' %}
    {% endif %}

    <button
      class="inline-flex items-center gap-2 rounded-xl border border-slate-300/20 bg-white/50 px-3 py-2 text-xs font-semibold text-slate-600 transition hover:bg-white hover:text-slate-900 dark:border-white/10 dark:bg-white/5 dark:text-slate-200 dark:hover:bg-white/10 dark:hover:text-white"
      type="button"
      @click="toggle()"
      aria-label="Toggle theme"
      title="Toggle theme"
    >
      <svg class="h-4 w-4 shrink-0 dark:hidden"><use href="#icon-moon"></use></svg>
      <svg class="h-4 w-4 shrink-0 hidden dark:block"><use href="#icon-sun"></use></svg>
      <span class="dark:hidden">Light</span>
      <span class="hidden dark:inline">Dark</span>
    </button>
  </div>
</div>
