<div class="flex items-center justify-between gap-3 px-4 py-3 sm:px-5 lg:px-6">
  <div class="space-y-1">
    <p class="inline-flex w-fit items-center rounded-full border border-cyan-300/20 bg-cyan-400/10 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.18em] text-cyan-100">
      Operations console
    </p>
    <h1 class="text-xl font-black tracking-tight text-white">Dashboard</h1>
  </div>

  <button
    class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-3 py-2 text-xs font-semibold text-slate-200 transition hover:bg-white/10"
    type="button"
    data-theme-toggle
    aria-pressed="false"
    aria-label="Toggle theme"
    title="Toggle theme"
  >
    <span data-theme-icon="moon">
      {% include 'components/icon.twig' with { name: 'moon', class: 'h-4 w-4 shrink-0' } only %}
    </span>
    <span class="hidden" data-theme-icon="sun">
      {% include 'components/icon.twig' with { name: 'sun', class: 'h-4 w-4 shrink-0' } only %}
    </span>
    <span data-theme-label>Dark</span>
  </button>
</div>
