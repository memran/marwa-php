<div class="flex items-center justify-between gap-3 px-4 py-2.5 sm:px-5 lg:px-6">
  <div class="flex items-center gap-3">
    <!-- Mobile Burger Menu Button -->
    <button 
      type="button" 
      class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 p-2 text-slate-300 transition hover:bg-white/10 hover:text-white lg:hidden"
      @click="toggleMobile()"
      aria-label="Toggle menu"
    >
      {% include 'components/icon.twig' with { name: 'menu', class: 'h-5 w-5' } only %}
    </button>

    <div class="flex flex-col gap-0.5">
      <p class="inline-flex w-fit items-center rounded-full border border-cyan-300/20 bg-cyan-400/10 px-2.5 py-0.5 text-[0.62rem] font-extrabold uppercase tracking-[0.18em] text-cyan-100">
        Operations console
      </p>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-0.5">
        <h1 class="text-lg font-black tracking-tight text-white sm:text-xl">Dashboard</h1>
        <strong class="ml-4">
        {% if user_name|default('') %}
          <span class="text-xs text-slate-400">Welcome, {{ user_name }}</span>
        {% endif %}
        {% if server_datetime|default('') %}
          <span class="text-xs text-slate-500">Server: {{ server_datetime }}</span>
        {% endif %}
        </strong>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-3">
    {% if is_authenticated|default(false) %}
      {% include '@notifications/partials/bell.twig' %}
    {% endif %}

    <button
      class="inline-flex items-center justify-center rounded-xl border border-slate-300/20 bg-white/50 p-2 text-slate-600 transition hover:bg-white hover:text-slate-900 dark:border-white/10 dark:bg-white/5 dark:text-slate-200 dark:hover:bg-white/10 dark:hover:text-white"
      type="button"
      @click="toggle()"
      aria-label="Toggle theme"
      title="Toggle theme"
    >
      {% include 'components/icon.twig' with { name: 'moon', class: 'h-4 w-4 shrink-0 dark:hidden' } only %}
      {% include 'components/icon.twig' with { name: 'sun', class: 'h-4 w-4 shrink-0 hidden dark:block' } only %}
    </button>

    {% if is_authenticated|default(false) %}
      <div class="relative" x-data="{ profileOpen: false }">
        <button
          type="button"
          class="inline-flex items-center justify-center rounded-full border border-white/10 bg-white/5 p-2 text-slate-200 transition hover:bg-white/10 hover:text-white"
          @click="profileOpen = !profileOpen"
          @click.outside="profileOpen = false"
          aria-label="Profile menu"
          title="Profile"
        >
          {% include 'components/icon.twig' with { name: 'user', class: 'h-4 w-4 shrink-0' } only %}
        </button>

        <div
          x-show="profileOpen"
          x-cloak
          x-transition:enter="transition ease-out duration-150"
          x-transition:enter-start="opacity-0 scale-95"
          x-transition:enter-end="opacity-100 scale-100"
          x-transition:leave="transition ease-in duration-100"
          x-transition:leave-start="opacity-100 scale-100"
          x-transition:leave-end="opacity-0 scale-95"
          class="absolute right-0 top-full mt-2 w-56 overflow-hidden rounded-2xl border border-white/10 bg-slate-900 shadow-xl"
        >
          <div class="border-b border-white/10 px-4 py-3">
            <p class="text-sm font-semibold text-white">{{ user_name|default('Admin') }}</p>
            <p class="text-xs text-slate-400 truncate">{{ user_email|default('') }}</p>
          </div>
          <div class="py-2">
            <a href="/admin/profile" class="flex items-center gap-3 px-4 py-2 text-sm text-slate-200 transition hover:bg-white/5 hover:text-white">
              {% include 'components/icon.twig' with { name: 'user', class: 'h-4 w-4 shrink-0' } only %}
              <span>My Profile</span>
            </a>
          </div>
          <div class="border-t border-white/10 py-2">
            <form method="post" action="/admin/logout">
              {{ csrf_field() }}
              <button type="submit" class="flex w-full items-center gap-3 px-4 py-2 text-sm text-slate-200 transition hover:bg-white/5 hover:text-white">
                {% include 'components/icon.twig' with { name: 'log-out', class: 'h-4 w-4 shrink-0' } only %}
                <span>Sign out</span>
              </button>
            </form>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</div>
