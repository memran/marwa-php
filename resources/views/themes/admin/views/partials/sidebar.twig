{% set currentPath = _current_path|default('') %}
{% set is_admin = is_admin_user|default(false) %}
{% set nav_link_base = 'inline-flex items-center gap-3 rounded-xl px-3 py-2.5 text-[0.82rem] font-semibold transition' %}
{% set nav_link_active = 'bg-cyan-400/10 text-cyan-100 ring-1 ring-inset ring-cyan-300/20' %}
{% set nav_link_inactive = 'text-slate-300 hover:bg-white/5 hover:text-white' %}
{% set section_header = 'px-3 py-2 text-[0.65rem] font-extrabold uppercase tracking-wider text-slate-500' %}

<div class="grid gap-3">
  <!-- Mobile Close Button -->
  <div class="flex items-center justify-between lg:hidden">
    <div class="inline-flex items-center gap-3">
      <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-cyan-300/20 bg-cyan-400/10 text-cyan-100 shadow-[0_20px_50px_rgba(2,6,23,0.18)]">
        {% include 'components/icon.twig' with { name: 'layout-dashboard', class: 'h-5 w-5' } only %}
      </span>
      <div class="grid gap-0.5">
        <span class="text-[0.82rem] font-black uppercase tracking-[0.18em] text-white">MarwaPHP</span>
        <span class="text-xs text-slate-400">Console</span>
      </div>
    </div>
    <button 
      type="button" 
      class="rounded-lg p-2 text-slate-400 hover:bg-white/5 hover:text-white"
      @click="$dispatch('close-mobile')"
    >
      {% include 'components/icon.twig' with { name: 'x', class: 'h-5 w-5' } only %}
    </button>
  </div>

  <!-- Desktop Logo (hidden on mobile) -->
  <div class="hidden lg:inline-flex items-center gap-3">
    <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-cyan-300/20 bg-cyan-400/10 text-cyan-100 shadow-[0_20px_50px_rgba(2,6,23,0.18)]">
      {% include 'components/icon.twig' with { name: 'layout-dashboard', class: 'h-5 w-5' } only %}
    </span>
    <div class="grid gap-0.5">
      <span class="text-[0.82rem] font-black uppercase tracking-[0.18em] text-white">MarwaPHP</span>
      <span class="text-xs text-slate-400">Operations console</span>
    </div>
  </div>
</div>

<nav class="grid gap-1" aria-label="Primary">
  {% set menuTree = mainMenu is defined and mainMenu is not empty ? mainMenu : menu_tree() %}
  {% for section in menuTree %}
    {% if section.children is not empty %}
      <span class="{{ section_header }} {% if not loop.first %}mt-2{% endif %}">{{ section.label }}</span>

      {% for item in section.children %}
        <div class="grid gap-1">
          <a class="{{ nav_link_base }} rounded-2xl border border-transparent {% if currentPath starts with item.url %}{{ nav_link_active }} border-cyan-300/20 bg-cyan-400/10 shadow-[0_8px_24px_rgba(8,145,178,0.08)]{% else %}{{ nav_link_inactive }} hover:border-white/10 hover:bg-white/5{% endif %}" href="{{ item.url }}" {% if currentPath starts with item.url %}aria-current="page"{% endif %}>
            <span class="inline-flex h-7 w-7 items-center justify-center rounded-xl">
              {% if item.icon is not empty %}
                {% include 'components/icon.twig' with { name: item.icon, class: 'h-4 w-4 shrink-0' } only %}
              {% else %}
                <span class="h-2 w-2 rounded-full bg-slate-400"></span>
              {% endif %}
            </span>
            <span class="truncate">{{ item.label }}</span>
            {% if item.name == 'notifications' and unread_notification_count|default(0) > 0 %}
              <span class="ml-auto flex h-5 w-5 items-center justify-center rounded-full bg-rose-500 text-[0.65rem] font-bold text-white">
                {{ unread_notification_count > 9 ? '9+' : unread_notification_count }}
              </span>
            {% endif %}
          </a>

          {% if item.children is not empty %}
            <div class="ml-4 grid gap-2 border-l border-cyan-300/15 pl-4 py-1">
              {% for child in item.children %}
                <a class="{{ nav_link_base }} rounded-xl border border-white/5 bg-white/[0.03] py-2.5 text-[0.78rem] shadow-[0_1px_0_rgba(255,255,255,0.02)] {% if currentPath starts with child.url %}{{ nav_link_active }} border-cyan-300/20 bg-cyan-400/10{% else %}{{ nav_link_inactive }} hover:border-white/10 hover:bg-white/5{% endif %}" href="{{ child.url }}" {% if currentPath starts with child.url %}aria-current="page"{% endif %}>
                  <span class="inline-flex h-6 w-6 items-center justify-center rounded-lg">
                    {% if child.icon is not empty %}
                      {% include 'components/icon.twig' with { name: child.icon, class: 'h-3.5 w-3.5 shrink-0' } only %}
                    {% else %}
                      <span class="h-1.5 w-1.5 rounded-full bg-cyan-300/70"></span>
                    {% endif %}
                  </span>
                  <span class="truncate">{{ child.label }}</span>
                </a>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    {% endif %}
  {% endfor %}

  {# Footer #}
  <div class="mt-2 pt-2 border-t border-white/10">
    <a class="{{ nav_link_base }} {{ nav_link_inactive }}" href="/admin/logout">
      {% include 'components/icon.twig' with { name: 'log-out', class: 'h-5 w-5 shrink-0' } only %}
      <span class="truncate">Logout</span>
    </a>
  </div>
</nav>
