{% set currentPath = _current_path|default('') %}
{% set is_admin = is_admin_user|default(false) %}
{% set nav_link_base = 'inline-flex items-center gap-3 rounded-xl px-3 py-2.5 text-[0.82rem] font-semibold transition' %}
{% set nav_link_active = 'bg-cyan-400/10 text-cyan-100 ring-1 ring-inset ring-cyan-300/20' %}
{% set nav_link_inactive = 'text-slate-300 hover:bg-white/5 hover:text-white' %}
{% set section_header = 'px-3 py-2 text-[0.65rem] font-extrabold uppercase tracking-wider text-slate-500' %}

<div class="grid gap-3">
  <!-- Mobile Close Button -->
  <div class="flex items-center justify-between lg:hidden">
    <div class="inline-flex items-center gap-3">
      <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-cyan-300/20 bg-cyan-400/10 text-cyan-100 shadow-[0_20px_50px_rgba(2,6,23,0.18)]">
        {% include 'components/icon.twig' with { name: 'layout-dashboard', class: 'h-5 w-5' } only %}
      </span>
      <div class="grid gap-0.5">
        <span class="text-[0.82rem] font-black uppercase tracking-[0.18em] text-white">MarwaPHP</span>
        <span class="text-xs text-slate-400">Console</span>
      </div>
    </div>
    <button 
      type="button" 
      class="rounded-lg p-2 text-slate-400 hover:bg-white/5 hover:text-white"
      @click="$dispatch('close-mobile')"
    >
      {% include 'components/icon.twig' with { name: 'x', class: 'h-5 w-5' } only %}
    </button>
  </div>

  <!-- Desktop Logo (hidden on mobile) -->
  <div class="hidden lg:inline-flex items-center gap-3">
    <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-cyan-300/20 bg-cyan-400/10 text-cyan-100 shadow-[0_20px_50px_rgba(2,6,23,0.18)]">
      {% include 'components/icon.twig' with { name: 'layout-dashboard', class: 'h-5 w-5' } only %}
    </span>
    <div class="grid gap-0.5">
      <span class="text-[0.82rem] font-black uppercase tracking-[0.18em] text-white">MarwaPHP</span>
      <span class="text-xs text-slate-400">Operations console</span>
    </div>
  </div>
</div>

<nav class="grid gap-1" aria-label="Primary">
  {% set can_dashboard = can_dashboard|default(false) %}
  {% set can_notifications = can_notifications|default(false) %}
  {% set can_users = can_users|default(false) %}
  {% set can_roles = can_roles|default(false) %}
  {% set can_permissions = can_permissions|default(false) %}
  {% set can_activity = can_activity|default(false) %}
  {% set can_settings = can_settings|default(false) %}
  {% set can_database = can_database|default(false) %}
  {% set has_user_space = can_dashboard or can_notifications %}
  {% set has_management = can_users or can_roles or can_permissions or can_activity %}
  {% set has_system = can_settings or can_database %}

  {% if has_user_space %}
    <span class="{{ section_header }}">User Space</span>
    {% if can_dashboard %}
      <a class="{{ nav_link_base }} rounded-2xl border border-transparent {% if currentPath starts with '/admin/dashboard' %}{{ nav_link_active }} border-cyan-300/20 bg-cyan-400/10 shadow-[0_8px_24px_rgba(8,145,178,0.08)]{% else %}{{ nav_link_inactive }} hover:border-white/10 hover:bg-white/5{% endif %}" href="/admin/dashboard" {% if currentPath starts with '/admin/dashboard' %}aria-current="page"{% endif %}>
        <span class="inline-flex h-7 w-7 items-center justify-center rounded-xl">
          {% include 'components/icon.twig' with { name: 'layout-dashboard', class: 'h-4 w-4 shrink-0' } only %}
        </span>
        <span class="truncate">Dashboard</span>
      </a>
    {% endif %}
    {% if can_notifications %}
      <a class="{{ nav_link_base }} rounded-2xl border border-transparent {% if currentPath starts with '/admin/notifications' %}{{ nav_link_active }} border-cyan-300/20 bg-cyan-400/10 shadow-[0_8px_24px_rgba(8,145,178,0.08)]{% else %}{{ nav_link_inactive }} hover:border-white/10 hover:bg-white/5{% endif %}" href="/admin/notifications" {% if currentPath starts with '/admin/notifications' %}aria-current="page"{% endif %}>
        <span class="inline-flex h-7 w-7 items-center justify-center rounded-xl">
          {% include 'components/icon.twig' with { name: 'bell', class: 'h-4 w-4 shrink-0' } only %}
        </span>
        <span class="truncate">Notifications</span>
        {% if unread_notification_count|default(0) > 0 %}
          <span class="ml-auto flex h-5 w-5 items-center justify-center rounded-full bg-rose-500 text-[0.65rem] font-bold text-white">
            {{ unread_notification_count > 9 ? '9+' : unread_notification_count }}
          </span>
        {% endif %}
      </a>
    {% endif %}
  {% endif %}

  {% if has_management %}
    <span class="{{ section_header }} {% if has_user_space %}mt-2{% endif %}">Management</span>
    {% if can_users %}
      <a class="{{ nav_link_base }} rounded-2xl border border-transparent {% if currentPath starts with '/admin/users' %}{{ nav_link_active }} border-cyan-300/20 bg-cyan-400/10 shadow-[0_8px_24px_rgba(8,145,178,0.08)]{% else %}{{ nav_link_inactive }} hover:border-white/10 hover:bg-white/5{% endif %}" href="/admin/users" {% if currentPath starts with '/admin/users' %}aria-current="page"{% endif %}>
        <span class="inline-flex h-7 w-7 items-center justify-center rounded-xl">
          {% include 'components/icon.twig' with { name: 'users', class: 'h-4 w-4 shrink-0' } only %}
        </span>
        <span class="truncate">Users</span>
      </a>
    {% endif %}
    {% if can_roles %}
      <a class="{{ nav_link_base }} rounded-2xl border border-transparent {% if currentPath starts with '/admin/roles' %}{{ nav_link_active }} border-cyan-300/20 bg-cyan-400/10 shadow-[0_8px_24px_rgba(8,145,178,0.08)]{% else %}{{ nav_link_inactive }} hover:border-white/10 hover:bg-white/5{% endif %}" href="/admin/roles" {% if currentPath starts with '/admin/roles' %}aria-current="page"{% endif %}>
        <span class="inline-flex h-7 w-7 items-center justify-center rounded-xl">
          {% include 'components/icon.twig' with { name: 'shield', class: 'h-4 w-4 shrink-0' } only %}
        </span>
        <span class="truncate">Roles</span>
      </a>
    {% endif %}
    {% if can_permissions %}
      <a class="{{ nav_link_base }} rounded-2xl border border-transparent {% if currentPath starts with '/admin/permissions' %}{{ nav_link_active }} border-cyan-300/20 bg-cyan-400/10 shadow-[0_8px_24px_rgba(8,145,178,0.08)]{% else %}{{ nav_link_inactive }} hover:border-white/10 hover:bg-white/5{% endif %}" href="/admin/permissions" {% if currentPath starts with '/admin/permissions' %}aria-current="page"{% endif %}>
        <span class="inline-flex h-7 w-7 items-center justify-center rounded-xl">
          {% include 'components/icon.twig' with { name: 'key-round', class: 'h-4 w-4 shrink-0' } only %}
        </span>
        <span class="truncate">Permissions</span>
      </a>
    {% endif %}
    {% if can_activity %}
      <a class="{{ nav_link_base }} rounded-2xl border border-transparent {% if currentPath starts with '/admin/activity' %}{{ nav_link_active }} border-cyan-300/20 bg-cyan-400/10 shadow-[0_8px_24px_rgba(8,145,178,0.08)]{% else %}{{ nav_link_inactive }} hover:border-white/10 hover:bg-white/5{% endif %}" href="/admin/activity" {% if currentPath starts with '/admin/activity' %}aria-current="page"{% endif %}>
        <span class="inline-flex h-7 w-7 items-center justify-center rounded-xl">
          {% include 'components/icon.twig' with { name: 'activity', class: 'h-4 w-4 shrink-0' } only %}
        </span>
        <span class="truncate">Activity</span>
      </a>
    {% endif %}
  {% endif %}

  {% if has_system %}
    <span class="{{ section_header }} {% if has_user_space or has_management %}mt-2{% endif %}">System</span>
    {% if can_settings %}
      <a class="{{ nav_link_base }} rounded-2xl border border-transparent {% if currentPath starts with '/admin/settings' %}{{ nav_link_active }} border-cyan-300/20 bg-cyan-400/10 shadow-[0_8px_24px_rgba(8,145,178,0.08)]{% else %}{{ nav_link_inactive }} hover:border-white/10 hover:bg-white/5{% endif %}" href="/admin/settings" {% if currentPath starts with '/admin/settings' %}aria-current="page"{% endif %}>
        <span class="inline-flex h-7 w-7 items-center justify-center rounded-xl">
          {% include 'components/icon.twig' with { name: 'settings', class: 'h-4 w-4 shrink-0' } only %}
        </span>
        <span class="truncate">Settings</span>
      </a>
    {% endif %}
    {% if can_database %}
      <a class="{{ nav_link_base }} rounded-2xl border border-transparent {% if currentPath starts with '/admin/database' %}{{ nav_link_active }} border-cyan-300/20 bg-cyan-400/10 shadow-[0_8px_24px_rgba(8,145,178,0.08)]{% else %}{{ nav_link_inactive }} hover:border-white/10 hover:bg-white/5{% endif %}" href="/admin/database" {% if currentPath starts with '/admin/database' %}aria-current="page"{% endif %}>
        <span class="inline-flex h-7 w-7 items-center justify-center rounded-xl">
          {% include 'components/icon.twig' with { name: 'database', class: 'h-4 w-4 shrink-0' } only %}
        </span>
        <span class="truncate">Database</span>
      </a>
    {% endif %}
  {% endif %}

  {# Footer #}
  <div class="mt-2 pt-2 border-t border-white/10">
    <a class="{{ nav_link_base }} {{ nav_link_inactive }}" href="/admin/logout">
      {% include 'components/icon.twig' with { name: 'log-out', class: 'h-5 w-5 shrink-0' } only %}
      <span class="truncate">Logout</span>
    </a>
  </div>
</nav>
