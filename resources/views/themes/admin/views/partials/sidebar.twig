{% set currentPath = _current_path|default('') %}
{% set sections = mainMenu|default([]) %}
{% set settings_ui = _settings.ui|default({}) %}
{% set logo_value = settings_ui.logo_url|default('')|trim %}
{% set logo_src = logo_value and not (logo_value starts with('http') or logo_value starts with('/')) ? '/' ~ logo_value : logo_value %}
{% set section_header = 'px-3 py-2 text-[0.65rem] font-extrabold uppercase tracking-wider text-app-muted' %}

<div class="grid gap-3">
  <!-- Mobile Close Button -->
  <div class="flex items-center justify-between lg:hidden">
    <div class="inline-flex items-center gap-3">
      {% if logo_src %}
        <img src="{{ logo_src }}" alt="Admin logo" class="h-10 w-10 rounded-xl border border-app-border bg-app-surface object-contain p-1.5 shadow-[0_20px_50px_rgba(2,6,23,0.18)]">
      {% else %}
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-app-border bg-app-accent/10 text-app-accent shadow-[0_20px_50px_rgba(2,6,23,0.18)]">
          {% include 'components/icon.twig' with { name: 'layout-dashboard', class: 'h-5 w-5' } only %}
        </span>
      {% endif %}
      <div class="grid gap-0.5">
        <span class="text-[0.82rem] font-black uppercase tracking-[0.18em] text-app-text">MarwaPHP</span>
        <span class="text-xs text-app-muted">Console</span>
      </div>
    </div>
    <button
      type="button"
      class="rounded-lg p-2 text-app-muted hover:bg-app-surface-2/60 hover:text-app-text"
      @click="$dispatch('close-mobile')"
    >
      {% include 'components/icon.twig' with { name: 'x', class: 'h-5 w-5' } only %}
    </button>
  </div>

  <!-- Desktop Logo (hidden on mobile) -->
  <div class="hidden lg:inline-flex items-center gap-3">
    {% if logo_src %}
      <img src="{{ logo_src }}" alt="Admin logo" class="h-10 w-10 rounded-xl border border-app-border bg-app-surface object-contain p-1.5 shadow-[0_20px_50px_rgba(2,6,23,0.18)]">
    {% else %}
      <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-app-border bg-app-accent/10 text-app-accent shadow-[0_20px_50px_rgba(2,6,23,0.18)]">
        {% include 'components/icon.twig' with { name: 'layout-dashboard', class: 'h-5 w-5' } only %}
      </span>
    {% endif %}
    <div class="grid gap-0.5">
      <span class="text-[0.82rem] font-black uppercase tracking-[0.18em] text-app-text">MarwaPHP</span>
      <span class="text-xs text-app-muted">Operations console</span>
    </div>
  </div>
</div>

{% set alpine_data = {} %}
{% for section in sections %}
  {% set children = section.children|default([]) %}
  {% if children|length > 1 %}
    {% set key = 'section_' ~ loop.index0 %}
    {% set open = false %}
    {% for child in children %}
      {% if currentPath starts with child.url %}
        {% set open = true %}
      {% endif %}
    {% endfor %}
    {% set alpine_data = alpine_data|merge({(key): open}) %}
  {% endif %}
{% endfor %}

<nav class="grid gap-1" aria-label="Primary" x-data='{ open: {{ alpine_data|json_encode|raw }} }'>
  {% for section in sections %}
    {% set children = section.children|default([]) %}
    {% if children|length > 0 %}
      {% set key = 'section_' ~ loop.index0 %}

      {% if children|length == 1 %}
        {% if loop.first %}
          <span class="{{ section_header }}">{{ section.label }}</span>
          <div class="grid gap-1">
        {% else %}
          <span class="{{ section_header }} mt-2">{{ section.label }}</span>
          <div class="grid gap-1">
        {% endif %}
        {% set child = children[0] %}
        {% set is_active = currentPath starts with child.url %}
        <a class="inline-flex items-center gap-3 rounded-xl px-3 py-2.5 text-[0.82rem] font-semibold transition {% if is_active %}bg-app-accent/10 text-app-accent ring-1 ring-inset ring-app-accent/20{% else %}text-app-muted hover:bg-app-surface-2/60 hover:text-app-text{% endif %}" href="{{ child.url }}"{% if is_active %} aria-current="page"{% endif %}>
          <span class="inline-flex h-7 w-7 items-center justify-center rounded-xl">
            {% if child.icon %}
              {% include 'components/icon.twig' with { name: child.icon, class: 'h-4 w-4 shrink-0' } only %}
            {% endif %}
          </span>
          <span class="truncate">{{ child.label }}</span>
          {% if child.label == 'Notifications' and unread_notification_count|default(0) > 0 %}
            <span class="ml-auto flex h-5 w-5 items-center justify-center rounded-full bg-app-danger text-[0.65rem] font-bold text-white">
              {{ unread_notification_count > 9 ? '9+' : unread_notification_count }}
            </span>
          {% endif %}
        </a>
        </div>
      {% else %}
        {% if loop.first %}
          <span class="{{ section_header }}">{{ section.label }}</span>
        {% else %}
          <span class="{{ section_header }} mt-2">{{ section.label }}</span>
        {% endif %}
        <div class="grid gap-1">
          <button
            type="button"
            class="inline-flex items-center justify-between gap-3 rounded-xl px-3 py-2.5 text-[0.82rem] font-semibold transition"
            :class="open.{{ key }} ? 'bg-app-accent/10 text-app-accent ring-1 ring-inset ring-app-accent/20' : 'text-app-muted hover:bg-app-surface-2/60 hover:text-app-text'"
            @click="open.{{ key }} = !open.{{ key }}"
            :aria-expanded="open.{{ key }}"
          >
            <span class="flex items-center gap-3">
              <span class="inline-flex h-7 w-7 items-center justify-center rounded-xl">
                {% include 'components/icon.twig' with { name: section.icon|default('folder'), class: 'h-4 w-4 shrink-0' } only %}
              </span>
              <span class="truncate">{{ section.label }}</span>
            </span>
            <span class="transition-transform duration-200" :class="open.{{ key }} ? 'rotate-180' : ''">
              {% include 'components/icon.twig' with { name: 'chevron-down', class: 'h-4 w-4 shrink-0' } only %}
            </span>
          </button>
          <div x-show="open.{{ key }}" class="grid gap-1 pl-4">
            {% for child in children %}
              {% set is_active = currentPath starts with child.url %}
              <a class="inline-flex items-center gap-3 rounded-xl px-3 py-2 text-[0.82rem] font-semibold transition {% if is_active %}bg-app-accent/10 text-app-accent{% else %}text-app-muted hover:bg-app-surface-2/60 hover:text-app-text{% endif %}" href="{{ child.url }}"{% if is_active %} aria-current="page"{% endif %}>
                {% if child.icon %}
                  <span class="inline-flex h-5 w-5 items-center justify-center">
                    {% include 'components/icon.twig' with { name: child.icon, class: 'h-4 w-4 shrink-0' } only %}
                  </span>
                {% endif %}
                <span class="truncate">{{ child.label }}</span>
                {% if child.label == 'Notifications' and unread_notification_count|default(0) > 0 %}
                  <span class="ml-auto flex h-5 w-5 items-center justify-center rounded-full bg-app-danger text-[0.65rem] font-bold text-white">
                    {{ unread_notification_count > 9 ? '9+' : unread_notification_count }}
                  </span>
                {% endif %}
              </a>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    {% endif %}
  {% endfor %}

  {# Footer #}
  <div class="mt-2 pt-2 border-t border-app-border">
    <a class="inline-flex items-center gap-3 rounded-xl px-3 py-2.5 text-[0.82rem] font-semibold text-app-muted hover:bg-app-surface-2/60 hover:text-app-text" href="/admin/logout">
      {% include 'components/icon.twig' with { name: 'log-out', class: 'h-5 w-5 shrink-0' } only %}
      <span class="truncate">Logout</span>
    </a>
  </div>
</nav>
