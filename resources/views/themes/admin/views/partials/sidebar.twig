{% set currentPath = _current_path|default('') %}

<div class="admin-brand">
  <span class="admin-brand__mark">
    {% include 'components/icon.twig' with { name: 'layout-dashboard', class: 'admin-brand__icon' } only %}
  </span>
  <div class="admin-brand__copy">
    <span class="admin-brand__title">MarwaPHP</span>
    <span class="admin-brand__sub">Operations console</span>
  </div>
</div>

<nav class="admin-nav" aria-label="Primary">
  <a class="admin-nav__link {% if currentPath == '/admin' %}admin-nav__link--active{% endif %}" href="/admin" {% if currentPath == '/admin' %}aria-current="page"{% endif %}>
    {% include 'components/icon.twig' with { name: 'layout-dashboard', class: 'admin-nav__icon' } only %}
    <span class="admin-nav__label">Dashboard</span>
  </a>
  <a class="admin-nav__link {% if currentPath starts with '/admin/users' %}admin-nav__link--active{% endif %}" href="/admin/users" {% if currentPath starts with '/admin/users' %}aria-current="page"{% endif %}>
    {% include 'components/icon.twig' with { name: 'users', class: 'admin-nav__icon' } only %}
    <span class="admin-nav__label">Users</span>
  </a>
  <a class="admin-nav__link {% if currentPath starts with '/admin/activity' %}admin-nav__link--active{% endif %}" href="/admin/activity" {% if currentPath starts with '/admin/activity' %}aria-current="page"{% endif %}>
    {% include 'components/icon.twig' with { name: 'activity', class: 'admin-nav__icon' } only %}
    <span class="admin-nav__label">Activity</span>
  </a>
  <a class="admin-nav__link" href="/admin/logout">
    {% include 'components/icon.twig' with { name: 'log-out', class: 'admin-nav__icon' } only %}
    <span class="admin-nav__label">Logout</span>
  </a>
</nav>
