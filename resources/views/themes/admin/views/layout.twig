<!doctype html>
<html lang="en" class="h-full scroll-smooth">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="csrf-token" content="{{ csrf|default('') }}">
    <meta name="theme-color" content="#020617">
    <title>{% block title %}{{ title|default('Admin Starter') }}{% endblock %}</title>
    <link rel="stylesheet" href="{{ theme_asset('css/app.css') }}">
  </head>
  <body id="top" class="theme-admin{% if _theme_previewing|default(false) %} theme-admin--previewing{% endif %}">
    <header class="border-b border-white/10 bg-slate-950/70 backdrop-blur">
      <div class="mx-auto flex max-w-7xl flex-col gap-6 px-4 py-6 lg:flex-row lg:items-start lg:justify-between">
        <div class="flex items-start gap-4">
          <img src="{{ theme_asset('images/logo-admin.svg') }}" alt="Admin starter logo" class="h-14 w-14 rounded-[1.25rem] ring-1 ring-white/10">
          <div>
            <p class="eyebrow">Admin starter</p>
            <h1 class="mt-2 text-3xl font-black tracking-tight text-white">
              {% block hero_title %}{{ _theme_meta.label|default('Admin Starter') }}{% endblock %}
            </h1>
            <p class="mt-2 max-w-2xl text-sm leading-7 text-slate-300">
              {% block hero_description %}
                {{ _theme_meta.description|default('A complete admin theme for dashboards, modules, and internal tooling.') }}
              {% endblock %}
            </p>
            <div class="mt-3 flex flex-wrap items-center gap-2 text-[11px] text-slate-400">
              <span class="chip">Theme: {{ _theme_name|replace({'-': ' '})|title }}</span>
              <span class="chip">{% if _theme_previewing|default(false) %}Preview{% else %}Live{% endif %}</span>
              <span class="chip">Chain: {{ _theme_chain|join(' -> ') }}</span>
            </div>
          </div>
        </div>

        <div class="w-full max-w-3xl rounded-[1.75rem] border border-white/10 bg-white/5 p-4 shadow-2xl shadow-black/20 backdrop-blur">
          <div class="mb-3 flex items-center justify-between gap-4">
            <div>
              <p class="text-xs font-black uppercase tracking-[0.24em] text-slate-400">Theme preview</p>
              <p class="mt-1 text-sm text-slate-300">Use the admin starter to preview, switch, and compare themes.</p>
            </div>
            {% if _theme_previewing|default(false) %}
              <div class="text-[11px] text-amber-200">
                Saved: <strong>{{ _theme_selected_meta.label }}</strong>
              </div>
            {% endif %}
          </div>

          <div class="grid gap-3 md:grid-cols-[minmax(0,1fr)_auto_auto]">
            <form method="get" action="/admin" class="flex items-center gap-2">
              <input type="hidden" name="preview" value="1">
              <label for="theme_name" class="sr-only">Theme</label>
              <select id="theme_name" name="theme" class="form-select w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white outline-none ring-0 transition focus:border-cyan-400">
                {% for theme in _theme_catalog %}
                  <option value="{{ theme.name }}" {% if theme.name == _theme_name %}selected{% endif %}>
                    {{ theme.metadata.label }}{% if theme.name != theme.metadata.label %} ({{ theme.name }}){% endif %}
                  </option>
                {% endfor %}
              </select>
              <button type="submit" class="button button--primary whitespace-nowrap">Preview</button>
            </form>

            <a href="/admin" class="button button--ghost whitespace-nowrap">Reset preview</a>
            <a href="/" class="button button--primary whitespace-nowrap">View frontend</a>
          </div>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-6 lg:py-10">
      {% block content %}{% endblock %}
    </main>

    <footer class="border-t border-white/10 bg-slate-950/60 py-6">
      <div class="mx-auto flex max-w-7xl flex-col gap-2 px-4 text-xs text-slate-400 sm:flex-row sm:items-center sm:justify-between">
        <p>Powered by Marwa\Framework + Marwa\View</p>
        <p>{% if _theme_previewing|default(false) %}Previewing {{ _theme_preview }}{% else %}Rendered with {{ _theme_name }}{% endif %}</p>
      </div>
    </footer>
  </body>
</html>
