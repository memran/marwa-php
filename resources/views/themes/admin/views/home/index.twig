{% extends 'admin/layout.twig' %}

{% block title %}Admin dashboard{% endblock %}

{% block body %}
  <section class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
    <article class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-xl shadow-slate-950/20">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p class="text-sm uppercase tracking-[0.2em] text-slate-400">Generated theme</p>
          <h2 class="mt-2 text-3xl font-black text-white">Admin workspace</h2>
        </div>
        <span class="chip">Active</span>
      </div>

      <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">
        This starter admin theme is designed to be extended by modules, dashboards, and internal tools without touching the public site theme.
      </p>

      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-4">
          <p class="text-sm text-slate-400">Navigation</p>
          <p class="mt-2 text-lg font-semibold text-white">Sidebar + topbar</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-4">
          <p class="text-sm text-slate-400">Assets</p>
          <p class="mt-2 text-lg font-semibold text-white">Shared compiled CSS</p>
        </div>
      </div>
    </article>

    <aside class="rounded-3xl border border-white/10 bg-slate-900/70 p-6">
      <p class="text-sm uppercase tracking-[0.2em] text-slate-400">Theme details</p>
      <dl class="mt-4 space-y-4">
        <div>
          <dt class="text-sm text-slate-400">Name</dt>
          <dd class="text-lg font-semibold text-white">{{ _theme_name|replace({'-': ' '})|title }}</dd>
        </div>
        <div>
          <dt class="text-sm text-slate-400">Purpose</dt>
          <dd class="text-lg font-semibold text-white">Backend interface</dd>
        </div>
        <div>
          <dt class="text-sm text-slate-400">Parent</dt>
          <dd class="text-lg font-semibold text-white">default</dd>
        </div>
      </dl>
    </aside>
  </section>
{% endblock %}
