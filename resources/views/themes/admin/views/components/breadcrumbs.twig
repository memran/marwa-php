{% set crumbs = crumbs|default([]) %}

{% if crumbs is not empty %}
  <nav aria-label="Breadcrumb" class="mb-4">
    <ol class="flex flex-wrap items-center gap-2 text-sm">
      {% for crumb in crumbs %}
        <li class="flex items-center gap-2">
          {% if not loop.first %}
            <span class="inline-flex h-4 w-4 items-center justify-center text-app-muted">
              {% include 'components/icon.twig' with { name: 'chevron-right', class: 'h-3.5 w-3.5' } only %}
            </span>
          {% endif %}

          {% if crumb.active or crumb.url is null %}
            <span class="font-semibold {{ loop.last ? 'text-app-text' : 'text-app-muted' }}">{{ crumb.label }}</span>
          {% else %}
            <a href="{{ crumb.url }}" class="font-semibold text-app-muted transition hover:text-app-text">
              {{ crumb.label }}
            </a>
          {% endif %}
        </li>
      {% endfor %}
    </ol>
  </nav>
{% endif %}
