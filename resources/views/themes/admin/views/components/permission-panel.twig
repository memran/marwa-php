{% set title = title|default('Role and permissions') %}
{% set description = description|default('The role controls access, and permissions are inherited from it.') %}
{% set role_name = role_name|default('Unknown') %}
{% set role_slug = role_slug|default('') %}
{% set permissions = permissions|default([]) %}
{% set limit = limit|default(8) %}
{% set count_label = count_label|default(permissions|length ~ ' permissions') %}
{% set empty_message = empty_message|default('No permissions assigned to this role.') %}
{% set grouped_permissions = {} %}

{% for permission in permissions %}
  {% set group_name = permission.getAttribute('group')|default('other')|trim %}
  {% set group_name = group_name is not empty ? group_name : 'other' %}
  {% set grouped_permissions = grouped_permissions|merge({
    (group_name): (grouped_permissions[group_name]|default([]))|merge([permission])
  }) %}
{% endfor %}

<section class="overflow-hidden rounded-[1.5rem] border border-app-border bg-app-surface/80 p-6 shadow-[0_24px_70px_rgba(2,6,23,0.18)] backdrop-blur-xl">
  <div class="flex items-center justify-between gap-3 border-b border-app-border pb-4">
    <div>
      <h2 class="text-lg font-bold tracking-tight text-app-text">{{ title }}</h2>
      <p class="mt-1 text-sm text-app-muted">{{ description }}</p>
    </div>
    <span class="inline-flex items-center rounded-full border border-app-border bg-app-surface-2/70 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-app-text">
      {{ count_label }}
    </span>
  </div>

  <div class="mt-5 space-y-5">
    <div class="rounded-2xl border border-app-border bg-app-surface-2/60 p-4">
      <p class="text-xs font-bold uppercase tracking-[0.16em] text-app-muted">Role</p>
      <p class="mt-2 text-sm font-semibold text-app-text">{{ role_name }}</p>
      <p class="mt-1 text-xs text-app-muted">{{ role_slug ? 'Slug: ' ~ role_slug : 'No role slug available' }}</p>
    </div>

    <div class="rounded-2xl border border-app-border bg-app-surface-2/60 p-4">
      <p class="text-xs font-bold uppercase tracking-[0.16em] text-app-muted">Permissions</p>
      {% if grouped_permissions is not empty %}
        <div class="mt-3 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
          {% for group_name, grouped_items in grouped_permissions %}
            <div class="rounded-2xl border border-app-border bg-app-surface px-4 py-3">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <p class="text-xs font-bold uppercase tracking-[0.16em] text-app-muted">{{ group_name|replace({'_': ' '})|capitalize }}</p>
                  <p class="mt-1 text-xs text-app-muted">{{ grouped_items|length }} permission{{ grouped_items|length == 1 ? '' : 's' }}</p>
                </div>
                <span class="inline-flex shrink-0 items-center rounded-full border border-app-border bg-app-surface-2/70 px-2.5 py-1 text-[0.65rem] font-bold uppercase tracking-[0.16em] text-app-text">
                  {{ group_name }}
                </span>
              </div>

              <div class="mt-3 flex flex-wrap gap-2">
                {% for perm in grouped_items|slice(0, limit) %}
                  <span class="inline-flex items-center rounded-full border border-app-border bg-app-surface-2/70 px-3 py-1 text-xs font-semibold text-app-text">
                    {{ perm.getAttribute('name') }}
                  </span>
                {% endfor %}
                {% if grouped_items|length > limit %}
                  <span class="inline-flex items-center rounded-full border border-app-border bg-app-surface-2/70 px-3 py-1 text-xs font-semibold text-app-muted">
                    +{{ grouped_items|length - limit }} more
                  </span>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <p class="mt-2 text-sm text-app-muted">{{ empty_message }}</p>
      {% endif %}
    </div>
  </div>
</section>
