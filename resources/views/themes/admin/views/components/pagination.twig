<div class="admin-pagination mt-4 flex flex-col gap-3 border-t border-white/10 pt-3 sm:flex-row sm:items-center sm:justify-between">
  <div class="text-xs text-slate-400 sm:text-sm">{{ pagination.summary }}</div>
  <div class="flex flex-wrap gap-1.5">
    {% for link in pagination.links %}
      {% if link.active %}
        <span class="inline-flex h-8 min-w-8 cursor-default select-none items-center justify-center rounded-xl border border-cyan-300/30 bg-cyan-400/10 px-2.5 text-xs font-semibold text-cyan-100" aria-current="page">
          {{ link.page }}
        </span>
      {% else %}
        <a class="inline-flex h-8 min-w-8 items-center justify-center rounded-xl border border-white/10 bg-white/5 px-2.5 text-xs font-semibold text-slate-200 transition hover:bg-white/10" href="{{ link.url }}">
          {{ link.page }}
        </a>
      {% endif %}
    {% endfor %}
  </div>
</div>
