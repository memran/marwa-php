{% set tone = tone|default('neutral') %}
{% set tone_classes = {
  'success': 'border-app-success/20 bg-app-success/10 text-app-success',
  'warning': 'border-app-warning/20 bg-app-warning/10 text-app-warning',
  'danger': 'border-app-danger/20 bg-app-danger/10 text-app-danger',
  'neutral': 'border-app-accent/20 bg-app-accent/10 text-app-accent'
} %}

{% embed 'components/card.twig' with {
  shell_class: 'rounded-[1.1rem] border border-app-border bg-app-surface/60 p-4 shadow-[0_20px_50px_rgba(2,6,23,0.28)] backdrop-blur-xl',
  body_class: 'grid gap-3'
} only %}
  {% block header %}
    <div class="flex items-start justify-between gap-3">
      <p class="text-xs font-semibold uppercase tracking-[0.14em] text-app-muted">{{ label }}</p>
      <span class="inline-flex rounded-xl border px-2.5 py-1 text-[0.68rem] font-bold uppercase tracking-[0.14em] {{ tone_classes[tone]|default(tone_classes.neutral) }}">{{ status }}</span>
    </div>
  {% endblock %}

  {% block body %}
    <p class="text-xl font-black tracking-tight text-app-text">{{ value }}</p>
    <div class="mt-1.5 text-sm text-app-muted">
      <span>{{ meta }}</span>
    </div>
  {% endblock %}
{% endembed %}
