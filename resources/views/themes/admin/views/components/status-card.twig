{% set tone = tone|default('neutral') %}
{% set tone_classes = {
  'success': 'border-emerald-400/20 bg-emerald-400/10 text-emerald-300',
  'warning': 'border-amber-400/20 bg-amber-400/10 text-amber-200',
  'danger': 'border-rose-400/20 bg-rose-500/10 text-rose-200',
  'neutral': 'border-cyan-300/20 bg-cyan-400/10 text-cyan-100'
} %}

<article class="rounded-[1.1rem] border border-white/10 bg-white/5 p-4 shadow-[0_20px_50px_rgba(2,6,23,0.28)] backdrop-blur-xl">
  <div class="flex items-start justify-between gap-3">
    <p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-300">{{ label }}</p>
    <span class="inline-flex rounded-xl border px-2.5 py-1 text-[0.68rem] font-bold uppercase tracking-[0.14em] {{ tone_classes[tone]|default(tone_classes.neutral) }}">{{ status }}</span>
  </div>

  <p class="mt-3 text-xl font-black tracking-tight text-white">{{ value }}</p>
  <div class="mt-1.5 text-sm text-slate-400">
    <span>{{ meta }}</span>
  </div>
</article>
