{% set title = title|default('Activity') %}
{% set description = description|default('Recent activity records') %}
{% set rows = rows|default([]) %}
{% set pagination = pagination|default(null) %}
{% set empty_message = empty_message|default('No activity recorded yet.') %}
{% set count_label = count_label|default(rows|length ~ ' entries') %}
{% set compact = compact|default(false) %}
{% set show_source = show_source|default(not compact) %}
{% set show_actor = show_actor|default(true) %}
{% set show_description = show_description|default(true) %}
{% set show_header = show_header|default(true) %}

<section class="overflow-hidden rounded-[1.5rem] border border-app-border bg-app-surface/80 p-6 shadow-[0_24px_70px_rgba(2,6,23,0.18)] backdrop-blur-xl">
  {% if show_header %}
    <div class="flex items-center justify-between gap-3 border-b border-app-border pb-4">
      <div>
        <h2 class="text-lg font-bold tracking-tight text-app-text">{{ title }}</h2>
        <p class="mt-1 text-sm text-app-muted">{{ description }}</p>
      </div>
      <span class="inline-flex items-center rounded-full border border-app-border bg-app-surface-2/70 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-app-text">
        {{ count_label }}
      </span>
    </div>
  {% endif %}

  {% if rows is not empty %}
    <div class="{{ show_header ? 'mt-5' : '' }} overflow-x-auto">
      <table class="min-w-full divide-y divide-app-border">
        <thead>
          <tr class="text-left text-xs font-bold uppercase tracking-[0.16em] text-app-muted">
            <th class="py-3 pr-4">When</th>
            <th class="py-3 pr-4">{{ compact ? 'Event' : 'Action' }}</th>
            {% if not compact and show_description %}
              <th class="py-3 pr-4">Description</th>
            {% endif %}
            <th class="py-3 pr-4">Details</th>
            {% if show_source %}
              <th class="py-3 pr-4">Source</th>
            {% endif %}
            {% if show_actor %}
              <th class="py-3">Actor</th>
            {% endif %}
          </tr>
        </thead>
        <tbody class="divide-y divide-app-border">
          {% for row in rows %}
            {% set row_action = row.getAttribute('action') %}
            {% set row_description = row.getAttribute('description') ?: row_action %}
            {% set actor_name = row.getAttribute('actor_name') ?: 'System' %}
            {% set actor_email = row.getAttribute('actor_email') %}
            {% set row_source = row.getAttribute('ip_address')|default('') %}
            {% set row_user_agent = row.getAttribute('user_agent')|default('') %}
            <tr class="align-top">
              <td class="whitespace-nowrap py-4 pr-4 text-sm text-app-muted">
                {{ row.getAttribute('created_at') ? row.getAttribute('created_at')|date('M j, Y \\a\\t g:i A') : 'N/A' }}
              </td>
              <td class="py-4 pr-4">
                {% if compact %}
                  <div class="text-sm font-semibold text-app-text">{{ row_description }}</div>
                  <div class="mt-1 font-mono text-[0.72rem] uppercase tracking-[0.16em] text-app-muted">
                    {{ row_action|replace({'.': ' • ', '_': ' '}) }}
                  </div>
                {% else %}
                  <span class="inline-flex rounded-full border border-cyan-300/20 bg-cyan-400/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-cyan-100">
                    {{ row_action }}
                  </span>
                {% endif %}
              </td>
              {% if not compact and show_description %}
                <td class="py-4 pr-4 text-sm text-app-text">
                  {{ row_description }}
                </td>
              {% endif %}
              <td class="py-4 pr-4 text-sm leading-6 text-app-muted">
                {{ row.readableDetails() }}
              </td>
              {% if show_source %}
                <td class="py-4 pr-4">
                  <div class="grid gap-0.5">
                    <span class="font-semibold text-app-text">{{ row_source|ip_format }}</span>
                    <span class="max-w-xs break-words text-sm text-app-muted">{{ row_user_agent|ua_summary(72) }}</span>
                  </div>
                </td>
              {% endif %}
              {% if show_actor %}
                <td class="py-4 text-sm text-app-text">
                  <div class="font-medium">{{ actor_name }}</div>
                  {% if actor_email %}
                    <div class="mt-1 break-all text-xs text-app-muted">{{ actor_email }}</div>
                  {% endif %}
                </td>
              {% endif %}
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {% if pagination is not null and pagination.hasPages %}
      <div class="mt-5 flex flex-col gap-3 border-t border-app-border pt-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="text-xs text-app-muted sm:text-sm">{{ pagination.summary }}</div>
        <div class="flex flex-wrap gap-1.5">
          {% for link in pagination.pages %}
            {% if link.disabled %}
              <span class="inline-flex h-8 min-w-8 items-center justify-center rounded-xl border border-app-border bg-app-surface/70 px-2.5 text-xs font-semibold text-app-muted">
                {{ link.label }}
              </span>
            {% elseif link.active %}
              <span class="inline-flex h-8 min-w-8 items-center justify-center rounded-xl border px-2.5 text-xs font-semibold border-app-accent/20 bg-app-accent/10 text-app-accent" aria-current="page">
                {{ link.label }}
              </span>
            {% else %}
              <a
                class="inline-flex h-8 min-w-8 items-center justify-center rounded-xl border px-2.5 text-xs font-semibold transition border-app-border bg-app-surface/70 text-app-text hover:bg-app-surface-2/70"
                href="{{ link.url }}"
              >
                {{ link.label }}
              </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  {% else %}
    <div class="mt-5 rounded-2xl border border-dashed border-app-border bg-app-surface-2/60 p-6 text-sm text-app-muted">
      {{ empty_message }}
    </div>
  {% endif %}
</section>
