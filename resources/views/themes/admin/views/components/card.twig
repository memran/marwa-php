{% set shell_class = shell_class|default('overflow-hidden rounded-[1.25rem] border border-app-border bg-app-surface/80 p-4 shadow-[0_30px_80px_rgba(2,6,23,0.45)] backdrop-blur-xl sm:p-5') %}
{% set header_class = header_class|default('') %}
{% set body_class = body_class|default('grid gap-4') %}
{% set footer_class = footer_class|default('') %}

{% set header_content %}
  {% block header %}{% endblock %}
{% endset %}

{% set body_content %}
  {% block body %}{% endblock %}
{% endset %}

{% set footer_content %}
  {% block footer %}{% endblock %}
{% endset %}

<section class="{{ shell_class }}">
  <div class="{{ body_class }}">
    {% if header_content|trim is not empty %}
      <div class="{{ header_class }}">
        {{ header_content|raw }}
      </div>
    {% endif %}

    {% if body_content|trim is not empty %}
      <div>
        {{ body_content|raw }}
      </div>
    {% endif %}

    {% if footer_content|trim is not empty %}
      <div class="{{ footer_class }}">
        {{ footer_content|raw }}
      </div>
    {% endif %}
  </div>
</section>
