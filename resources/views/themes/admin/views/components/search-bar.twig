{% set field_id = id|default(name|default('q')) %}
{% set field_name = name|default('q') %}
{% set field_value = value|default('') %}
{% set action_items = actions|default([]) %}
{% set submit_label = submit_label|default('Search') %}
{% set clear_label = clear_label|default('Clear search') %}

<form class="admin-search group w-full max-w-full" method="{{ method|default('get') }}" action="{{ action }}">
  <div class="flex min-w-0 flex-wrap items-center gap-2 rounded-[1.2rem] border border-white/10 bg-slate-950/40 px-3 py-2 text-sm text-slate-100 shadow-[0_24px_60px_rgba(2,6,23,0.22)] backdrop-blur-xl transition focus-within:border-cyan-300/50 focus-within:bg-slate-950/55 focus-within:ring-4 focus-within:ring-cyan-400/10 lg:flex-nowrap">
    <div class="flex min-w-[14rem] flex-1 items-center gap-2">
      <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-white/5 text-slate-400 transition group-focus-within:text-cyan-100" aria-hidden="true">
        {% include 'components/icon.twig' with { name: 'search', class: 'h-4 w-4' } only %}
      </span>
      <div class="min-w-0 flex-1">
        {% if aria_label is defined and aria_label %}
          <label class="sr-only" for="{{ field_id }}">{{ aria_label }}</label>
        {% endif %}
        <input
          id="{{ field_id }}"
          class="w-full border-0 bg-transparent px-0 py-0 text-sm text-slate-100 placeholder:text-slate-500 outline-none ring-0 focus:ring-0"
          type="search"
          name="{{ field_name }}"
          value="{{ field_value }}"
          placeholder="{{ placeholder|default('Search') }}"
          autocomplete="off"
          spellcheck="false"
          {% if aria_label is defined and aria_label %}aria-label="{{ aria_label }}"{% endif %}
        >
      </div>
    </div>

    {% if action_items is not empty %}
      <div class="flex min-w-0 flex-wrap items-center gap-1">
        {% for item in action_items %}
          {% set item_label = item.label|default('Action') %}
          {% set item_icon = item.icon|default('chevron-right') %}
          {% set item_class = item.class|default('') %}
          {% set item_title = item.title|default(item_label) %}
          {% set item_disabled = item.disabled|default(false) %}
          {% set item_type = item.type|default('link') %}
          {% if item_type == 'button' %}
            <button
              class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/5 text-slate-100 transition hover:bg-white/10 hover:text-white disabled:cursor-not-allowed disabled:opacity-50 disabled:hover:bg-white/5 disabled:hover:text-slate-100 {{ item_class }}"
              type="{{ item.button_type|default('button') }}"
              {% if item_title %}title="{{ item_title }}"{% endif %}
              {% if item_disabled %}disabled aria-disabled="true"{% endif %}
              {% if item.onclick is defined and not item_disabled %}onclick="{{ item.onclick }}"{% endif %}
            >
              <span class="sr-only">{{ item_label }}</span>
              {% include 'components/icon.twig' with { name: item_icon, class: 'h-4 w-4 shrink-0' } only %}
            </button>
          {% elseif item_disabled %}
            <span
              class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/5 text-slate-100 opacity-50 {{ item_class }}"
              {% if item_title %}title="{{ item_title }}"{% endif %}
              aria-disabled="true"
            >
              <span class="sr-only">{{ item_label }}</span>
              {% include 'components/icon.twig' with { name: item_icon, class: 'h-4 w-4 shrink-0' } only %}
            </span>
          {% else %}
            <a
              class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/5 text-slate-100 transition hover:bg-white/10 hover:text-white {{ item_class }}"
              href="{{ item.href|default(action) }}"
              {% if item_title %}title="{{ item_title }}"{% endif %}
              {% if item.target is defined and item.target %}target="{{ item.target }}"{% endif %}
              {% if item.rel is defined and item.rel %}rel="{{ item.rel }}"{% endif %}
            >
              <span class="sr-only">{{ item_label }}</span>
              {% include 'components/icon.twig' with { name: item_icon, class: 'h-4 w-4 shrink-0' } only %}
            </a>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {% if field_value %}
      <a
        class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/5 text-slate-300 transition hover:bg-white/10 hover:text-white"
        href="{{ action }}"
        title="{{ clear_label }}"
      >
        <span class="sr-only">{{ clear_label }}</span>
        {% include 'components/icon.twig' with { name: 'x', class: 'h-4 w-4 shrink-0' } only %}
      </a>
    {% endif %}

    <button
      class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-white text-slate-950 transition hover:bg-cyan-200"
      type="submit"
      title="{{ submit_label }}"
    >
      <span class="sr-only">{{ submit_label }}</span>
      {% include 'components/icon.twig' with { name: 'search', class: 'h-4 w-4 shrink-0' } only %}
    </button>
  </div>
</form>
