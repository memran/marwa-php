<form class="admin-search flex w-full max-w-sm items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-3 py-2 text-sm text-slate-100 shadow-[0_20px_50px_rgba(2,6,23,0.18)] backdrop-blur-xl focus-within:border-cyan-300/40 focus-within:ring-2 focus-within:ring-cyan-300/20" method="{{ method|default('get') }}" action="{{ action }}">
  <span class="text-slate-400" aria-hidden="true">⌕</span>
  <input
    class="w-full bg-transparent text-slate-100 placeholder:text-slate-400 focus:outline-none"
    type="search"
    name="{{ name|default('q') }}"
    value="{{ value|default('') }}"
    placeholder="{{ placeholder|default('Search') }}"
    {% if aria_label is defined and aria_label %}aria-label="{{ aria_label }}"{% endif %}
  >
</form>
