{% set tone = toast.tone|default('info') %}
{% set tone_classes = {
  success: {
    shell: 'border-app-success/30 bg-app-success/12',
    accent: 'bg-app-success',
    icon: 'bg-app-success/20 text-app-success',
    title: 'text-app-success'
  },
  warning: {
    shell: 'border-app-warning/30 bg-app-warning/12',
    accent: 'bg-app-warning',
    icon: 'bg-app-warning/20 text-app-warning',
    title: 'text-app-warning'
  },
  error: {
    shell: 'border-app-danger/30 bg-app-danger/12',
    accent: 'bg-app-danger',
    icon: 'bg-app-danger/20 text-app-danger',
    title: 'text-app-danger'
  },
  info: {
    shell: 'border-app-accent/30 bg-app-accent/12',
    accent: 'bg-app-accent',
    icon: 'bg-app-accent/20 text-app-accent',
    title: 'text-app-accent'
  }
} %}
{% set tone_config = tone_classes[tone]|default(tone_classes.info) %}

<article
  x-data="{ open: true }"
  x-init="window.setTimeout(() => open = false, 5500)"
  x-show="open"
  x-transition:enter="transition ease-out duration-200"
  x-transition:enter-start="opacity-0 translate-y-2 scale-[0.98]"
  x-transition:enter-end="opacity-100 translate-y-0 scale-100"
  x-transition:leave="transition ease-in duration-150"
  x-transition:leave-start="opacity-100 translate-y-0 scale-100"
  x-transition:leave-end="opacity-0 translate-y-2 scale-[0.98]"
  data-toast-tone="{{ tone }}"
  class="pointer-events-auto overflow-hidden rounded-2xl border-l-4 border bg-app-surface/96 shadow-[0_20px_50px_rgba(2,6,23,0.18)] backdrop-blur-xl {{ tone_config.shell }}"
>
  <div class="flex items-start gap-3 p-4">
    <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full {{ tone_config.icon }}">
      {% include 'components/icon.twig' with { name: toast.icon|default('badge-info'), class: 'h-4 w-4' } only %}
    </div>

    <div class="min-w-0 flex-1">
      <div class="mb-2 h-1 w-10 rounded-full {{ tone_config.accent }}"></div>
      <p class="text-sm font-bold text-app-text">{{ toast.title|default('Notice') }}</p>
      <p class="mt-1 text-sm leading-6 text-app-muted">{{ toast.message|default('') }}</p>
    </div>

    <button
      type="button"
      class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-app-border text-app-muted transition hover:text-app-text"
      @click="open = false"
    >
      <span class="sr-only">Dismiss</span>
      {% include 'components/icon.twig' with { name: 'x', class: 'h-4 w-4' } only %}
    </button>
  </div>
</article>
