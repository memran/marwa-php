<div class="{{ wrapper_class|default('grid gap-2') }}">
  <label class="text-[0.82rem] font-semibold text-app-text" for="{{ id }}">{{ label }}</label>
  {% if hint is defined and hint %}
    <p class="text-xs leading-5 text-app-muted">{{ hint }}</p>
  {% endif %}

  {% if type|default('text') == 'textarea' %}
    <textarea
      class="form-textarea w-full rounded-xl border border-app-border bg-app-surface px-3 py-2 text-sm text-app-text placeholder:text-slate-400 dark:placeholder:text-slate-300 outline-none transition focus:border-app-accent focus:ring-2 focus:ring-app-accent/10 disabled:cursor-not-allowed disabled:opacity-60"
      id="{{ id }}"
      name="{{ name|default(id) }}"
      rows="{{ rows|default(3) }}"
      {% if placeholder is defined and placeholder %}placeholder="{{ placeholder }}"{% endif %}
      {% if disabled|default(false) %}disabled{% endif %}
    >{{ value|default('') }}</textarea>
  {% elseif type|default('text') == 'select' %}
    <select
      class="form-select w-full rounded-xl border border-app-border bg-app-surface px-3 py-2 text-sm text-app-text outline-none transition focus:border-app-accent focus:ring-1 focus:ring-app-accent/10 disabled:cursor-not-allowed disabled:opacity-60"
      id="{{ id }}"
      name="{{ name|default(id) }}"
      {% if disabled|default(false) %}disabled{% endif %}
    >
      {% for option_value, option_label in options|default([]) %}
        <option value="{{ option_value }}" {% if value is defined and value == option_value %}selected{% endif %}>{{ option_label }}</option>
      {% endfor %}
    </select>
  {% else %}
    <input
      class="form-input w-full rounded-xl border border-app-border bg-app-surface px-3 py-2 text-sm text-app-text placeholder:text-slate-400 dark:placeholder:text-slate-300 outline-none transition focus:border-app-accent focus:ring-2 focus:ring-app-accent/10 disabled:cursor-not-allowed disabled:opacity-60"
      id="{{ id }}"
      name="{{ name|default(id) }}"
      type="{{ type|default('text') }}"
      value="{{ value|default('') }}"
      {% if placeholder is defined and placeholder %}placeholder="{{ placeholder }}"{% endif %}
      {% if autocomplete is defined and autocomplete %}autocomplete="{{ autocomplete }}"{% endif %}
      {% if readonly|default(false) %}readonly{% endif %}
      {% if disabled|default(false) %}disabled{% endif %}
    >
  {% endif %}

  {% if error is defined and error %}
    <p class="text-xs text-app-danger">{{ error }}</p>
  {% endif %}

  {% if success is defined and success %}
    <p class="text-xs text-app-success">{{ success }}</p>
  {% endif %}
</div>
