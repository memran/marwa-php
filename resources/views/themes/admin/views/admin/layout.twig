{% extends 'layout.twig' %}

{% block content %}
  <div class="admin-shell grid gap-6 lg:grid-cols-[300px_minmax(0,1fr)]">
    <aside class="rounded-[1.75rem] border border-white/10 bg-white/5 p-5 shadow-xl shadow-black/20 backdrop-blur">
      <div class="flex items-center gap-3">
        <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-cyan-400 text-sm font-black text-slate-950">A</div>
        <div>
          <p class="text-sm font-black uppercase tracking-[0.2em] text-cyan-200">Admin shell</p>
          <p class="text-sm text-slate-400">Starter dashboard layout</p>
        </div>
      </div>

      <nav class="mt-6 space-y-2">
        {% block sidebar %}
          {% set nav_items = _admin_menu|default([
            {'label': 'Overview', 'hint': 'Dashboard', 'url': '/admin', 'active': true},
            {'label': 'Modules', 'hint': 'Packages', 'url': '/admin#modules', 'active': false},
            {'label': 'Themes', 'hint': 'Preview', 'url': '/admin#themes', 'active': false},
            {'label': 'Settings', 'hint': 'Config', 'url': '/admin#settings', 'active': false},
          ]) %}

          {% for item in nav_items %}
            <a href="{{ item.url }}"
               class="flex items-center justify-between rounded-2xl border px-4 py-3 text-sm transition {% if item.active %}border-cyan-400/30 bg-cyan-400/10 text-white{% else %}border-white/10 bg-white/5 text-slate-300 hover:border-white/20 hover:bg-white/10{% endif %}">
              <span>
                <strong class="block text-sm font-bold">{{ item.label }}</strong>
                <span class="text-xs text-slate-400">{{ item.hint }}</span>
              </span>
              <span class="text-xs uppercase tracking-[0.18em] text-slate-400">{% if item.active %}Active{% else %}Open{% endif %}</span>
            </a>
          {% endfor %}
        {% endblock %}
      </nav>

      <div class="mt-6 rounded-3xl border border-white/10 bg-slate-950/60 p-4">
        <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-400">Theme details</p>
        <dl class="mt-4 space-y-3 text-sm">
          <div>
            <dt class="text-slate-400">Label</dt>
            <dd class="font-semibold text-white">{{ _theme_meta.label }}</dd>
          </div>
          <div>
            <dt class="text-slate-400">Mode</dt>
            <dd class="font-semibold text-white">{% if _theme_previewing|default(false) %}Preview{% else %}Live{% endif %}</dd>
          </div>
          <div>
            <dt class="text-slate-400">Parent</dt>
            <dd class="font-semibold text-white">default</dd>
          </div>
        </dl>
      </div>
    </aside>

    <section class="grid gap-6">
      <header class="rounded-[1.75rem] border border-white/10 bg-white/5 p-5 shadow-xl shadow-black/20 backdrop-blur">
        <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
          <div>
            <p class="eyebrow">{% block eyebrow %}Backend workspace{% endblock %}</p>
            <h2 class="mt-2 text-3xl font-black tracking-tight text-white">{% block topbar_title %}{{ title|default('Admin dashboard') }}{% endblock %}</h2>
            <p class="mt-2 max-w-3xl text-sm leading-7 text-slate-300">
              {% block subtitle %}A complete admin starter layout for application modules, settings, and operator workflows.{% endblock %}
            </p>
          </div>

          <div class="flex flex-wrap items-center gap-2">
            {% block topbar_actions %}
              <span class="chip">Active: {{ _admin_theme|replace({'-': ' '})|title }}</span>
              <span class="chip">{% if _theme_previewing|default(false) %}Preview mode{% else %}Live mode{% endif %}</span>
            {% endblock %}
          </div>
        </div>
      </header>

      <div class="grid gap-6">
        {% block body_before %}{% endblock %}
        {% block body %}{% endblock %}
      </div>
    </section>
  </div>

  <div class="mt-6 rounded-[1.75rem] border border-white/10 bg-white/5 px-5 py-4 text-sm text-slate-300">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
      <p>Use this shell for module dashboards, settings screens, and admin pages.</p>
      <p class="text-xs uppercase tracking-[0.18em] text-slate-400">Theme: {{ _admin_theme }}</p>
    </div>
  </div>
{% endblock %}
