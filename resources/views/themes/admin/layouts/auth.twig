<!DOCTYPE html>
<html lang="en" data-theme="admin">
<head>
    {% include 'partials/head.twig' %}
    <title>{% block title %}Admin Access{% endblock %}</title>
    {% block styles %}{% endblock %}
    <script>
        (function() {
            var theme = localStorage.getItem('marwa-admin-theme') || localStorage.getItem('marwa-auth-theme');
            var preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
            var finalTheme = (theme === 'light' || theme === 'dark') ? theme : preferred;
            document.documentElement.dataset.adminTheme = finalTheme;
            document.documentElement.style.colorScheme = finalTheme;
            localStorage.setItem('marwa-admin-theme', finalTheme);
            localStorage.setItem('marwa-auth-theme', finalTheme);
        })();
    </script>
</head>
<body class="auth-theme admin-theme theme-auth min-h-screen bg-app-bg text-app-text antialiased">
    <div class="relative isolate min-h-screen overflow-hidden bg-[linear-gradient(135deg,#f8fafc_0%,#eef6ff_52%,#e2e8f0_100%)] dark:bg-[linear-gradient(135deg,#020617_0%,#071426_52%,#020617_100%)]">
        <div class="pointer-events-none absolute inset-0 opacity-50 dark:opacity-35" style="background-image: linear-gradient(rgba(148,163,184,0.12) 1px, transparent 1px), linear-gradient(90deg, rgba(148,163,184,0.12) 1px, transparent 1px); background-size: 4rem 4rem;"></div>
        <div class="pointer-events-none absolute left-[-7rem] top-[-8rem] h-80 w-80 rounded-full blur-3xl" style="background-color: rgba(var(--app-accent), 0.16);"></div>
        <div class="pointer-events-none absolute bottom-[-10rem] right-[-8rem] h-96 w-96 rounded-full blur-3xl" style="background-color: rgba(var(--app-success), 0.14);"></div>

        <div class="relative z-10 grid min-h-screen lg:grid-cols-[minmax(30rem,0.92fr)_minmax(0,1.08fr)]">
            <aside class="theme-auth__brand-panel relative hidden min-h-screen overflow-hidden bg-[linear-gradient(180deg,#071b33_0%,#041326_100%)] text-white lg:block">
                <div class="pointer-events-none absolute inset-0 opacity-25" style="background-image: linear-gradient(rgba(255,255,255,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.06) 1px, transparent 1px); background-size: 3.5rem 3.5rem;"></div>
                <div class="pointer-events-none absolute -left-24 top-24 h-72 w-72 rounded-full bg-sky-400/20 blur-3xl"></div>
                <div class="pointer-events-none absolute bottom-12 right-[-8rem] h-96 w-96 rounded-full bg-emerald-400/10 blur-3xl"></div>

                <div class="relative flex min-h-screen flex-col justify-between px-10 py-9 xl:px-12">
                    <div class="space-y-14">
                        <a href="/" class="flex items-center gap-3">
                            <div class="flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/10 shadow-[0_12px_32px_rgba(2,6,23,0.24)]">
                                {% include 'components/icon.twig' with { name: 'gem', class: 'h-5 w-5 text-sky-200' } only %}
                            </div>
                            <div>
                                <p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-slate-300">Marwa-PHP</p>
                                <p class="text-lg font-semibold tracking-tight text-white">Admin Starter</p>
                            </div>
                        </a>

                        <div class="max-w-[38rem] space-y-5">
                            <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-[0.7rem] font-semibold uppercase tracking-[0.22em] text-slate-200">
                                <span class="h-2 w-2 rounded-full bg-emerald-400 shadow-[0_0_0_4px_rgba(52,211,153,0.16)]"></span>
                                Secure admin workspace
                            </span>
                            <h1 class="text-4xl font-semibold leading-tight tracking-tight text-white xl:text-5xl">
                                Manage the starter application from one polished console.
                            </h1>
                            <p class="max-w-md text-sm leading-6 text-slate-300">
                                A focused control surface for users, roles, permissions, settings, and operational workflows.
                            </p>
                        </div>

                        <div class="grid max-w-[38rem] gap-3">
                            <div class="flex items-start gap-4 rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur">
                                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-sky-400/15 text-sky-100">
                                    {% include 'components/icon.twig' with { name: 'shield-check', class: 'h-5 w-5' } only %}
                                </div>
                                <div>
                                    <p class="text-sm font-semibold text-white">Permission aware</p>
                                    <p class="mt-1 text-sm leading-5 text-slate-300">Role based access and module navigation stay consistent after sign in.</p>
                                </div>
                            </div>
                            <div class="flex items-start gap-4 rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur">
                                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-emerald-400/15 text-emerald-100">
                                    {% include 'components/icon.twig' with { name: 'activity', class: 'h-5 w-5' } only %}
                                </div>
                                <div>
                                    <p class="text-sm font-semibold text-white">Operationally ready</p>
                                    <p class="mt-1 text-sm leading-5 text-slate-300">Built for repeat admin work with clear hierarchy and low visual noise.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="relative mt-12 rounded-[2rem] border border-white/10 bg-white/5 p-5 shadow-[0_24px_70px_rgba(2,6,23,0.28)] backdrop-blur">
                        <div class="flex items-center justify-between gap-4">
                            <div>
                                <p class="text-[0.7rem] font-semibold uppercase tracking-[0.24em] text-slate-300">System summary</p>
                                <p class="mt-1 text-lg font-semibold text-white">Ready for secure access</p>
                            </div>
                            <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white/10 text-sky-100">
                                {% include 'components/icon.twig' with { name: 'lock-keyhole', class: 'h-6 w-6' } only %}
                            </div>
                        </div>
                        <div class="mt-5 grid grid-cols-3 gap-3">
                            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                                <p class="text-[0.68rem] uppercase tracking-[0.2em] text-slate-300">Modules</p>
                                <p class="mt-2 text-2xl font-semibold text-white">Live</p>
                            </div>
                            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                                <p class="text-[0.68rem] uppercase tracking-[0.2em] text-slate-300">Access</p>
                                <p class="mt-2 text-2xl font-semibold text-white">RBAC</p>
                            </div>
                            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                                <p class="text-[0.68rem] uppercase tracking-[0.2em] text-slate-300">Theme</p>
                                <p class="mt-2 text-2xl font-semibold text-white">Admin</p>
                            </div>
                        </div>
                    </div>
                </div>
            </aside>

            <main class="{% block auth_main_class %}relative flex min-h-screen w-full items-center justify-center px-5 py-8 sm:px-8 lg:px-12 xl:px-16{% endblock %}">
                <div class="absolute left-0 right-0 top-0 flex items-center justify-between px-5 py-5 sm:px-8 lg:px-12 xl:px-16">
                    <a href="/" class="flex items-center gap-3 lg:hidden">
                        <div class="flex h-10 w-10 items-center justify-center rounded-2xl border border-app-accent/20 bg-app-accent/10">
                            {% include 'components/icon.twig' with { name: 'gem', class: 'h-5 w-5 text-app-accent' } only %}
                        </div>
                        <div>
                            <p class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-app-muted">Marwa-PHP</p>
                            <p class="text-base font-semibold text-app-text">Admin Starter</p>
                        </div>
                    </a>
                    <span class="hidden lg:block"></span>

                    <button
                        type="button"
                        class="inline-flex h-11 items-center justify-center gap-2 rounded-xl border border-app-border bg-app-surface/80 px-3 text-sm font-medium text-app-text shadow-sm backdrop-blur-xl transition hover:border-app-accent/30 hover:bg-app-surface hover:text-app-accent"
                        aria-label="Toggle theme"
                        title="Toggle theme"
                        onclick="
                            (function() {
                                var current = document.documentElement.dataset.adminTheme || 'dark';
                                var next = current === 'dark' ? 'light' : 'dark';
                                document.documentElement.dataset.adminTheme = next;
                                document.documentElement.style.colorScheme = next;
                                localStorage.setItem('marwa-admin-theme', next);
                                localStorage.setItem('marwa-auth-theme', next);
                            })();
                        "
                    >
                        {% include 'components/icon.twig' with { name: 'moon', class: 'h-4 w-4 shrink-0 dark:hidden' } only %}
                        {% include 'components/icon.twig' with { name: 'sun', class: 'h-4 w-4 shrink-0 hidden dark:block' } only %}
                        <span class="hidden sm:inline">Theme</span>
                    </button>
                </div>

                <section class="{% block auth_card_class %}theme-auth__card w-full max-w-[46rem] pt-20 lg:pt-0{% endblock %}">
                    <div class="overflow-hidden rounded-[2rem] border border-app-border bg-app-surface/90 shadow-[0_24px_80px_rgba(15,23,42,0.12)] backdrop-blur-xl dark:shadow-[0_30px_80px_rgba(2,6,23,0.45)]">
                        <div class="border-b border-app-border/70 bg-app-surface-2/40 px-6 py-5 sm:px-8">
                            <p class="text-[0.7rem] font-semibold uppercase tracking-[0.24em] text-app-muted">Administrator login</p>
                            <p class="mt-1 text-sm text-app-muted">Use your authorized credentials to continue.</p>
                        </div>
                        <div class="px-6 py-7 sm:px-8 sm:py-8 lg:px-10 lg:py-10">
                            {% block content %}{% endblock %}
                        </div>
                    </div>
                </section>
            </main>
        </div>
    </div>

    {% include 'partials/scripts.twig' %}
    {% block scripts %}{% endblock %}
</body>
</html>
