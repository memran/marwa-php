{% set currentPath = _current_path|default('') %}
{% set sections = mainMenu|default([]) %}
{% set settings_ui = _settings.ui|default({}) %}
{% set logo_value = settings_ui.logo_url|default('')|trim %}
{% set logo_src = logo_value and not (logo_value starts with('http') or logo_value starts with('/')) ? '/' ~ logo_value : logo_value %}

<div class="theme-sidebar__brand-panel grid gap-5">
  <div class="flex items-center justify-between gap-3">
    <a href="/admin" class="inline-flex min-w-0 items-center gap-3">
      {% if logo_src %}
        <img src="{{ logo_src }}" alt="Executive logo" class="h-9 w-9 shrink-0 rounded-xl object-contain">
      {% else %}
        <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-white/8 text-white">
          {% include 'components/icon.twig' with { name: 'layout-dashboard', class: 'h-5 w-5' } only %}
        </span>
      {% endif %}
      <span class="grid min-w-0">
        <span class="truncate text-sm font-semibold uppercase tracking-[0.18em] text-white">MARWA-PHP</span>
        <span class="truncate text-xs text-slate-300">Executive</span>
      </span>
    </a>

    <button
      type="button"
      class="rounded-lg p-2 text-slate-300 transition hover:bg-white/8 hover:text-white lg:hidden"
      data-theme-sidebar-close
      aria-label="Close sidebar"
    >
      {% include 'components/icon.twig' with { name: 'x', class: 'h-5 w-5' } only %}
    </button>
  </div>

  <nav class="grid gap-6" aria-label="Primary">
    {% for section in sections %}
      {% set children = section.children|default([]) %}
      {% if children|length > 0 %}
        <div class="grid gap-3">
          <p class="px-1 text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-slate-400">
            {{ section.label|default('Section') }}
          </p>

          <div class="grid gap-1">
            {% for child in children %}
              {% set is_active = currentPath == child.url or currentPath starts with(child.url ~ '/') %}
              <a
                href="{{ child.url }}"
                class="theme-sidebar__link flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium transition {% if is_active %}bg-[#1E3A8A] text-white shadow-sm{% else %}text-slate-300 hover:bg-white/8 hover:text-white{% endif %}"
                {% if is_active %}aria-current="page"{% endif %}
              >
                <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-xl {% if is_active %}bg-white/10{% else %}bg-white/8{% endif %}">
                  {% if child.icon %}
                    {% include 'components/icon.twig' with { name: child.icon, class: 'h-5 w-5 shrink-0' } only %}
                  {% endif %}
                </span>
                <span class="truncate">{{ child.label }}</span>

                {% if child.label == 'Updates' %}
                  <span class="ml-auto inline-flex items-center rounded-lg bg-blue-500 px-2 py-0.5 text-[0.65rem] font-semibold text-white">
                    3
                  </span>
                {% endif %}
              </a>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </nav>

</div>
