{% set name = name|default('select') %}
{% set label = label|default('') %}
{% set options = options|default([]) %}
{% set value = value|default('') %}
{% set class = class|default('') %}

<label class="grid gap-1.5">
  {% if label %}
    <span class="text-sm font-medium text-slate-700">{{ label }}</span>
  {% endif %}
  <select
    name="{{ name }}"
    class="h-11 w-full rounded-xl border border-slate-200 bg-white px-3.5 text-sm text-slate-700 outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 {{ class }}"
  >
    {% for optionValue, optionLabel in options %}
      <option value="{{ optionValue }}"{% if optionValue == value %} selected{% endif %}>{{ optionLabel }}</option>
    {% endfor %}
  </select>
</label>
