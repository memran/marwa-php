{% set pagination = pagination|default(null) %}

{% if pagination %}
  <nav class="theme-pagination mt-4 flex flex-wrap items-center justify-between gap-3 text-sm" aria-label="Pagination">
    <span class="text-slate-500">{{ pagination.total }} total</span>
    <div class="flex flex-wrap items-center gap-2">
      {% for page in pagination.pages() %}
        {% if page.disabled %}
          <span class="inline-flex h-10 min-w-10 items-center justify-center rounded-xl border border-slate-200 bg-slate-50 px-3 text-slate-400">...</span>
        {% elseif page.active %}
          <span class="inline-flex h-10 min-w-10 items-center justify-center rounded-xl border border-blue-600 bg-blue-600 px-3 font-medium text-white">{{ page.label }}</span>
        {% else %}
          <a href="{{ page.url }}" class="inline-flex h-10 min-w-10 items-center justify-center rounded-xl border border-slate-200 bg-white px-3 text-slate-700 transition hover:bg-slate-50">{{ page.label }}</a>
        {% endif %}
      {% endfor %}
    </div>
  </nav>
{% endif %}
