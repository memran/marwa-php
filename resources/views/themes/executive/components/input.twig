{% set name = name|default('input') %}
{% set label = label|default('') %}
{% set type = type|default('text') %}
{% set value = value|default('') %}
{% set class = class|default('') %}

<label class="grid gap-1.5">
  {% if label %}
    <span class="text-sm font-semibold text-app-text">{{ label }}</span>
  {% endif %}
  <input
    name="{{ name }}"
    type="{{ type }}"
    value="{{ value }}"
    class="w-full rounded-xl border border-app-border bg-app-surface/70 px-3 py-2.5 text-sm text-app-text outline-none transition placeholder:text-app-muted focus:border-app-accent focus:ring-2 focus:ring-app-accent/20 {{ class }}"
  >
</label>
