{% set label = label|default('Button') %}
{% set type = type|default('button') %}
{% set variant = variant|default('primary') %}
{% set class = class|default('') %}
{% set base = 'inline-flex h-11 items-center justify-center gap-2 rounded-xl px-4 text-sm font-medium transition focus:outline-none focus:ring-2 focus:ring-blue-500/20' %}
{% set variants = {
  'primary': 'border border-transparent bg-blue-600 text-white hover:bg-blue-700',
  'secondary': 'border border-slate-200 bg-white text-slate-700 shadow-sm hover:bg-slate-50',
  'danger': 'border border-transparent bg-red-600 text-white hover:bg-red-700'
} %}

<button type="{{ type }}" class="{{ base }} {{ variants[variant]|default(variants.primary) }} {{ class }}">
  {{ label }}
</button>
