<!DOCTYPE html>
<html lang="en" x-data="adminTheme()">
<head>
  {% include 'partials/head.twig' %}
  <title>{% block title %}Executive{% endblock %}</title>
  <script>
    (function() {
      var theme = localStorage.getItem('marwa-admin-theme');
      var preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      var finalTheme = (theme === 'light' || theme === 'dark') ? theme : preferred;
      document.documentElement.dataset.adminTheme = finalTheme;
      document.documentElement.style.colorScheme = finalTheme;
    })();
  </script>
  <script>
    document.addEventListener('alpine:init', function() {
      Alpine.data('adminTheme', function() {
        return {
          theme: document.documentElement.dataset.adminTheme || 'light',
          mobileOpen: false,
          toggle() {
            var newTheme = this.theme === 'dark' ? 'light' : 'dark';
            this.theme = newTheme;
            localStorage.setItem('marwa-admin-theme', newTheme);
            document.documentElement.dataset.adminTheme = newTheme;
            document.documentElement.style.colorScheme = newTheme;
          },
          toggleMobile() {
            this.mobileOpen = !this.mobileOpen;
          },
          closeMobile() {
            this.mobileOpen = false;
          }
        };
      });
    });
  </script>
  {% block styles %}{% endblock %}
</head>
<body class="admin-theme executive-theme min-h-screen bg-app-bg text-app-text antialiased" @close-mobile.window="closeMobile()">
  <div class="hidden" aria-hidden="true">{{ csrf_field() }}</div>
  <div class="admin-shell relative isolate min-h-screen bg-app-bg">
    <div
      x-show="mobileOpen"
      x-cloak
      @click="closeMobile()"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      class="fixed inset-0 z-40 bg-slate-950/50 backdrop-blur-sm lg:hidden"
    ></div>

    <div class="grid min-h-screen lg:grid-cols-[280px_minmax(0,1fr)]">
      <aside
        id="admin-sidebar"
        aria-label="Sidebar navigation"
        class="admin-sidebar fixed inset-y-0 left-0 z-50 w-[280px] transform border-r border-white/8 bg-[#071B33] transition-transform duration-300 lg:sticky lg:translate-x-0"
        :class="mobileOpen ? 'translate-x-0' : '-translate-x-full'"
      >
        <div class="flex h-full flex-col gap-6 px-5 py-6">
          {% include 'partials/sidebar.twig' %}
        </div>
      </aside>

      <div class="flex min-w-0 flex-col">
        <header class="admin-topbar sticky top-0 z-30 h-[72px] border-b border-slate-200 bg-white/95 backdrop-blur-xl">
          {% include 'partials/header.twig' %}
        </header>

        <main class="admin-content flex-1 px-4 py-8 sm:px-6 lg:px-8">
          {% include 'components/breadcrumbs.twig' with { crumbs: admin_breadcrumbs(currentPath|default('')) } only %}
          {% block content %}{% endblock %}
        </main>
      </div>
    </div>
  </div>

  {% include 'components/toast-host.twig' with { toasts: admin_toasts() } only %}
  {% include 'components/ai-chat-widget.twig' %}
  {% include 'partials/scripts.twig' %}
  {% block scripts %}{% endblock %}
</body>
</html>
