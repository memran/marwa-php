<!DOCTYPE html>
<html lang="en" data-theme="admin">
<head>
    {% include 'partials/head.twig' %}
    <title>{% block title %}Executive Access{% endblock %}</title>
    {% block styles %}{% endblock %}
    <script>
        (function() {
            var theme = localStorage.getItem('marwa-admin-theme') || localStorage.getItem('marwa-auth-theme');
            var preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
            var finalTheme = (theme === 'light' || theme === 'dark') ? theme : preferred;
            document.documentElement.dataset.adminTheme = finalTheme;
            document.documentElement.style.colorScheme = finalTheme;
            localStorage.setItem('marwa-admin-theme', finalTheme);
            localStorage.setItem('marwa-auth-theme', finalTheme);
        })();
    </script>
</head>
<body class="auth-theme admin-theme executive-theme min-h-screen bg-app-bg text-app-text antialiased">
    <div class="relative isolate flex min-h-screen items-center justify-center overflow-hidden px-4 py-10 sm:px-6 lg:px-8">
        {# Ambient background orbs #}
        <div class="pointer-events-none absolute inset-0 overflow-hidden">
            <div class="absolute -left-[10%] -top-[10%] h-[50rem] w-[50rem] rounded-full opacity-20 blur-[128px]" style="background: radial-gradient(circle, rgb(var(--app-accent)) 0%, transparent 70%);"></div>
            <div class="absolute -right-[10%] top-[20%] h-[40rem] w-[40rem] rounded-full opacity-15 blur-[112px]" style="background: radial-gradient(circle, rgb(var(--app-success)) 0%, transparent 70%);"></div>
            <div class="absolute bottom-[-10%] left-[30%] h-[35rem] w-[35rem] rounded-full opacity-10 blur-[96px]" style="background: radial-gradient(circle, rgb(var(--app-accent-soft)) 0%, transparent 70%);"></div>
        </div>

        {# Fine grid overlay #}
        <div class="pointer-events-none absolute inset-0 opacity-[0.03] dark:opacity-[0.05]" style="background-image: linear-gradient(rgba(var(--app-text), 0.4) 1px, transparent 1px), linear-gradient(90deg, rgba(var(--app-text), 0.4) 1px, transparent 1px); background-size: 3rem 3rem;"></div>

        {# Top bar: brand + theme toggle #}
        <div class="absolute left-0 right-0 top-0 z-20 flex items-center justify-between px-6 py-5 sm:px-10">
            <a href="/" class="group flex items-center gap-3">
                <div class="flex h-9 w-9 items-center justify-center rounded-xl border border-app-accent/20 bg-app-accent/10 shadow-[0_0_20px_rgb(var(--app-accent)/0.15)] transition group-hover:shadow-[0_0_30px_rgb(var(--app-accent)/0.25)]">
                    <svg class="h-5 w-5 text-app-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
                    </svg>
                </div>
                <span class="text-lg font-black tracking-tight text-app-text">Marwa<span class="text-app-accent">.</span></span>
            </a>

            <button
                type="button"
                class="inline-flex items-center justify-center gap-2 rounded-xl border border-app-border bg-app-surface/60 px-3 py-2 text-sm font-medium text-app-text shadow-sm backdrop-blur-xl transition hover:border-app-accent/30 hover:bg-app-surface hover:text-app-accent"
                aria-label="Toggle theme"
                title="Toggle theme"
                onclick="
                    (function() {
                        var current = document.documentElement.dataset.adminTheme || 'dark';
                        var next = current === 'dark' ? 'light' : 'dark';
                        document.documentElement.dataset.adminTheme = next;
                        document.documentElement.style.colorScheme = next;
                        localStorage.setItem('marwa-admin-theme', next);
                        localStorage.setItem('marwa-auth-theme', next);
                    })();
                "
            >
                {% include 'components/icon.twig' with { name: 'moon', class: 'h-4 w-4 shrink-0 dark:hidden' } only %}
                {% include 'components/icon.twig' with { name: 'sun', class: 'h-4 w-4 shrink-0 hidden dark:block' } only %}
                <span class="hidden sm:inline">Theme</span>
            </button>
        </div>

        {# Main content card #}
        <main class="relative z-10 w-full max-w-md">
            <section class="rounded-[2rem] border border-app-border/60 bg-app-surface/70 p-8 shadow-[0_35px_90px_rgba(2,6,23,0.28)] backdrop-blur-2xl dark:bg-app-surface/50 dark:shadow-[0_35px_90px_rgba(0,0,0,0.45)] sm:p-10">
                {% block content %}{% endblock %}
            </section>

            <p class="mt-6 text-center text-xs text-app-muted/80">
                Secure executive access. Authorized personnel only.
            </p>
        </main>
    </div>

    {% include 'partials/scripts.twig' %}
    {% block scripts %}{% endblock %}
</body>
</html>
