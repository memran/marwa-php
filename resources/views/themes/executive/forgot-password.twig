{% extends "layouts/auth.twig" %}

{% block title %}Forgot password | MarwaPHP Executive{% endblock %}

{% block content %}
  <div class="space-y-3">
    <span class="inline-flex w-fit items-center rounded-full border border-app-accent/20 bg-app-accent/10 px-4 py-1.5 text-[0.7rem] font-bold uppercase tracking-[0.22em] text-app-accent">Account recovery</span>
    <h2 class="text-2xl font-semibold tracking-tight text-app-text sm:text-3xl">Request a recovery link.</h2>
    <p class="text-sm leading-6 text-app-muted">Generate a short-lived reset link for the matching admin account.</p>
  </div>

  {% if notice is defined and notice %}
    <div class="mt-5 rounded-2xl border border-app-success/20 bg-app-success/10 p-4 text-app-success">
      <p class="text-sm font-semibold">Recovery link sent</p>
      <p class="mt-1 text-sm">{{ notice }}</p>
    </div>
  {% endif %}

  {% if errors is defined and errors.email is defined %}
    <div class="mt-5 rounded-2xl border border-app-danger/20 bg-app-danger/10 p-4 text-app-danger">
      <p class="text-sm font-semibold">Unable to generate link</p>
      <p class="mt-1 text-sm">{{ errors.email|first }}</p>
    </div>
  {% endif %}

  <form class="mt-6 grid gap-5" method="post" action="/admin/forgot-password">
    {{ csrf_field() }}

    {% include "components/input.twig" with {
      name: 'email',
      label: 'Email address',
      type: 'email',
      value: old.email|default(''),
      placeholder: 'admin@marwa.test'
    } only %}

    {% if errors.email is defined and errors.email|length > 0 %}
      <p class="text-sm text-red-600">{{ errors.email|first }}</p>
    {% endif %}

    {% include "components/button.twig" with {
      label: 'Send recovery link',
      type: 'submit',
      variant: 'primary',
      class: 'w-full'
    } only %}

    <a class="text-sm font-semibold text-app-muted transition hover:text-app-text" href="/admin/login">Back to sign in</a>
  </form>
{% endblock %}
