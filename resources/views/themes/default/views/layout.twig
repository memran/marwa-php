<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}MarwaPHP Framework{% endblock %}</title>
  <meta name="description" content="A framework-first PHP starter built on Marwa.">
  <link rel="stylesheet" href="/assets/css/app.css">
</head>
<body class="min-h-screen bg-slate-950 text-slate-100">
  <div class="relative isolate overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(180deg,#020617_0%,#0f172a_48%,#020617_100%)]"></div>

    <main class="mx-auto flex min-h-screen w-full max-w-7xl flex-col justify-center px-6 py-16 lg:px-10">
      {% block content %}{% endblock %}
    </main>
  </div>

  {% include '@Shared/components/ai-chat-widget.twig' %}
</body>
</html>
