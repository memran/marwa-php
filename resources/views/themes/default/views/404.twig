{% extends "layout.twig" %}

{% block title %}404 - Page not found{% endblock %}

{% block body %}
<section class="mx-auto max-w-2xl rounded-3xl border border-white/10 bg-white/5 p-8 text-center">
  <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-300">404</p>
  <h1 class="mt-4 text-4xl font-black text-white">We could not find that page.</h1>
  <p class="mt-4 text-slate-300">The route may have moved or the link may be outdated. Use the home page to continue exploring the starter.</p>
  <a href="/" class="mt-8 inline-flex rounded-xl bg-white px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-200">
    Back to home
  </a>
</section>
{% endblock %}
