{% extends "layout.twig" %}

{% block title %}500 - Server error{% endblock %}

{% block body %}
<section class="mx-auto max-w-2xl rounded-3xl border border-white/10 bg-white/5 p-8 text-center">
  <p class="text-sm font-semibold uppercase tracking-[0.3em] text-rose-300">500</p>
  <h1 class="mt-4 text-4xl font-black text-white">Something went wrong.</h1>
  <p class="mt-4 text-slate-300">The application hit an unexpected condition. Check logs, fix the root cause, and reload the page.</p>
  <a href="/" class="mt-8 inline-flex rounded-xl bg-white px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-200">
    Reload home
  </a>
</section>
{% endblock %}
