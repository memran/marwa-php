<form class="relative w-full max-w-md shrink-0" method="get" action="{{ search.action|default('') }}">
  {% for field in search.hidden_fields|default([]) %}
    <input type="hidden" name="{{ field.name }}" value="{{ field.value }}">
  {% endfor %}
  <label class="sr-only" for="{{ search.id|default('table-search') }}">{{ search.aria_label|default('Search records') }}</label>
  <span class="sr-only">{{ search.placeholder|default('Search') }}</span>
  <div class="relative">
    <div class="pointer-events-none absolute inset-y-0 start-0 flex items-center ps-3">
      <svg class="h-4 w-4 text-body" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
        <path stroke="currentColor" stroke-linecap="round" stroke-width="2" d="m21 21-3.5-3.5M17 10a7 7 0 1 1-14 0 7 7 0 1 1 14 0Z"/>
      </svg>
    </div>
    <input
      id="{{ search.id|default('table-search') }}"
      class="block w-full rounded-base border border-default-medium bg-neutral-secondary-medium p-3 pe-28 ps-9 text-sm text-heading shadow-xs placeholder:text-body focus:border-brand focus:ring-brand focus:outline-none"
      type="search"
      name="{{ search.name|default('q') }}"
      value="{{ search.value|default('') }}"
      placeholder="{{ search.placeholder|default('Search') }}"
      autocomplete="off"
      spellcheck="false"
      aria-label="{{ search.aria_label|default('Search records') }}"
    >
    {% if search.clear_url is defined and search.value|default('') %}
      <a class="absolute end-16 top-1/2 inline-flex h-9 -translate-y-1/2 items-center justify-center rounded text-xs font-medium leading-5 border border-default-medium bg-neutral-secondary-medium px-3 py-1.5 text-body shadow-xs transition hover:bg-neutral-secondary-medium/80 focus:outline-none focus:ring-4 focus:ring-brand-medium" href="{{ search.clear_url }}" title="{{ search.clear_label|default('Clear search') }}">
        <span class="sr-only">{{ search.clear_label|default('Clear search') }}</span>
        {% include '@Shared/components/icon.twig' with { name: 'x', class: 'h-4 w-4 shrink-0' } only %}
      </a>
    {% endif %}
    <button class="absolute end-1.5 bottom-1.5 inline-flex h-9 items-center justify-center rounded border border-transparent bg-brand px-3 text-white shadow-xs transition hover:bg-brand-strong focus:outline-none focus:ring-4 focus:ring-brand-medium" type="submit" title="{{ search.submit_label|default('Search') }}">
      <span class="sr-only">{{ search.submit_label|default('Search') }}</span>
      {% include '@Shared/components/icon.twig' with { name: 'search', class: 'h-4 w-4 shrink-0' } only %}
    </button>
  </div>
</form>
