<div class="mt-5 flex flex-col gap-3 xl:flex-row xl:items-center xl:justify-between">
  <div class="flex min-w-0 flex-1 flex-wrap items-center gap-3 xl:flex-nowrap">
    {% if features.search|default(false) and toolbar.search is defined %}
      {% include '@Shared/components/datatable/search.twig' with { search: toolbar.search } only %}
    {% endif %}

    {% if features.filter|default(false) and toolbar.filter is defined and toolbar.filter.items|default([]) is not empty %}
      {% include '@Shared/components/datatable/filter.twig' with {
        filter: toolbar.filter,
        toolbar_button_secondary: toolbar_button_secondary
      } only %}
    {% endif %}

    {% if features.columns|default(false) and toolbar.columns is defined and toolbar.columns.items|default([]) is not empty %}
      {% include '@Shared/components/datatable/columns.twig' with {
        column_menu: toolbar.columns,
        toolbar_button_secondary: toolbar_button_secondary,
        toolbar_button_primary: toolbar_button_primary
      } only %}
    {% endif %}

    {% if features.export|default(false) %}
      {% include '@Shared/components/datatable/exports.twig' with {
        toolbar: toolbar,
        toolbar_button_secondary: toolbar_button_secondary
      } only %}
    {% endif %}

    {% for action in toolbar.actions|default([]) %}
      {% set action_permission = action.permission|default('') %}
      {% if action_permission == '' or can(action_permission) %}
        {% set action_button_class = action.variant|default('secondary') == 'primary'
          ? toolbar_button_primary
          : action.variant|default('secondary') == 'danger'
            ? toolbar_button_danger
            : action.variant|default('secondary') == 'ghost'
              ? toolbar_button_ghost
              : toolbar_button_secondary %}
        {% if action.type|default('link') == 'button' %}
          <button class="{{ action_button_class }} {{ action.class|default('') }}" type="{{ action.button_type|default('button') }}" {% if action.title is defined and action.title %}title="{{ action.title }}"{% endif %}{% if action.onclick is defined and action.onclick %} onclick="{{ action.onclick }}"{% endif %}>
            {% if action.icon is defined and action.icon %}
              {% include '@Shared/components/icon.twig' with { name: action.icon, class: 'h-4 w-4 shrink-0' } only %}
            {% endif %}
            <span>{{ action.label|default('Action') }}</span>
          </button>
        {% else %}
          <a class="{{ action_button_class }} {{ action.class|default('') }}" href="{{ action.href|default('#') }}" {% if action.title is defined and action.title %}title="{{ action.title }}"{% endif %}{% if action.target is defined and action.target %}target="{{ action.target }}"{% endif %}{% if action.rel is defined and action.rel %}rel="{{ action.rel }}"{% endif %}>
            {% if action.icon is defined and action.icon %}
              {% include '@Shared/components/icon.twig' with { name: action.icon, class: 'h-4 w-4 shrink-0' } only %}
            {% endif %}
            <span>{{ action.label|default('Action') }}</span>
          </a>
        {% endif %}
      {% endif %}
    {% endfor %}
  </div>
</div>
