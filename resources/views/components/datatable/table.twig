<div class="mt-5 overflow-hidden rounded-[1.5rem] border border-app-border bg-app-surface">
  <table class="w-full border-collapse">
    <thead>
      <tr class="bg-app-surface-2/70">
        {% if has_bulk %}
          <th class="border-b border-app-border px-3 py-3 text-left text-xs font-extrabold uppercase tracking-[0.12em] text-app-muted">
            <span class="sr-only">{{ bulk.selection_header_label|default('Select rows') }}</span>
          </th>
        {% endif %}
        {% for column in columns %}
          <th class="border-b border-app-border px-3 py-3 text-left text-xs font-extrabold uppercase tracking-[0.12em] text-app-muted">
            {% if features.sort|default(false) and column.sortable and column.href %}
              <a class="inline-flex items-center gap-1 hover:text-app-text {% if column.active|default(false) %}text-app-accent{% endif %}" href="{{ column.href }}">
                <span>{{ column.label }}</span>
                {% if column.active|default(false) %}
                  {% include '@Shared/components/icon.twig' with { name: column.sort_direction|default('desc') == 'asc' ? 'arrow-up' : 'arrow-down', class: 'h-3.5 w-3.5 shrink-0 text-app-accent' } only %}
                {% endif %}
              </a>
            {% else %}
              <span>{{ column.label }}</span>
            {% endif %}
          </th>
        {% endfor %}
        {% if features.actions|default(false) %}
          <th class="border-b border-app-border px-3 py-3 text-left text-xs font-extrabold uppercase tracking-[0.12em] text-app-muted"></th>
        {% endif %}
      </tr>
    </thead>
    <tbody class="divide-y divide-app-border">
      {% for row in rows %}
        {% include '@Shared/components/datatable/row.twig' with {
          row: row,
          columns: columns,
          features: features,
          bulk: bulk,
          has_bulk: has_bulk,
          row_action_primary: row_action_primary,
          row_action_secondary: row_action_secondary,
          row_action_ghost: row_action_ghost,
          row_action_danger: row_action_danger,
          tone_classes: tone_classes
        } only %}
      {% endfor %}
    </tbody>
  </table>
</div>
