{% if cell is not null %}
  {% if cell.type == 'avatar_link' %}
    <div class="flex items-center gap-3">
      <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-app-border bg-app-accent/10 text-sm font-black uppercase text-app-accent ring-1 ring-app-accent/15">
        {{ cell.avatar|default(cell.value|default('U'))|slice(0, 1)|upper }}
      </div>
      <div class="grid gap-0.5 min-w-0">
        {% if cell.href %}
          <a class="truncate font-semibold text-app-text transition hover:text-app-accent" href="{{ cell.href }}">{{ cell.value }}</a>
        {% else %}
          <span class="truncate font-semibold text-app-text">{{ cell.value }}</span>
        {% endif %}
        {% if cell.meta is defined and cell.meta %}
          <span class="text-sm text-app-muted">{{ cell.meta }}</span>
        {% endif %}
      </div>
    </div>
  {% elseif cell.type == 'text' %}
    {% if cell.href %}
      <a class="{% if cell.muted|default(false) %}text-app-muted{% else %}text-app-text hover:text-app-accent transition{% endif %}" href="{{ cell.href }}">
        {{ cell.value }}
      </a>
    {% else %}
      <span class="{% if cell.muted|default(false) %}text-app-muted{% else %}text-app-text{% endif %}">{{ cell.value }}</span>
    {% endif %}
  {% elseif cell.type == 'badge' %}
    <span class="inline-flex rounded-full border px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] {{ tone_classes[cell.tone|default('accent')]|default(tone_classes.accent) }}">
      {% if cell.icon is defined and cell.icon %}
        {% include '@Shared/components/icon.twig' with { name: cell.icon, class: 'h-4 w-4 shrink-0' } only %}
      {% endif %}
      <span>{{ cell.value }}</span>
    </span>
  {% elseif cell.type == 'badge_stack' %}
    <div class="grid gap-2">
      {% for badge in cell.items|default([]) %}
        <span class="inline-flex w-fit items-center gap-2 rounded-full border px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] {{ tone_classes[badge.tone|default('accent')]|default(tone_classes.accent) }}">
          {% if badge.icon is defined and badge.icon %}
            {% include '@Shared/components/icon.twig' with { name: badge.icon, class: 'h-4 w-4 shrink-0' } only %}
          {% endif %}
          <span>{{ badge.value }}</span>
        </span>
      {% endfor %}
    </div>
  {% else %}
    <span class="text-app-text">{{ cell.value|default('') }}</span>
  {% endif %}
{% endif %}
