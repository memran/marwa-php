APP_NAME=MarwaPHP
APP_URL=http://localhost/
APP_KEY=
APP_DEBUG=1
LOG_ENABLED=0
APP_ENV=local
TIMEZONE=Asia/Dhaka
MAINTENANCE=false
MAINTENANCE_TIME=300

# DEBUGBAR
DEBUGBAR_ENABLED=1

# Modules
MODULES_ENABLED=1
DATABASE_MANAGER_ENABLED=1

# Database
DB_ENABLED=1
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=marwa
DB_USER=root
DB_PASSWORD=

# Admin Auth
ADMIN_BOOTSTRAP_EMAIL=admin@marwa.test
ADMIN_BOOTSTRAP_PASSWORD=ExampleAdminPassword123!

# Theme
FRONTEND_THEME=default
ADMIN_THEME=executive

# Logging
LOG_PREFIX=marwa
LOG_CHANNEL=file
LOG_LEVEL=debug

# Error handling
ERROR_ENABLED=1
ERROR_USE_LOGGER=1
ERROR_USE_DEBUG_REPORTER=1

# Mail
MAIL_ENABLED=1
MAIL_DRIVER=smtp
MAIL_CHARSET=UTF-8
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=MarwaPHP
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_TIMEOUT=30
MAIL_SENDMAIL_PATH="/usr/sbin/sendmail -bs"

# AI Providers
AI_PROVIDER=openrouter

# OpenRouter (default)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Ollama (local AI)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_ORG=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus
