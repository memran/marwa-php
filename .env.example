APP_NAME=MarwaPHP
APP_TITLE=MarwaPHP
APP_URL=http://localhost/
APP_KEY=
APP_DEBUG=1
APP_ENV=local
TIMEZONE=Asia/Dhaka
MAINTENANCE=false
MAINTENANCE_TIME=300
MODULES_ENABLED=1
FRONTEND_THEME=default
ADMIN_THEME=admin
LOG_ENABLE=1
LOG_CHANNEL=file
LOG_LEVEL=debug
LOG_PREFIX=marwa-php
ERROR_ENABLED=1
ERROR_USE_LOGGER=1
ERROR_USE_DEBUG_REPORTER=1
MAIL_ENABLED=1
MAIL_DRIVER=smtp
MAIL_CHARSET=UTF-8
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=MarwaPHP
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_TIMEOUT=30
MAIL_SENDMAIL_PATH=/usr/sbin/sendmail -bs

# HTTP

# Optional integrations
# DB_HOST=127.0.0.1
# DB_NAME=marwa
# DB_USER=root
# DB_PASSWORD=
