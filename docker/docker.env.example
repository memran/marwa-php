APP_NAME=MarwaPHP
APP_TITLE=MarwaPHP
APP_URL=http://localhost/
APP_KEY=change-this-app-key
APP_DEBUG=1
APP_ENV=local
TIMEZONE=Asia/Dhaka
MAINTENANCE=false
DEBUGBAR_ENABLED=false
MODULES_ENABLED=1

DB_ENABLED=1
