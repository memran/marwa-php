DB_NAME=marwa
DB_DATABASE=marwa
DB_USER=marwa
DB_USERNAME=marwa
DB_PASSWORD=change-this-db-password
MYSQL_ROOT_PASSWORD=change-this-root-password

ADMIN_BOOTSTRAP_EMAIL=admin@marwa.test
ADMIN_BOOTSTRAP_PASSWORD=ExampleAdminPassword123!
FRONTEND_THEME=default
ADMIN_THEME=admin
