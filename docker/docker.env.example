APP_NAME=MarwaPHP
APP_TITLE=MarwaPHP
APP_URL=http://localhost/
APP_KEY=change-this-app-key
APP_DEBUG=1
APP_ENV=local
TIMEZONE=Asia/Dhaka
MAINTENANCE=false
DEBUGBAR_ENABLED=false

# Modules
MODULES_ENABLED=1
APP_MODULE_CACHE=storage/cache/modules.php

# Database
DB_ENABLED=1
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=marwa
DB_USER=marwa
DB_PASSWORD=super-secret

# MariaDB bootstrap
MARIADB_ROOT_PASSWORD=super-secret
MARIADB_DATABASE=marwa
MARIADB_USER=marwa
MARIADB_PASSWORD=super-secret

# Admin auth
ADMIN_BOOTSTRAP_EMAIL=admin@marwa.test
ADMIN_BOOTSTRAP_PASSWORD=ExampleAdminPassword123!

# Theme
FRONTEND_THEME=default
ADMIN_THEME=admin
