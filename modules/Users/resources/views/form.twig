{% extends "layout.twig" %}

{% block title %}{{ title }} | MarwaPHP Admin{% endblock %}

{% block content %}
  <section class="admin-page-header">
    <div class="admin-page-header__copy">
      <span class="admin-eyebrow">Identity management</span>
      <h1 class="admin-page-title">{{ title }}</h1>
      <p class="admin-page-lead">Keep the form compact and readable for long working sessions.</p>
    </div>

    <div class="admin-table-tools">
      <a class="admin-btn admin-btn--ghost" href="/admin/users">Back to users</a>
    </div>
  </section>

  <section class="admin-form-card">
    {% if errors is defined and errors is not empty %}
      <div class="admin-alert admin-alert--danger">
        <p class="admin-alert__title">Please review the form</p>
        <p class="admin-alert__body">One or more fields contain validation errors.</p>
      </div>
    {% endif %}

    <form class="admin-stack" method="post" action="{{ action }}">
      {% include "components/form-field.twig" with {
        id: 'name',
        label: 'Full name',
        value: form.name|default(''),
        placeholder: 'Jane Doe',
        error: errors.name|default([])|first
      } only %}

      {% include "components/form-field.twig" with {
        id: 'email',
        label: 'Email address',
        type: 'email',
        autocomplete: 'email',
        value: form.email|default(''),
        placeholder: 'jane@company.com',
        error: errors.email|default([])|first
      } only %}

      <div class="admin-field">
        <label class="admin-field__label" for="role">Role</label>
        <select class="admin-field__control" id="role" name="role">
          {% for value, label in roles %}
            <option value="{{ value }}" {% if form.role|default('staff') == value %}selected{% endif %}>{{ label }}</option>
          {% endfor %}
        </select>
        {% if errors.role is defined %}
          <p class="admin-field__message admin-field__message--error">{{ errors.role|first }}</p>
        {% else %}
          <p class="admin-field__hint">Controls the access level shown in the user table.</p>
        {% endif %}
      </div>

      {% set is_active_checked = form.is_active is defined ? form.is_active : true %}

      <div class="admin-field">
        <label class="admin-field__label" for="is_active">Status</label>
        <label class="admin-checkbox">
          <input type="checkbox" id="is_active" name="is_active" value="1" {% if is_active_checked %}checked{% endif %}>
          <span>Active account</span>
        </label>
        {% if errors.is_active is defined %}
          <p class="admin-field__message admin-field__message--error">{{ errors.is_active|first }}</p>
        {% else %}
          <p class="admin-field__hint">Inactive users cannot sign in.</p>
        {% endif %}
      </div>

      <div class="admin-field admin-field--password">
        <label class="admin-field__label" for="password">{{ mode == 'create' ? 'Password' : 'Password (optional)' }}</label>
        <input
          class="admin-field__control"
          id="password"
          name="password"
          type="password"
          autocomplete="new-password"
          placeholder="Minimum 8 characters"
        >
        <div class="admin-password-tools">
          <button class="admin-btn admin-btn--secondary admin-password-tools__button" type="button" id="generate_password">Generate password</button>
          <button class="admin-btn admin-btn--ghost admin-password-tools__button" type="button" id="copy_password">Copy password</button>
          <label class="admin-checkbox admin-password-tools__toggle">
            <input type="checkbox" id="show_password">
            <span>Show password</span>
          </label>
        </div>
        {% if errors.password is defined %}
          <p class="admin-field__message admin-field__message--error">{{ errors.password|first }}</p>
        {% else %}
          <p class="admin-field__hint">{{ mode == 'create' ? 'Required for new accounts. Use Generate password for a 12-character random string.' : 'Leave blank to keep the current password. Use Generate password for a 12-character random string.' }}</p>
        {% endif %}
      </div>

      <div class="admin-field">
        <label class="admin-field__label" for="password_confirmation">Confirm password</label>
        <input
          class="admin-field__control"
          id="password_confirmation"
          name="password_confirmation"
          type="password"
          autocomplete="new-password"
          placeholder="Repeat the password"
        >
      </div>

      <div class="admin-table-tools">
        <button class="admin-btn admin-btn--primary" type="submit">{{ submit_label }}</button>
        <a class="admin-btn admin-btn--secondary" href="/admin/users">Cancel</a>
      </div>
    </form>
  </section>

  <script>
    (() => {
      const password = document.getElementById('password');
      const confirmation = document.getElementById('password_confirmation');
      const generate = document.getElementById('generate_password');
      const copy = document.getElementById('copy_password');
      const toggle = document.getElementById('show_password');

      if (!password || !confirmation || !generate || !copy || !toggle) {
        return;
      }

      const setType = (type) => {
        password.type = type;
        confirmation.type = type;
      };

      const setClipboard = async (value) => {
        if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
          await navigator.clipboard.writeText(value);
          return;
        }

        password.focus();
        password.select();
        document.execCommand('copy');
      };

      toggle.addEventListener('change', () => {
        setType(toggle.checked ? 'text' : 'password');
      });

      generate.addEventListener('click', () => {
        const charset = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz23456789!@#$%^&*';
        const bytes = new Uint8Array(12);
        window.crypto.getRandomValues(bytes);
        const value = Array.from(bytes, (byte) => charset.charAt(byte % charset.length)).join('');

        password.value = value;
        confirmation.value = value;
        toggle.checked = true;
        setType('text');
        password.focus();
        password.select();
      });

      copy.addEventListener('click', async () => {
        if (password.value === '') {
          return;
        }

        await setClipboard(password.value);
        copy.textContent = 'Copied';
        window.setTimeout(() => {
          copy.textContent = 'Copy password';
        }, 1200);
      });
    })();
  </script>
{% endblock %}
