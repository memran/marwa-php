{% extends "layout.twig" %}

{% block title %}{{ title }} | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-xl border px-3.5 py-2 text-[0.82rem] font-semibold transition' %}
  {% set button_primary = button_base ~ ' border-transparent bg-white text-slate-950 hover:bg-cyan-200' %}
  {% set button_secondary = button_base ~ ' border-white/10 bg-white/5 text-slate-100 hover:bg-white/10' %}
  {% set user = user|default(null) %}
  {% set form = form|default({}) %}
  {% set roles = roles|default([]) %}
  {% set is_edit = user is not null %}

  <section class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-2">
      <span class="inline-flex w-fit items-center rounded-xl border border-cyan-300/20 bg-cyan-400/10 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.16em] text-cyan-100">Identity management</span>
      <h1 class="text-2xl font-black tracking-tight text-white sm:text-3xl">{{ title }}</h1>
      <p class="max-w-2xl text-sm leading-6 text-slate-300">
        {% if is_edit %}
          Update account details for this user. Leave password blank to keep the current password.
        {% else %}
          Create a new user account. A password is required for new accounts.
        {% endif %}
      </p>
    </div>

    <div class="flex flex-wrap gap-2">
      <a class="{{ button_secondary }}" href="/admin/users">Back to users</a>
    </div>
  </section>

  <form method="post" action="{{ action }}" class="mt-6">
    {{ csrf_field() }}

    <div class="grid gap-6 lg:grid-cols-2">
      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <h2 class="mb-4 text-lg font-semibold text-slate-100">Account Details</h2>

        <div class="space-y-4">
          {% include "components/form-field.twig" with {
            id: 'name',
            label: 'Name',
            value: form.name|default(''),
            placeholder: 'John Doe',
            error: errors.name|default([])|first,
          } only %}

          {% include "components/form-field.twig" with {
            id: 'email',
            label: 'Email',
            type: 'email',
            value: form.email|default(''),
            placeholder: 'john@example.com',
            error: errors.email|default([])|first,
          } only %}

          {% include "components/form-field.twig" with {
            id: 'role_id',
            label: 'Role',
            type: 'select',
            value: form.role_id|default(0),
            options: roles,
            error: errors.role_id|default([])|first,
          } only %}

          <div class="grid gap-2">
            <label class="text-[0.82rem] font-semibold text-app-text">Status</label>
            <div class="flex items-center gap-4">
              <label class="flex items-center gap-2">
                <input type="radio" name="is_active" value="1" {% if form.is_active|default(1) == 1 %}checked{% endif %} class="rounded border-white/10 bg-white/5 text-cyan-400 focus:ring-cyan-400/20">
                <span class="text-sm text-slate-300">Active</span>
              </label>
              <label class="flex items-center gap-2">
                <input type="radio" name="is_active" value="0" {% if form.is_active|default(1) == 0 %}checked{% endif %} class="rounded border-white/10 bg-white/5 text-cyan-400 focus:ring-cyan-400/20">
                <span class="text-sm text-slate-300">Disabled</span>
              </label>
            </div>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <h2 class="mb-4 text-lg font-semibold text-slate-100">
          {% if is_edit %}Change Password{% else %}Password{% endif %}
        </h2>

        <div class="space-y-4">
          {% include "components/form-field.twig" with {
            id: 'password',
            label: 'Password',
            type: 'password',
            value: '',
            placeholder: is_edit ? 'Leave blank to keep current' : 'Minimum 8 characters',
            error: errors.password|default([])|first,
          } only %}

          {% include "components/form-field.twig" with {
            id: 'password_confirmation',
            label: 'Confirm Password',
            type: 'password',
            value: '',
            placeholder: 'Repeat password',
            error: errors.password_confirmation|default([])|first,
          } only %}
        </div>
      </div>
    </div>

    <div class="mt-6 flex justify-end gap-3">
      <a href="/admin/users" class="{{ button_secondary }}">Cancel</a>
      <button type="submit" class="{{ button_primary }}">{{ submit_label }}</button>
    </div>
  </form>
{% endblock %}
