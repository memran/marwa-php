{% extends "layouts/admin.twig" %}

{% block title %}{{ title }} | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-xl border px-3.5 py-2 text-[0.82rem] font-semibold transition' %}
  {% set button_primary = button_base ~ ' border-transparent bg-app-accent text-white hover:bg-app-accent-soft' %}
  {% set button_secondary = button_base ~ ' border-app-border bg-app-surface/80 text-app-text hover:bg-app-surface-2/70' %}
  {% set field_class = 'w-full rounded-xl border border-app-border bg-app-surface px-3 py-2 text-sm text-app-text placeholder:text-app-muted outline-none transition focus:border-app-accent focus:ring-0 focus-visible:outline-none focus-visible:border-app-accent focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-app-accent/20 disabled:cursor-not-allowed disabled:opacity-60' %}
  {% set select_class = field_class %}
  {% set user = user|default(null) %}
  {% set form = form|default({}) %}
  {% set roles = roles|default([]) %}
  {% set is_edit = user is not null %}

  <section class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <span class="inline-flex w-fit items-center rounded-xl border border-app-accent/20 bg-app-accent/10 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.16em] text-app-accent">Identity management</span>

    <div class="flex flex-wrap gap-2">
      <a class="{{ button_secondary }}" href="/admin/users">Back to users</a>
    </div>
  </section>

  <form method="post" action="{{ action }}" class="mt-6 space-y-6"
        {{ ui().data('{
          showPassword: false,
          showConfirm: false,
          password: "",
          passwordConfirm: "",
          copied: false,
          get hasPassword() { return this.password.length > 0 },
          get score() {
            if (this.password.length === 0) return 0
            let s = 0
            if (this.password.length >= 8) s++
            if (this.password.length >= 12) s++
            if (/[a-z]/.test(this.password) && /[A-Z]/.test(this.password)) s++
            if (/\d/.test(this.password)) s++
            if (/[^a-zA-Z0-9]/.test(this.password)) s++
            return s
          },
          get strengthLabel() {
            return ["", "Weak", "Fair", "Good", "Strong", "Very strong"][this.score]
          },
          get strengthBar() {
            return ["", "bg-app-danger", "bg-app-warning", "bg-app-warning", "bg-app-accent", "bg-app-success"][this.score]
          },
          get strengthText() {
            return ["", "text-app-danger", "text-app-warning", "text-app-warning", "text-app-accent", "text-app-success"][this.score]
          },
          generatePassword() {
            const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*()_+-=[]{}|;:,.<>?"
            let pwd = ""
            for (let i = 0; i < 20; i++) {
              pwd += chars.charAt(Math.floor(Math.random() * chars.length))
            }
            this.password = pwd
            this.passwordConfirm = pwd
            this.showPassword = true
            this.showConfirm = true
          },
          copyPassword() {
            navigator.clipboard.writeText(this.password)
            this.copied = true
            setTimeout(() => { this.copied = false }, 2000)
          }
        }') }}">
    {{ csrf_field() }}

    <div class="grid gap-6 lg:grid-cols-2">
      <div class="rounded-[1.25rem] border border-app-border bg-app-surface/80 p-6 shadow-[0_30px_80px_rgba(2,6,23,0.45)] backdrop-blur-xl">
        <div class="mb-5 flex items-center gap-2.5">
          <svg class="h-5 w-5 shrink-0 text-app-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
          </svg>
          <h2 class="text-lg font-semibold text-app-text">Account Details</h2>
        </div>

        <div class="space-y-5">
          <div class="grid gap-2">
            <label class="text-[0.82rem] font-semibold text-app-text" for="name">Full name</label>
            <p class="text-xs leading-5 text-app-muted">The user's display name across the platform.</p>
            <input
              class="{{ field_class }}"
              id="name"
              name="name"
              type="text"
              value="{{ form.name|default('') }}"
              placeholder="e.g. John Doe"
              autocomplete="name"
            >
            {% if errors.name|default([])|length > 0 %}
              <p class="text-xs text-app-danger">{{ errors.name|default([])|first }}</p>
            {% endif %}
          </div>

          <div class="grid gap-2">
            <label class="text-[0.82rem] font-semibold text-app-text" for="email">Email address</label>
            <p class="text-xs leading-5 text-app-muted">Used for login, notifications, and Gravatar.</p>
            <input
              class="{{ field_class }}"
              id="email"
              name="email"
              type="email"
              value="{{ form.email|default('') }}"
              placeholder="e.g. john@example.com"
              autocomplete="email"
            >
            {% if errors.email|default([])|length > 0 %}
              <p class="text-xs text-app-danger">{{ errors.email|default([])|first }}</p>
            {% endif %}
          </div>

          <div class="grid gap-2">
            <label class="text-[0.82rem] font-semibold text-app-text" for="role_id">Access role</label>
            <p class="text-xs leading-5 text-app-muted">Controls which sections and actions the user can access.</p>
            <select
              class="{{ select_class }}"
              id="role_id"
              name="role_id"
            >
              {% for option_value, option_label in roles %}
                <option value="{{ option_value }}" {% if form.role_id|default(0) == option_value %}selected{% endif %}>{{ option_label }}</option>
              {% endfor %}
            </select>
            {% if errors.role_id|default([])|length > 0 %}
              <p class="text-xs text-app-danger">{{ errors.role_id|default([])|first }}</p>
            {% endif %}
          </div>

          <div class="grid gap-2">
            <label class="text-[0.82rem] font-semibold text-app-text">Account status</label>
            <p class="text-xs leading-5 text-app-muted">Active users can log in and access the system.</p>
            <div class="mt-1 flex gap-3">
              <label class="dashboard-status-option flex flex-1 cursor-pointer items-center gap-3 rounded-xl border border-app-border bg-app-surface p-3 transition hover:border-app-accent/30 hover:bg-app-accent/5 has-[:checked]:border-app-accent/40 has-[:checked]:bg-app-accent/10">
                <input type="radio" name="is_active" value="1" {% if form.is_active|default(1) == 1 %}checked{% endif %} class="h-4 w-4 accent-[rgb(var(--app-accent))] outline-none focus:outline-none focus:ring-0 focus-visible:ring-2 focus-visible:ring-app-accent/20">
                <span class="text-sm font-medium text-app-text">Active</span>
              </label>
              <label class="dashboard-status-option flex flex-1 cursor-pointer items-center gap-3 rounded-xl border border-app-border bg-app-surface p-3 transition hover:border-app-danger/30 hover:bg-app-danger/5 has-[:checked]:border-app-danger/40 has-[:checked]:bg-app-danger/10">
                <input type="radio" name="is_active" value="0" {% if form.is_active|default(1) == 0 %}checked{% endif %} class="h-4 w-4 accent-[rgb(var(--app-accent))] outline-none focus:outline-none focus:ring-0 focus-visible:ring-2 focus-visible:ring-app-accent/20">
                <span class="text-sm font-medium text-app-text">Disabled</span>
              </label>
            </div>
            {% if errors.is_active|default([])|length > 0 %}
              <p class="flex items-center gap-1.5 text-xs text-app-danger">
                <svg class="h-3 w-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/></svg>
                {{ errors.is_active|default([])|first }}
              </p>
            {% endif %}
          </div>
        </div>
      </div>

      {% include '@users/_password-fields.twig' with {
        is_edit: is_edit,
        errors: errors
      } only %}
    </div>

    <div class="flex items-center justify-end gap-3 rounded-xl border border-app-border bg-app-surface/60 px-6 py-4">
      <a href="/admin/users" class="{{ button_secondary }}">Cancel</a>
      <button type="submit" class="{{ button_primary }}">{{ submit_label }}</button>
    </div>
  </form>
{% endblock %}
