{% extends "layout.twig" %}

{% block title %}{{ title }} | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-full border px-5 py-3 text-sm font-semibold transition hover:-translate-y-0.5' %}
  {% set button_primary = button_base ~ ' border-transparent bg-white text-slate-950 hover:bg-cyan-200' %}
  {% set button_secondary = button_base ~ ' border-white/10 bg-white/5 text-slate-100 hover:bg-white/10' %}
  {% set button_ghost = button_base ~ ' border-white/10 bg-transparent text-slate-200 hover:bg-white/5' %}

  <section class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-3">
      <span class="inline-flex w-fit items-center rounded-full border border-cyan-300/20 bg-cyan-400/10 px-4 py-1.5 text-[0.7rem] font-extrabold uppercase tracking-[0.22em] text-cyan-100">Identity management</span>
      <h1 class="text-3xl font-black tracking-tight text-white sm:text-4xl">{{ title }}</h1>
      <p class="max-w-2xl text-sm leading-6 text-slate-300 sm:text-base">Keep the form compact and readable for long working sessions.</p>
    </div>

    <div class="flex flex-wrap gap-3">
      <a class="{{ button_ghost }}" href="/admin/users">Back to users</a>
    </div>
  </section>

  <section class="mt-8 overflow-hidden rounded-[2rem] border border-white/10 bg-white/5 p-5 shadow-[0_30px_80px_rgba(2,6,23,0.45)] backdrop-blur-xl sm:p-6">
    {% if errors is defined and errors is not empty %}
      <div class="rounded-2xl border border-rose-400/20 bg-rose-500/10 p-4 text-rose-100">
        <p class="text-sm font-semibold">Please review the form</p>
        <p class="mt-1 text-sm text-rose-100/80">One or more fields contain validation errors.</p>
      </div>
    {% endif %}

    <form class="mt-6 grid gap-5" method="post" action="{{ action }}">
      {% include "components/form-field.twig" with {
        id: 'name',
        label: 'Full name',
        value: form.name|default(''),
        placeholder: 'Jane Doe',
        error: errors.name|default([])|first
      } only %}

      {% include "components/form-field.twig" with {
        id: 'email',
        label: 'Email address',
        type: 'email',
        autocomplete: 'email',
        value: form.email|default(''),
        placeholder: 'jane@company.com',
        error: errors.email|default([])|first
      } only %}

      <div class="grid gap-2">
        <label class="text-sm font-semibold text-slate-200" for="role">Role</label>
        <select class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-slate-100 outline-none transition focus:border-cyan-400 focus:ring-4 focus:ring-cyan-400/10" id="role" name="role">
          {% for value, label in roles %}
            <option value="{{ value }}" {% if form.role|default('staff') == value %}selected{% endif %}>{{ label }}</option>
          {% endfor %}
        </select>
        {% if errors.role is defined %}
          <p class="text-sm text-rose-300">{{ errors.role|first }}</p>
        {% else %}
          <p class="text-sm text-slate-400">Controls the access level shown in the user table.</p>
        {% endif %}
      </div>

      {% set is_active_checked = form.is_active is defined ? form.is_active : true %}

      <div class="grid gap-2">
        <label class="text-sm font-semibold text-slate-200" for="is_active">Status</label>
        <label class="inline-flex items-center gap-3 text-sm text-slate-300">
          <input type="checkbox" id="is_active" name="is_active" value="1" {% if is_active_checked %}checked{% endif %}>
          <span>Active account</span>
        </label>
        {% if errors.is_active is defined %}
          <p class="text-sm text-rose-300">{{ errors.is_active|first }}</p>
        {% else %}
          <p class="text-sm text-slate-400">Inactive users cannot sign in.</p>
        {% endif %}
      </div>

      <div class="grid gap-2">
        <label class="text-sm font-semibold text-slate-200" for="password">{{ mode == 'create' ? 'Password' : 'Password (optional)' }}</label>
        <input
          class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-slate-100 placeholder:text-slate-500 outline-none transition focus:border-cyan-400 focus:ring-4 focus:ring-cyan-400/10"
          id="password"
          name="password"
          type="password"
          autocomplete="new-password"
          placeholder="Minimum 8 characters"
        >
        <div class="flex flex-wrap items-center gap-3">
          <button class="{{ button_secondary }}" type="button" id="generate_password">Generate password</button>
          <button class="{{ button_ghost }}" type="button" id="copy_password">Copy password</button>
          <label class="inline-flex items-center gap-3 text-sm text-slate-300">
            <input type="checkbox" id="show_password">
            <span>Show password</span>
          </label>
        </div>
        {% if errors.password is defined %}
          <p class="text-sm text-rose-300">{{ errors.password|first }}</p>
        {% else %}
          <p class="text-sm text-slate-400">{{ mode == 'create' ? 'Required for new accounts. Use Generate password for a 12-character random string.' : 'Leave blank to keep the current password. Use Generate password for a 12-character random string.' }}</p>
        {% endif %}
      </div>

      <div class="grid gap-2">
        <label class="text-sm font-semibold text-slate-200" for="password_confirmation">Confirm password</label>
        <input
          class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-slate-100 placeholder:text-slate-500 outline-none transition focus:border-cyan-400 focus:ring-4 focus:ring-cyan-400/10"
          id="password_confirmation"
          name="password_confirmation"
          type="password"
          autocomplete="new-password"
          placeholder="Repeat the password"
        >
      </div>

      <div class="flex flex-wrap gap-3">
        <button class="{{ button_primary }}" type="submit">{{ submit_label }}</button>
        <a class="{{ button_secondary }}" href="/admin/users">Cancel</a>
      </div>
    </form>
  </section>

  <script>
    (() => {
      const password = document.getElementById('password');
      const confirmation = document.getElementById('password_confirmation');
      const generate = document.getElementById('generate_password');
      const copy = document.getElementById('copy_password');
      const toggle = document.getElementById('show_password');

      if (!password || !confirmation || !generate || !copy || !toggle) {
        return;
      }

      const setType = (type) => {
        password.type = type;
        confirmation.type = type;
      };

      const setClipboard = async (value) => {
        if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
          await navigator.clipboard.writeText(value);
          return;
        }

        password.focus();
        password.select();
        document.execCommand('copy');
      };

      toggle.addEventListener('change', () => {
        setType(toggle.checked ? 'text' : 'password');
      });

      generate.addEventListener('click', () => {
        const charset = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz23456789!@#$%^&*';
        const bytes = new Uint8Array(12);
        window.crypto.getRandomValues(bytes);
        const value = Array.from(bytes, (byte) => charset.charAt(byte % charset.length)).join('');

        password.value = value;
        confirmation.value = value;
        toggle.checked = true;
        setType('text');
        password.focus();
        password.select();
      });

      copy.addEventListener('click', async () => {
        if (password.value === '') {
          return;
        }

        await setClipboard(password.value);
        copy.textContent = 'Copied';
        window.setTimeout(() => {
          copy.textContent = 'Copy password';
        }, 1200);
      });
    })();
  </script>
{% endblock %}
