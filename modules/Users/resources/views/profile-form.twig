{% extends "layout.twig" %}

{% block title %}{{ title }} | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-full border px-5 py-3 text-sm font-semibold transition hover:-translate-y-0.5' %}
  {% set button_primary = button_base ~ ' border-transparent bg-app-accent text-white hover:bg-app-accent-soft' %}
  {% set button_secondary = button_base ~ ' border-app-border bg-app-surface/80 text-app-text hover:bg-app-surface-2/70' %}
  {% set button_ghost = button_base ~ ' border-app-border bg-transparent text-app-text hover:bg-app-surface-2/60' %}

  <section class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-3">
      <span class="inline-flex w-fit items-center rounded-full border border-app-accent/20 bg-app-accent/10 px-4 py-1.5 text-[0.7rem] font-extrabold uppercase tracking-[0.22em] text-app-accent">Identity management</span>
      <h1 class="text-3xl font-black tracking-tight text-app-text sm:text-4xl">{{ title }}</h1>
      <p class="max-w-2xl text-sm leading-6 text-app-muted sm:text-base">Update your account details and password.</p>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
      <a class="{{ button_ghost }} w-full sm:w-auto" href="/admin/profile">Back to profile</a>
    </div>
  </section>

  {% embed 'components/card.twig' with {
    shell_class: 'profile-form-shell mt-8 overflow-hidden rounded-[2rem] border border-app-border bg-gradient-to-b from-app-surface via-app-surface to-app-surface-2/70 p-5 shadow-[0_30px_80px_rgba(2,6,23,0.45)] backdrop-blur-xl sm:p-6',
    body_class: 'grid gap-5'
  } %}
    {% block header %}
      <div class="border-b border-app-border pb-5">
        <div>
          <h2 class="text-2xl font-bold tracking-tight text-app-text">Edit profile</h2>
          <p class="mt-1 text-sm text-app-muted">Update your account details and password.</p>
        </div>
      </div>
    {% endblock %}

    {% block body %}
      <form class="grid gap-5" method="post" action="{{ action }}">
        {{ csrf_field() }}

        <div class="grid gap-5 lg:grid-cols-2">
          {% include "components/form-field.twig" with {
            id: 'name',
            label: 'Full name',
            value: form.name|default(user.getAttribute('name')),
            placeholder: 'Jane Doe',
            error: errors.name|default([])|first
          } only %}

          {% include "components/form-field.twig" with {
            id: 'email',
            label: 'Email address',
            type: 'email',
            autocomplete: 'email',
            value: form.email|default(user.getAttribute('email')),
            placeholder: 'jane@company.com',
            error: errors.email|default([])|first
          } only %}
        </div>

        <div class="grid gap-2">
          <label class="text-[0.82rem] font-semibold text-app-text" for="current_password">Current password</label>
          <input
            class="w-full rounded-2xl border border-app-border bg-app-surface-2/80 px-4 py-3 text-app-text placeholder:text-app-muted outline-none transition focus:border-app-accent focus:ring-4 focus:ring-app-accent/10"
            id="current_password"
            name="current_password"
            type="password"
            autocomplete="current-password"
            placeholder="Required to update password"
          >
          {% if errors.current_password is defined %}
            <p class="text-sm text-app-danger">{{ errors.current_password|first }}</p>
          {% else %}
            <p class="text-sm text-app-muted">Required when changing password.</p>
          {% endif %}
        </div>

        <div class="grid gap-2">
          <label class="text-[0.82rem] font-semibold text-app-text" for="password">New password</label>
          <input
            class="w-full rounded-2xl border border-app-border bg-app-surface-2/80 px-4 py-3 text-app-text placeholder:text-app-muted outline-none transition focus:border-app-accent focus:ring-4 focus:ring-app-accent/10"
            id="password"
            name="password"
            type="password"
            autocomplete="new-password"
            placeholder="Leave blank to keep current password"
          >
          <p class="text-sm text-app-muted">Minimum 8 characters. Leave blank to keep the current password.</p>
          {% if errors.password is defined %}
            <p class="text-sm text-app-danger">{{ errors.password|first }}</p>
          {% endif %}
        </div>

        <div class="grid gap-2">
          <label class="text-[0.82rem] font-semibold text-app-text" for="password_confirmation">Confirm new password</label>
          <input
            class="w-full rounded-2xl border border-app-border bg-app-surface-2/80 px-4 py-3 text-app-text placeholder:text-app-muted outline-none transition focus:border-app-accent focus:ring-4 focus:ring-app-accent/10"
            id="password_confirmation"
            name="password_confirmation"
            type="password"
            autocomplete="new-password"
            placeholder="Repeat the new password"
          >
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <button class="{{ button_primary }} w-full sm:w-auto" type="submit">{{ submit_label }}</button>
        </div>
      </form>
    {% endblock %}
  {% endembed %}
{% endblock %}
