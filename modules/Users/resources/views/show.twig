{% extends "layouts/admin.twig" %}

{% block title %}{{ user.getAttribute('name') }} | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-xl border px-3.5 py-2 text-[0.82rem] font-semibold transition' %}
  {% set button_primary = button_base ~ ' border-transparent bg-app-accent text-white hover:bg-app-accent-soft' %}
  {% set button_secondary = button_base ~ ' border-app-border bg-app-surface/80 text-app-text hover:bg-app-surface-2/70' %}
  {% set tab_base = 'inline-flex items-center justify-center gap-2 rounded-xl border px-4 py-2 text-sm font-semibold transition' %}
  {% set tab_active = 'border-app-accent/20 bg-app-accent/10 text-app-accent' %}
  {% set tab_inactive = 'border-app-border bg-app-surface/60 text-app-text hover:bg-app-surface-2/70' %}
  {% set is_trashed = user.getAttribute('deleted_at') is not empty %}
  {% set protected_id = protected_admin_id|default(null) %}
  {% set is_protected = protected_id is not null and user.getKey() == protected_id %}
  {% set initials = user.getAttribute('name')|slice(0, 1)|upper %}
  {% set created = user.getAttribute('created_at') %}
  {% set lastLogin = user.getAttribute('last_login_at') %}
  {% set accountAge = created ? date().diff(date(created)).days : null %}
  {% set role = user.role() %}
  {% set role_name = role is not null ? role.getAttribute('name') : 'Unknown' %}
  {% set role_slug = role is not null ? role.getAttribute('slug') : '' %}
  {% set permissions = role is not null ? role.permissions() : [] %}
  {% set default_tab = default_tab|default('overview') %}
  {% set activities = activities|default([]) %}
  {% set activity_total = activity_total|default(0) %}
  {% set activity_pagination = activity_pagination|default({ links: [], summary: '' }) %}
  {% set status_label = is_trashed ? 'Trashed' : (user.getAttribute('is_active') ? 'Active' : 'Disabled') %}
  {% set status_tone = is_trashed ? 'border-app-danger/20 bg-app-danger/10 text-app-danger' : (user.getAttribute('is_active') ? 'border-app-success/20 bg-app-success/10 text-app-success' : 'border-app-warning/20 bg-app-warning/10 text-app-warning') %}
  {% set status_value_tone = is_trashed ? 'text-app-danger' : (user.getAttribute('is_active') ? 'text-app-success' : 'text-app-warning') %}
  {% set last_login_label = lastLogin ? lastLogin|date('M j, Y \\a\\t g:i A') : 'Never logged in' %}
  {% set account_age_label = created ? (accountAge == 0 ? 'Created today' : accountAge ~ ' day' ~ (accountAge != 1 ? 's' : '') ~ ' old') : 'No creation date' %}

  <div {{ ui().data('{ activeTab: "' ~ default_tab ~ '" }') }}>
    <section class="relative overflow-hidden rounded-[2rem] border border-app-border bg-app-surface/85 shadow-[0_30px_80px_rgba(2,6,23,0.35)] backdrop-blur-xl">
      <div class="relative flex flex-col gap-6 p-6 lg:flex-row lg:items-start lg:justify-between lg:p-8">
        <div class="flex min-w-0 items-start gap-5">
          <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-[1.5rem] bg-app-accent text-2xl font-black tracking-tight text-white shadow-[0_20px_50px_rgba(15,23,42,0.18)] ring-2 ring-app-border/60">
            {{ initials }}
          </div>

          <div class="min-w-0">
            <div class="flex flex-wrap items-center gap-2">
              <span class="inline-flex items-center rounded-full border border-app-accent/20 bg-app-accent/10 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.18em] text-app-accent">
                Identity management
              </span>
              <span class="inline-flex items-center rounded-full border px-3 py-1 text-[0.65rem] font-bold uppercase tracking-[0.18em] {{ status_tone }}">
                {{ status_label }}
              </span>
              {% if role is not null %}
                <span class="inline-flex items-center rounded-full border border-app-border bg-app-surface-2/70 px-3 py-1 text-[0.65rem] font-bold uppercase tracking-[0.18em] text-app-text">
                  {{ role_name }}
                </span>
              {% endif %}
            </div>

            <h1 class="mt-4 text-3xl font-black tracking-tight text-app-text sm:text-4xl">{{ user.getAttribute('name') }}</h1>
            <p class="mt-2 max-w-3xl text-sm leading-6 text-app-muted sm:text-[0.95rem]">
              {{ user.getAttribute('email') }}
            </p>

            <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-app-muted">
              <span class="inline-flex items-center gap-1.5">
                {% include 'components/icon.twig' with { name: 'hash', class: 'h-3.5 w-3.5 text-app-accent' } %}
                <span class="font-mono font-semibold text-app-text">#{{ user.getKey() }}</span>
              </span>
              <span class="inline-flex items-center gap-1.5">
                {% include 'components/icon.twig' with { name: 'calendar', class: 'h-3.5 w-3.5 text-app-accent' } %}
                Joined <span class="font-medium text-app-text">{{ created ? created|date('M j, Y') : 'N/A' }}</span>
              </span>
              <span class="inline-flex items-center gap-1.5">
                {% include 'components/icon.twig' with { name: 'clock-3', class: 'h-3.5 w-3.5 text-app-accent' } %}
                Last login <span class="font-medium text-app-text">{{ last_login_label }}</span>
              </span>
            </div>
          </div>
        </div>

        <div class="flex flex-wrap gap-2 lg:justify-end">
          <a class="{{ button_secondary }}" href="/admin/users">
            {% include 'components/icon.twig' with { name: 'arrow-left', class: 'h-4 w-4' } %}
            Back to users
          </a>
          {% if gate.allows('users.edit') and not is_trashed %}
            <a class="{{ button_primary }}" href="/admin/users/{{ user.getKey() }}/edit">
              {% include 'components/icon.twig' with { name: 'pencil', class: 'h-4 w-4' } %}
              Edit user
            </a>
          {% endif %}
        </div>
      </div>
    </section>

    <nav class="mt-6 flex flex-wrap gap-2 rounded-[1.35rem] border border-app-border bg-app-surface/80 p-2 shadow-[0_18px_50px_rgba(2,6,23,0.18)] backdrop-blur-xl">
      <button
        type="button"
        {{ ui().click('activeTab = "overview"') }}
        class="{{ tab_base }}"
        {{ ui().bind('class', "activeTab === 'overview' ? '" ~ tab_active ~ "' : '" ~ tab_inactive ~ "'") }}
      >
        Overview
      </button>
      <button
        type="button"
        {{ ui().click('activeTab = "activity"') }}
        class="{{ tab_base }}"
        {{ ui().bind('class', "activeTab === 'activity' ? '" ~ tab_active ~ "' : '" ~ tab_inactive ~ "'") }}
      >
        Activity
        <span class="rounded-full border border-app-border bg-app-surface-2/70 px-2.5 py-0.5 text-[0.68rem] font-bold uppercase tracking-[0.14em] text-app-muted">
          {{ activity_total }}
        </span>
      </button>
      <button
        type="button"
        {{ ui().click('activeTab = "permissions"') }}
        class="{{ tab_base }}"
        {{ ui().bind('class', "activeTab === 'permissions' ? '" ~ tab_active ~ "' : '" ~ tab_inactive ~ "'") }}
      >
        Permissions
        <span class="rounded-full border border-app-border bg-app-surface-2/70 px-2.5 py-0.5 text-[0.68rem] font-bold uppercase tracking-[0.14em] text-app-muted">
          {{ permissions|length }}
        </span>
      </button>
    </nav>

    <div class="mt-6 space-y-6">
      <section {{ ui().show("activeTab === 'overview'") }}>
        <div class="grid gap-4 md:grid-cols-3">
          <article class="rounded-[1.25rem] border border-app-border bg-app-surface/80 p-4 shadow-[0_24px_70px_rgba(2,6,23,0.18)] backdrop-blur-xl">
            <div class="flex items-center justify-between">
              <span class="text-xs font-bold uppercase tracking-[0.18em] text-app-muted">Status</span>
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl {{ is_trashed ? 'bg-app-danger/10 text-app-danger' : (user.getAttribute('is_active') ? 'bg-app-success/10 text-app-success' : 'bg-app-warning/10 text-app-warning') }}">
                {% include 'components/icon.twig' with { name: is_trashed ? 'archive' : (user.getAttribute('is_active') ? 'badge-check' : 'ban'), class: 'h-4 w-4' } %}
              </span>
            </div>
            <div class="mt-4 text-lg font-bold tracking-tight {{ status_value_tone }}">{{ status_label }}</div>
            <p class="mt-1 text-sm text-app-muted">{{ is_protected ? 'Protected account' : 'Standard account' }}</p>
          </article>

          <article class="rounded-[1.25rem] border border-app-border bg-app-surface/80 p-4 shadow-[0_24px_70px_rgba(2,6,23,0.18)] backdrop-blur-xl">
            <div class="flex items-center justify-between">
              <span class="text-xs font-bold uppercase tracking-[0.18em] text-app-muted">Age</span>
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-app-success/10 text-app-success">
                {% include 'components/icon.twig' with { name: 'calendar-days', class: 'h-4 w-4' } %}
              </span>
            </div>
            <div class="mt-4 text-lg font-bold tracking-tight text-app-text">{{ account_age_label }}</div>
            <p class="mt-1 text-sm text-app-muted">{{ created ? 'Created ' ~ created|date('M j, Y') : 'No creation timestamp available' }}</p>
          </article>

          <article class="rounded-[1.25rem] border border-app-border bg-app-surface/80 p-4 shadow-[0_24px_70px_rgba(2,6,23,0.18)] backdrop-blur-xl">
            <div class="flex items-center justify-between">
              <span class="text-xs font-bold uppercase tracking-[0.18em] text-app-muted">Login</span>
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-app-accent/10 text-app-accent">
                {% include 'components/icon.twig' with { name: 'log-in', class: 'h-4 w-4' } %}
              </span>
            </div>
            <div class="mt-4 text-lg font-bold tracking-tight text-app-text">{{ lastLogin ? lastLogin|date('M j, H:i') : 'Never' }}</div>
            <p class="mt-1 text-sm text-app-muted">{{ lastLogin ? 'Last active recently' : 'No sign-in history yet' }}</p>
          </article>
        </div>

        <section class="mt-6 overflow-hidden rounded-[1.5rem] border border-app-border bg-app-surface/80 p-6 shadow-[0_24px_70px_rgba(2,6,23,0.18)] backdrop-blur-xl">
          <div class="flex items-center justify-between gap-3 border-b border-app-border pb-4">
            <div>
              <h2 class="text-lg font-bold tracking-tight text-app-text">Account details</h2>
              <p class="mt-1 text-sm text-app-muted">Core identity and status information only.</p>
            </div>
          </div>

          <dl class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-2xl border border-app-border bg-app-surface-2/60 p-4">
              <dt class="text-xs font-bold uppercase tracking-[0.16em] text-app-muted">User ID</dt>
              <dd class="mt-2 font-mono text-sm font-semibold text-app-text">#{{ user.getKey() }}</dd>
            </div>
            <div class="rounded-2xl border border-app-border bg-app-surface-2/60 p-4">
              <dt class="text-xs font-bold uppercase tracking-[0.16em] text-app-muted">Email</dt>
              <dd class="mt-2 break-all font-mono text-sm font-semibold text-app-text">{{ user.getAttribute('email') }}</dd>
            </div>
            <div class="rounded-2xl border border-app-border bg-app-surface-2/60 p-4">
              <dt class="text-xs font-bold uppercase tracking-[0.16em] text-app-muted">Created</dt>
              <dd class="mt-2 text-sm font-semibold text-app-text">{{ created ? created|date('M j, Y \\a\\t H:i') : 'N/A' }}</dd>
            </div>
            <div class="rounded-2xl border border-app-border bg-app-surface-2/60 p-4">
              <dt class="text-xs font-bold uppercase tracking-[0.16em] text-app-muted">Updated</dt>
              <dd class="mt-2 text-sm font-semibold text-app-text">{{ user.getAttribute('updated_at') ? user.getAttribute('updated_at')|date('M j, Y \\a\\t H:i') : 'N/A' }}</dd>
            </div>
          </dl>
        </section>
      </section>

      <section {{ ui().show("activeTab === 'activity'") }}>
        {% include 'components/activity-log.twig' with {
          title: 'Recent activity',
          description: 'Rows from the activity table for this user account.',
          rows: activities,
          pagination: activity_pagination,
          compact: true,
          show_source: false,
          count_label: activity_total ~ ' entries',
          empty_message: 'No activity recorded for this user yet.'
        } only %}
      </section>

      <section {{ ui().show("activeTab === 'permissions'") }}>
        {% include 'components/permission-panel.twig' with {
          title: 'Role and permissions',
          description: 'The role controls access, and permissions are inherited from it.',
          role_name: role_name,
          role_slug: role_slug,
          permissions: permissions,
          limit: 8,
          empty_message: 'No permissions assigned to this role.',
          count_label: permissions|length ~ ' permissions'
        } only %}
      </section>
    </div>
  </div>
{% endblock %}
