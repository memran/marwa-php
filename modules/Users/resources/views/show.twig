{% extends "layout.twig" %}

{% block title %}{{ user.getAttribute('name') }} | MarwaPHP Admin{% endblock %}

{% block content %}
  {% include "@users/_buttons.twig" %}
  {% set is_trashed = user.getAttribute('deleted_at') is not empty %}
  {% set initials = user.getAttribute('name')|slice(0, 1)|upper %}
  {% set created = user.getAttribute('created_at') %}
  {% set lastLogin = user.getAttribute('last_login_at') %}
  {% set accountAge = created ? date().diff(date(created)).days : null %}
  {% set role = user.role() %}
  {% set avatar_gradients = ['from-blue-500 to-cyan-400', 'from-purple-500 to-pink-400', 'from-emerald-500 to-teal-400', 'from-orange-500 to-amber-400', 'from-rose-500 to-red-400', 'from-indigo-500 to-violet-400', 'from-sky-500 to-blue-400', 'from-teal-500 to-emerald-400'] %}
  {% set avatar_gradient = avatar_gradients[user.getKey() % avatar_gradients|length] %}

  <section class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-2">
      <span class="inline-flex w-fit items-center rounded-xl border border-cyan-300/20 bg-cyan-400/10 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.16em] text-cyan-100">Identity management</span>
      <h1 class="text-2xl font-black tracking-tight text-white sm:text-3xl">User profile</h1>
      <p class="max-w-2xl text-sm leading-6 text-slate-300">Detailed view of user account and activity.</p>
    </div>

    <div class="flex flex-wrap gap-2">
      <a class="{{ button_secondary }}" href="/admin/users">
        {% include 'components/icon.twig' with { name: 'arrow-left', class: 'h-4 w-4' } %}
        Back to users
      </a>
      {% if gate.allows('users.edit') and not is_trashed %}
        <a class="{{ button_primary }}" href="/admin/users/{{ user.getKey() }}/edit">
          {% include 'components/icon.twig' with { name: 'pencil', class: 'h-4 w-4' } %}
          Edit user
        </a>
      {% endif %}
    </div>
  </section>

  <div class="mt-6 overflow-hidden rounded-[1.25rem] border border-white/10 bg-white/5 p-5 shadow-[0_30px_80px_rgba(2,6,23,0.45)] backdrop-blur-xl sm:p-6">
    <div class="flex flex-col items-start gap-5 sm:flex-row sm:items-center">
      <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-gradient-to-br {{ avatar_gradient }} text-xl font-bold text-white shadow-lg ring-2 ring-white/20">
        {{ initials }}
      </div>
      <div class="min-w-0 flex-1">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
          <div class="min-w-0">
            <h2 class="text-xl font-bold tracking-tight text-white">{{ user.getAttribute('name') }}</h2>
            <p class="mt-0.5 font-mono text-sm text-slate-400">{{ user.getAttribute('email') }}</p>
          </div>
          <div class="flex shrink-0 flex-wrap items-center gap-2">
            {% include "@users/_badges.twig" %}
          </div>
        </div>
        <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-slate-500">
          <span>ID <span class="font-mono text-slate-400">{{ user.getKey() }}</span></span>
          {% if created %}
            <span>Joined <span class="font-mono text-slate-400">{{ created|date('M j, Y') }}</span></span>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  <div class="mt-4 grid grid-cols-2 gap-4 lg:grid-cols-4">
    <div class="rounded-xl border border-white/10 bg-white/5 p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-medium text-slate-400 uppercase tracking-wider">Last Login</span>
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-cyan-400/10">
          {% include 'components/icon.twig' with { name: 'log-in', class: 'h-4 w-4 text-cyan-300' } %}
        </span>
      </div>
      <div class="font-mono text-lg font-bold tabular-nums text-white">{{ lastLogin ? lastLogin|date('M j, H:i') : 'Never' }}</div>
      <div class="mt-1 text-xs text-slate-500">{{ lastLogin ? date().diff(date(lastLogin)).days == 0 ? 'Today' : date().diff(date(lastLogin)).days ~ ' day' ~ (date().diff(date(lastLogin)).days != 1 ? 's' : '') ~ ' ago' : '' }}</div>
    </div>

    <div class="rounded-xl border border-white/10 bg-white/5 p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-medium text-slate-400 uppercase tracking-wider">Account Age</span>
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-400/10">
          {% include 'components/icon.twig' with { name: 'calendar', class: 'h-4 w-4 text-emerald-300' } %}
        </span>
      </div>
      <div class="font-mono text-lg font-bold tabular-nums text-white">{{ accountAge is not null ? (accountAge == 0 ? 'Today' : accountAge ~ ' day' ~ (accountAge != 1 ? 's' : '')) : 'N/A' }}</div>
      <div class="mt-1 text-xs text-slate-500">{{ created ? 'Since ' ~ created|date('M j, Y') : '' }}</div>
    </div>

    <div class="rounded-xl border border-white/10 bg-white/5 p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-medium text-slate-400 uppercase tracking-wider">Role</span>
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-purple-400/10">
          {% include 'components/icon.twig' with { name: 'shield', class: 'h-4 w-4 text-purple-300' } %}
        </span>
      </div>
      <div class="font-mono text-lg font-bold tabular-nums text-white">{{ role is not null ? role.getAttribute('name') : 'Unknown' }}</div>
      <div class="mt-1 text-xs text-slate-500">{{ role is not null and role.getAttribute('slug') == 'admin' ? 'Full system access' : 'Limited permissions' }}</div>
    </div>

    <div class="rounded-xl border border-white/10 bg-white/5 p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-medium text-slate-400 uppercase tracking-wider">Status</span>
        <span class="flex h-8 w-8 items-center justify-center rounded-lg {{ is_trashed ? 'bg-rose-400/10' : (user.getAttribute('is_active') ? 'bg-emerald-400/10' : 'bg-amber-400/10') }}">
          {% include 'components/icon.twig' with { name: is_trashed ? 'archive' : (user.getAttribute('is_active') ? 'badge-check' : 'ban'), class: 'h-4 w-4 ' ~ (is_trashed ? 'text-rose-300' : (user.getAttribute('is_active') ? 'text-emerald-300' : 'text-amber-300')) } %}
        </span>
      </div>
      <div class="font-mono text-lg font-bold tabular-nums text-white">{{ is_trashed ? 'Trashed' : (user.getAttribute('is_active') ? 'Active' : 'Disabled') }}</div>
      <div class="mt-1 text-xs text-slate-500">{{ _is_protected is defined and _is_protected ? 'Protected account' : (is_trashed ? 'Soft-deleted' : (user.getAttribute('is_active') ? 'Can sign in' : 'Access revoked')) }}</div>
    </div>
  </div>

  <div class="mt-4 grid gap-4 lg:grid-cols-2">
    <div class="overflow-hidden rounded-[1.25rem] border border-white/10 bg-white/5 p-5 shadow-[0_30px_80px_rgba(2,6,23,0.45)] backdrop-blur-xl">
      <h3 class="flex items-center gap-2 text-base font-semibold text-white">
        {% include 'components/icon.twig' with { name: 'user', class: 'h-4 w-4 text-cyan-300' } %}
        Profile Details
      </h3>
      <div class="mt-4 divide-y divide-white/10">
        <div class="flex items-center justify-between py-2.5">
          <span class="text-sm text-slate-400">Full name</span>
          <span class="text-sm font-medium text-white">{{ user.getAttribute('name') }}</span>
        </div>
        <div class="flex items-center justify-between py-2.5">
          <span class="text-sm text-slate-400">Email</span>
          <span class="font-mono text-sm font-medium text-white">{{ user.getAttribute('email') }}</span>
        </div>
        <div class="flex items-center justify-between py-2.5">
          <span class="text-sm text-slate-400">User ID</span>
          <span class="font-mono text-sm font-medium text-white">{{ user.getKey() }}</span>
        </div>
        <div class="flex items-center justify-between py-2.5">
          <span class="text-sm text-slate-400">Created</span>
          <span class="font-mono text-sm font-medium text-white">{{ created ? created|date('M j, Y \\a\\t H:i') : 'N/A' }}</span>
        </div>
        <div class="flex items-center justify-between py-2.5">
          <span class="text-sm text-slate-400">Updated</span>
          <span class="font-mono text-sm font-medium text-white">{{ user.getAttribute('updated_at') ? user.getAttribute('updated_at')|date('M j, Y \\a\\t H:i') : 'N/A' }}</span>
        </div>
      </div>
    </div>

    <div class="overflow-hidden rounded-[1.25rem] border border-white/10 bg-white/5 p-5 shadow-[0_30px_80px_rgba(2,6,23,0.45)] backdrop-blur-xl">
      <h3 class="flex items-center gap-2 text-base font-semibold text-white">
        {% include 'components/icon.twig' with { name: 'shield', class: 'h-4 w-4 text-cyan-300' } %}
        Role &amp; Permissions
      </h3>
      <div class="mt-4 divide-y divide-white/10">
        <div class="flex items-center justify-between py-2.5">
          <span class="text-sm text-slate-400">Role</span>
          <span class="inline-flex items-center rounded-full border border-purple-300/20 bg-purple-400/10 px-2.5 py-0.5 text-xs font-medium text-purple-200">
            {% include 'components/icon.twig' with { name: 'shield', class: 'mr-1 h-3 w-3' } %}
            {{ role is not null ? role.getAttribute('name') : 'Unknown' }}
          </span>
        </div>
        <div class="flex items-center justify-between py-2.5">
          <span class="text-sm text-slate-400">Status</span>
          <span>{% include "@users/_badges.twig" %}</span>
        </div>
        <div class="flex items-center justify-between py-2.5">
          <span class="text-sm text-slate-400">Last login IP</span>
          <span class="font-mono text-sm text-slate-400">—</span>
        </div>
        <div class="flex items-center justify-between py-2.5">
          <span class="text-sm text-slate-400">Email verified</span>
          <span class="inline-flex items-center gap-1 text-sm font-medium text-emerald-300">
            {% include 'components/icon.twig' with { name: 'badge-check', class: 'h-3.5 w-3.5' } %}
            Verified
          </span>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-4 overflow-hidden rounded-[1.25rem] border border-white/10 bg-white/5 p-5 shadow-[0_30px_80px_rgba(2,6,23,0.45)] backdrop-blur-xl">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <h3 class="flex items-center gap-2 text-base font-semibold text-white">
        {% include 'components/icon.twig' with { name: 'activity', class: 'h-4 w-4 text-cyan-300' } %}
        Actions
      </h3>
    </div>
    <div class="mt-4 flex flex-wrap gap-3">
      {% if gate.allows('users.edit') and not is_trashed %}
        <a href="/admin/users/{{ user.getKey() }}/edit" class="{{ button_primary }}">
          {% include 'components/icon.twig' with { name: 'pencil', class: 'h-4 w-4' } %}
          Edit user
        </a>
      {% endif %}

      {% if gate.allows('users.delete') and not is_trashed and not _is_protected %}
        <form method="post" action="/admin/users/{{ user.getKey() }}/delete" onsubmit="return confirm('Delete this user?');">
          {{ csrf_field() }}
          <button type="submit" class="{{ button_danger }}">
            {% include 'components/icon.twig' with { name: 'trash-2', class: 'h-4 w-4' } %}
            Delete user
          </button>
        </form>
      {% endif %}

      {% if is_trashed %}
        <span class="flex items-center gap-2 rounded-xl border border-rose-500/20 bg-rose-500/10 px-4 py-2 text-sm font-medium text-rose-200">
          {% include 'components/icon.twig' with { name: 'archive', class: 'h-4 w-4' } %}
          This user has been trashed
        </span>
      {% endif %}
    </div>
  </div>
{% endblock %}
