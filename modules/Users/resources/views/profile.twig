{% extends "layout.twig" %}

{% block title %}My Profile | MarwaPHP Admin{% endblock %}

{% block content %}
  {% include "@users/_buttons.twig" %}
  {% set user = authUser %}
  {% set role = user.role() %}
  {% set permissions = role is not null ? role.permissions() : [] %}
  {% set name = user.getAttribute('name') %}
  {% set email = user.getAttribute('email') %}
  {% set initials = name|slice(0, 1)|upper %}
  {% set created = user.getAttribute('created_at') %}
  {% set lastLogin = user.getAttribute('last_login_at') %}
  {% set updated = user.getAttribute('updated_at') %}

  <section class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-2">
      <span class="inline-flex w-fit items-center rounded-xl border border-cyan-300/20 bg-cyan-400/10 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.16em] text-cyan-100">Account</span>
      <h1 class="text-2xl font-black tracking-tight text-white sm:text-3xl">My Profile</h1>
      <p class="max-w-2xl text-sm leading-6 text-slate-300">Your personal account details, security information, and access permissions.</p>
    </div>
  </section>

  <div class="mt-6 grid gap-6 lg:grid-cols-3">
    <div class="users-form-shell rounded-xl border p-6 lg:col-span-1">
      <div class="flex flex-col items-center text-center">
        <div class="flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-cyan-400 to-blue-600 text-2xl font-bold tracking-tight text-white shadow-lg shadow-cyan-500/20">
          {{ initials }}
        </div>
        <h2 class="mt-4 text-xl font-bold tracking-tight text-white">{{ name }}</h2>
        <p class="mt-0.5 text-sm text-slate-400">{{ email }}</p>

        <div class="mt-4 flex flex-wrap justify-center gap-2">
          {% if role is not null %}
            <span class="inline-flex items-center gap-1.5 rounded-full bg-cyan-400/10 px-3 py-1 text-xs font-medium text-cyan-200">
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>
              {{ role.getAttribute('name') }}
            </span>
          {% endif %}
          {% include "@users/_badges.twig" %}
        </div>
      </div>

      <div class="mt-6 space-y-3 border-t border-white/5 pt-6">
        <div class="flex items-center justify-between">
          <span class="text-xs font-semibold uppercase tracking-wider text-slate-400">Member since</span>
          <span class="text-sm text-slate-200">{{ created ? created|date('M j, Y') : 'N/A' }}</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-xs font-semibold uppercase tracking-wider text-slate-400">Last updated</span>
          <span class="text-sm text-slate-200">{{ updated ? updated|date('M j, Y') : 'N/A' }}</span>
        </div>
      </div>
    </div>

    <div class="users-form-shell rounded-xl border p-6 lg:col-span-1">
      <div class="mb-4 flex items-center gap-2.5">
        <svg class="h-5 w-5 shrink-0 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
        </svg>
        <h2 class="text-lg font-semibold text-slate-100">Security</h2>
      </div>

      <dl class="space-y-4">
        <div class="rounded-xl border border-white/5 bg-white/[0.02] px-4 py-3">
          <dt class="flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-slate-400">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z" /></svg>
            Last login
          </dt>
          <dd class="mt-1 text-sm text-slate-200">
            {% if lastLogin %}
              {{ lastLogin|date('M j, Y \\a\\t g:i A') }}
            {% else %}
              <span class="text-slate-500">Never logged in</span>
            {% endif %}
          </dd>
        </div>

        <div class="rounded-xl border border-white/5 bg-white/[0.02] px-4 py-3">
          <dt class="flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-slate-400">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>
            Account created
          </dt>
          <dd class="mt-1 text-sm text-slate-200">{{ created ? created|date('M j, Y \\a\\t g:i A') : 'N/A' }}</dd>
        </div>

        <div class="rounded-xl border border-white/5 bg-white/[0.02] px-4 py-3">
          <dt class="flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-slate-400">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z" /></svg>
            Account ID
          </dt>
          <dd class="mt-1 font-mono text-sm text-slate-200">#{{ user.getKey() }}</dd>
        </div>
      </dl>
    </div>

    <div class="users-form-shell rounded-xl border p-6 lg:col-span-1">
      <div class="mb-4 flex items-center gap-2.5">
        <svg class="h-5 w-5 shrink-0 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
        </svg>
        <h2 class="text-lg font-semibold text-slate-100">Access &amp; Permissions</h2>
      </div>

      <div class="mb-4 rounded-xl border border-white/5 bg-white/[0.02] px-4 py-3">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-slate-200">
              {% if role is not null %}
                {{ role.getAttribute('name') }}
              {% else %}
                <span class="text-slate-500">No role assigned</span>
              {% endif %}
            </p>
            {% if role is not null and role.getAttribute('description') %}
              <p class="mt-0.5 text-xs text-slate-400">{{ role.getAttribute('description') }}</p>
            {% endif %}
          </div>
          <span class="inline-flex items-center rounded-full bg-white/5 px-2.5 py-0.5 text-xs font-medium text-slate-300">
            {{ permissions|length }} {{ permissions|length == 1 ? 'permission' : 'permissions' }}
          </span>
        </div>
      </div>

      {% if permissions is not empty %}
        {% set grouped = {} %}
        {% for perm in permissions %}
          {% set group = perm.getAttribute('group') ?: 'General' %}
          {% if grouped[group] is not defined %}
            {% set grouped = grouped|merge({ (group): [] }) %}
          {% endif %}
          {% set grouped = grouped|merge({ (group): grouped[group]|merge([perm]) }) %}
        {% endfor %}

        <div class="max-h-72 space-y-4 overflow-y-auto pr-1">
          {% for group, perms in grouped %}
            <div>
              <h4 class="mb-2 text-[0.65rem] font-bold uppercase tracking-[0.18em] text-slate-500">{{ group }}</h4>
              <div class="flex flex-wrap gap-1.5">
                {% for perm in perms %}
                  <span class="inline-flex items-center gap-1 rounded-md border border-white/5 bg-white/[0.03] px-2 py-1 text-xs text-slate-300" title="{{ perm.getAttribute('slug') }}">
                    <svg class="h-2.5 w-2.5 shrink-0 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                    {{ perm.getAttribute('name') }}
                  </span>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <p class="text-sm text-slate-500">No permissions assigned to your role.</p>
      {% endif %}
    </div>
  </div>
{% endblock %}
