{% extends "layout.twig" %}

{% block title %}{{ user.getAttribute('name')|default('User profile') }} | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-full border px-5 py-3 text-sm font-semibold transition hover:-translate-y-0.5' %}
  {% set button_secondary = button_base ~ ' border-white/10 bg-white/5 text-slate-100 hover:bg-white/10' %}
  {% set button_ghost = button_base ~ ' border-white/10 bg-transparent text-slate-200 hover:bg-white/5' %}

  <section class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-3">
      <span class="inline-flex w-fit items-center rounded-full border border-cyan-300/20 bg-cyan-400/10 px-4 py-1.5 text-[0.7rem] font-extrabold uppercase tracking-[0.22em] text-cyan-100">Identity management</span>
      <h1 class="text-3xl font-black tracking-tight text-white sm:text-4xl">{{ user.getAttribute('name')|default('Unknown user') }}</h1>
      <p class="max-w-2xl text-sm leading-6 text-slate-300 sm:text-base">Read-only profile details for this user account.</p>
    </div>

    <div class="flex flex-wrap gap-3">
      <a class="{{ button_ghost }}" href="/admin/users">Back to users</a>
      {% if not user.getAttribute('deleted_at') %}
        <a class="{{ button_secondary }}" href="/admin/users/{{ user.getKey() }}/edit">Edit user</a>
      {% endif %}
    </div>
  </section>

  <section class="mt-8 overflow-hidden rounded-[2rem] border border-white/10 bg-white/5 p-5 shadow-[0_30px_80px_rgba(2,6,23,0.45)] backdrop-blur-xl sm:p-6">
    <div class="border-b border-white/10 pb-5">
      <div>
        <h2 class="text-2xl font-bold tracking-tight text-white">Account snapshot</h2>
        <p class="mt-1 text-sm text-slate-400">Current identity, access, and lifecycle details.</p>
      </div>
    </div>

    <div class="mt-5 overflow-hidden rounded-[1.5rem] border border-white/10">
      <table class="w-full border-collapse">
        <tbody class="divide-y divide-white/10">
        <tr class="align-top">
          <td class="w-44 px-3 py-3 text-sm font-semibold uppercase tracking-[0.12em] text-slate-300">Full Name</td>
          <td class="px-3 py-3 text-sm text-slate-200">{{ user.getAttribute('name')|default('Unknown') }}</td>
        </tr>
        <tr class="align-top">
          <td class="w-44 px-3 py-3 text-sm font-semibold uppercase tracking-[0.12em] text-slate-300">Email Address</td>
          <td class="px-3 py-3 text-sm text-slate-200">{{ user.getAttribute('email')|default('Unknown') }}</td>
        </tr>
        <tr class="align-top">
          <td class="w-44 px-3 py-3 text-sm font-semibold uppercase tracking-[0.12em] text-slate-300">Role</td>
          <td class="px-3 py-3">
            {% set user_role = user.role() %}
            <span class="inline-flex rounded-full border border-cyan-300/20 bg-cyan-400/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-cyan-100">
              {{ user_role is not null ? user_role.getAttribute('name') : 'Unknown' }}
            </span>
          </td>
        </tr>
        <tr class="align-top">
          <td class="w-44 px-3 py-3 text-sm font-semibold uppercase tracking-[0.12em] text-slate-300">Account Status</td>
          <td class="px-3 py-3">
            {% if user.getAttribute('deleted_at') %}
              <span class="inline-flex items-center gap-2 rounded-full border border-rose-400/20 bg-rose-500/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-rose-100">
                {% include 'components/icon.twig' with { name: 'trash-2', class: 'h-4 w-4 shrink-0' } only %}
                <span>Trashed</span>
              </span>
            {% elseif user.getAttribute('is_active') %}
              <span class="inline-flex rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-emerald-100">Active</span>
            {% else %}
              <span class="inline-flex rounded-full border border-amber-400/20 bg-amber-400/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-amber-100">Disabled</span>
            {% endif %}
            {% if protected_admin_id is defined and protected_admin_id is not null and user.getKey() == protected_admin_id %}
              <div class="mt-2">
                <span class="inline-flex items-center gap-2 rounded-full border border-amber-400/20 bg-amber-400/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-amber-100">
                  {% include 'components/icon.twig' with { name: 'shield', class: 'h-4 w-4 shrink-0' } only %}
                  <span>Protected</span>
                </span>
              </div>
            {% endif %}
          </td>
        </tr>
        <tr class="align-top">
          <td class="w-44 px-3 py-3 text-sm font-semibold uppercase tracking-[0.12em] text-slate-300">Last Sign-In</td>
          <td class="px-3 py-3 text-sm text-slate-200">{{ user.getAttribute('last_login_at')|default('Never') }}</td>
        </tr>
        <tr class="align-top">
          <td class="w-44 px-3 py-3 text-sm font-semibold uppercase tracking-[0.12em] text-slate-300">Deleted At</td>
          <td class="px-3 py-3 text-sm text-slate-200">{{ user.getAttribute('deleted_at')|default('Not deleted') }}</td>
        </tr>
        <tr class="align-top">
          <td class="w-44 px-3 py-3 text-sm font-semibold uppercase tracking-[0.12em] text-slate-300">User ID</td>
          <td class="px-3 py-3 text-sm text-slate-200">{{ user.getKey() }}</td>
        </tr>
        </tbody>
      </table>
    </div>
  </section>
{% endblock %}
