{% extends "layout.twig" %}

{% block title %}My Profile | MarwaPHP Admin{% endblock %}

{% block content %}
  {% include "@users/_buttons.twig" %}
  {% set user = authUser %}

  <section class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-2">
      <span class="inline-flex w-fit items-center rounded-xl border border-cyan-300/20 bg-cyan-400/10 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.16em] text-cyan-100">Account</span>
      <h1 class="text-2xl font-black tracking-tight text-white sm:text-3xl">Account snapshot</h1>
      <p class="max-w-2xl text-sm leading-6 text-slate-300">Your profile and account details.</p>
    </div>
  </section>

  <div class="mt-6 grid gap-6 lg:grid-cols-2">
    <div class="rounded-xl border border-white/10 bg-white/5 p-6">
      <h2 class="mb-4 text-lg font-semibold text-slate-100">Profile</h2>
      <dl class="space-y-4">
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">Name</dt>
          <dd class="mt-1 text-sm text-slate-200">{{ user.getAttribute('name') }}</dd>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">Email</dt>
          <dd class="mt-1 text-sm text-slate-200">{{ user.getAttribute('email') }}</dd>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">Role</dt>
          <dd class="mt-1">
            {% set role = user.role() %}
            <span class="inline-flex items-center rounded-full bg-cyan-400/10 px-2 py-0.5 text-xs font-medium text-cyan-200">
              {{ role is not null ? role.getAttribute('name') : 'Unknown' }}
            </span>
          </dd>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">Status</dt>
          <dd class="mt-1">
            {% include "@users/_badges.twig" %}
          </dd>
        </div>
      </dl>
    </div>
  </div>
{% endblock %}
