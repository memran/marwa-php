{% extends "layout.twig" %}

{% block title %}Users | MarwaPHP Admin{% endblock %}

{% block content %}
  {% include "@users/_buttons.twig" %}

  <section class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-2">
      <span class="inline-flex w-fit items-center rounded-xl border border-cyan-300/20 bg-cyan-400/10 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.16em] text-cyan-100">Identity management</span>
      <h1 class="text-2xl font-black tracking-tight text-white sm:text-3xl">Users</h1>
      <p class="max-w-2xl text-sm leading-6 text-slate-300">Manage user accounts, roles, and access.</p>
    </div>

    <div class="flex flex-wrap gap-2">
      {% if gate.allows('users.create') %}
        <a class="{{ button_primary }}" href="/admin/users/create">Create user</a>
      {% endif %}
    </div>
  </section>

  <div class="mt-4 overflow-hidden rounded-xl border border-white/10 bg-white/5">
    <table class="w-full">
      <thead>
        <tr class="border-b border-white/10 bg-white/5 text-left">
          <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-slate-400">Name</th>
          <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-slate-400">Email</th>
          <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-slate-400">Role</th>
          <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-slate-400">Status</th>
          <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-slate-400">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-white/5">
        {% for user in users %}
          <tr class="hover:bg-white/5">
            <td class="px-4 py-3">
              <a href="/admin/users/{{ user.getKey() }}" class="text-sm font-semibold text-slate-100 hover:text-cyan-200">{{ user.getAttribute('name') }}</a>
              <span class="ml-2 text-xs text-slate-500">ID {{ user.getKey() }}</span>
            </td>
            <td class="px-4 py-3">
              <span class="text-sm text-slate-300">{{ user.getAttribute('email') }}</span>
            </td>
            <td class="px-4 py-3">
              {% set role = user.role() %}
              <span class="inline-flex items-center rounded-full bg-cyan-400/10 px-2 py-0.5 text-xs font-medium text-cyan-200">
                {{ role is not null ? role.getAttribute('name') : 'Unknown' }}
              </span>
            </td>
            <td class="px-4 py-3">
              {% include "@users/_badges.twig" %}
            </td>
            <td class="px-4 py-3">
              <div class="flex items-center gap-2">
                <a href="/admin/users/{{ user.getKey() }}" class="rounded-lg p-2 text-slate-400 hover:bg-white/10 hover:text-cyan-200" title="View">
                  {% include 'components/icon.twig' with { name: 'eye', class: 'h-4 w-4' } only %}
                </a>
                {% if gate.allows('users.edit') and not _is_trashed %}
                  <a href="/admin/users/{{ user.getKey() }}/edit" class="rounded-lg p-2 text-slate-400 hover:bg-white/10 hover:text-cyan-200" title="Edit">
                    {% include 'components/icon.twig' with { name: 'pencil', class: 'h-4 w-4' } only %}
                  </a>
                {% endif %}
                {% if gate.allows('users.delete') and not _is_trashed and not _is_protected %}
                  <form method="post" action="/admin/users/{{ user.getKey() }}/delete" onsubmit="return confirm('Delete this user?');">
                    {{ csrf_field() }}
                    <button type="submit" class="rounded-lg p-2 text-slate-400 hover:bg-rose-500/20 hover:text-rose-400" title="Delete">
                      {% include 'components/icon.twig' with { name: 'trash-2', class: 'h-4 w-4' } only %}
                    </button>
                  </form>
                {% endif %}
              </div>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  {% if users|length == 0 %}
    <div class="mt-8 flex flex-col items-center justify-center py-12 text-center">
      <div class="flex h-16 w-16 items-center justify-center rounded-full bg-white/5">
        {% include 'components/icon.twig' with { name: 'users', class: 'h-8 w-8 text-slate-500' } only %}
      </div>
      <h3 class="mt-4 text-lg font-semibold text-slate-200">No users found</h3>
      <p class="mt-1 text-sm text-slate-400">Adjust your search or create a new user.</p>
    </div>
  {% endif %}

  {% include 'components/pagination.twig' with {
    pagination: pagination|default({ summary: '', links: [] }),
    search: true,
    search_value: query|default(''),
    search_url: '/admin/users',
    search_param: 'q',
    sort: sort|default('created_at'),
    direction: direction|default('desc'),
    filter: filter|default('all'),
    filters: [
      { label: 'All', value: 'all', active: filter|default('all') == 'all' },
      { label: 'Active', value: 'active', active: filter|default('all') == 'active' },
      { label: 'Disabled', value: 'disabled', active: filter|default('all') == 'disabled' },
      { label: 'Trashed', value: 'trashed', active: filter|default('all') == 'trashed' },
    ],
  } only %}
{% endblock %}
