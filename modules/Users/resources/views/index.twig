{% extends "layout.twig" %}

{% block title %}Users | MarwaPHP Admin{% endblock %}

{% block content %}
  <section class="admin-page-header">
    <div class="admin-page-header__copy">
      <span class="admin-eyebrow">Identity management</span>
      <h1 class="admin-page-title">Users</h1>
      <p class="admin-page-lead">Minimal admin user management for the starter application.</p>
    </div>

    <div class="admin-table-tools">
      <a class="admin-btn admin-btn--primary" href="/admin/users/create">Create user</a>
    </div>
  </section>

  {% if notice is defined and notice %}
    <div class="admin-alert admin-alert--success">
      <p class="admin-alert__title">Success</p>
      <p class="admin-alert__body">{{ notice }}</p>
    </div>
  {% endif %}

  <section class="admin-table-shell">
    <div class="admin-table-shell__header">
      <div>
        <h2 class="admin-section-title">Registered users</h2>
        <p class="admin-section-subtitle">Search, edit, or deactivate access.</p>
      </div>

      <form class="admin-search" method="get" action="/admin/users">
        <span class="admin-search__icon">⌕</span>
        <input class="admin-search__input" type="search" name="q" value="{{ query|default('') }}" placeholder="Search users">
      </form>
    </div>

    {% if users.data is empty %}
      <div class="admin-alert admin-alert--info">
        <p class="admin-alert__title">No users yet</p>
        <p class="admin-alert__body">Create the first account to start managing access.</p>
      </div>
    {% else %}
      <table class="admin-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Status</th>
            <th>Last login</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {% for user in users.data %}
            <tr>
              <td>
                <div class="admin-row-meta">
                  <span class="admin-row-meta__title">{{ user.getAttribute('name') }}</span>
                  <span class="admin-row-meta__subtitle">ID {{ user.getKey() }}</span>
                </div>
              </td>
              <td>{{ user.getAttribute('email') }}</td>
              <td><span class="admin-badge admin-badge--neutral">{{ user.getAttribute('role') }}</span></td>
              <td>
                {% if user.getAttribute('is_active') %}
                  <span class="admin-badge admin-badge--success">Active</span>
                {% else %}
                  <span class="admin-badge admin-badge--warning">Disabled</span>
                {% endif %}
              </td>
              <td>{{ user.getAttribute('last_login_at')|default('Never') }}</td>
              <td>
                <div class="admin-table-tools">
                  <a class="admin-btn admin-btn--secondary" href="/admin/users/{{ user.getKey() }}/edit">Edit</a>
                  <form method="post" action="/admin/users/{{ user.getKey() }}/delete">
                    <button class="admin-btn admin-btn--danger" type="submit">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}

    <div class="admin-table-shell__footer">
      <div class="admin-section-subtitle">
        Showing {{ users.data|length }} of {{ users.total }} users
      </div>
      <div class="admin-pagination">
        {% for page in 1..users.last_page %}
          <a class="admin-pagination__button {% if page == users.current_page %}admin-pagination__button--active{% endif %}" href="/admin/users?page={{ page }}{% if query|default('') %}&q={{ query|url_encode }}{% endif %}">
            {{ page }}
          </a>
        {% endfor %}
      </div>
    </div>
  </section>
{% endblock %}
