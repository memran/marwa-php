{% extends "layout.twig" %}

{% block title %}Users | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-full border px-5 py-3 text-sm font-semibold transition hover:-translate-y-0.5' %}
  {% set button_primary = 'users-create-button ' ~ button_base %}

  <section class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-3">
      <span class="inline-flex w-fit items-center rounded-full border border-app-accent/20 bg-app-accent/10 px-4 py-1.5 text-[0.7rem] font-extrabold uppercase tracking-[0.22em] text-app-accent">Identity management</span>
      <h1 class="text-3xl font-black tracking-tight text-app-text sm:text-4xl">Users</h1>
      <p class="max-w-2xl text-sm leading-6 text-app-muted sm:text-base">Minimal admin user management for the starter application.</p>
    </div>

    <div class="flex flex-wrap gap-3">
      {% if gate.allows('users.create') %}
      <a class="{{ button_primary }}" href="/admin/users/create">Create user</a>
      {% endif %}
    </div>
  </section>

  {% include 'components/data-table.twig' with { table: table|default({}) } only %}
{% endblock %}
