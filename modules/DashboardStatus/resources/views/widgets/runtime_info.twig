{% set card = card|default({}) %}
<div class="space-y-4">
  <div class="h-1.5 rounded-full bg-gradient-to-r from-violet-300 via-cyan-300 to-violet-300"></div>
  <div class="flex items-start gap-3">
    <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl border border-violet-400/20 bg-violet-400/10 text-violet-100">
      {% include 'components/icon.twig' with { name: 'cpu', class: 'h-5 w-5' } only %}
    </span>
    <div class="space-y-1">
      <p class="dashboard-widget-label text-[0.65rem] font-extrabold uppercase tracking-[0.18em] text-violet-100/75">{{ card.label|default('Runtime') }}</p>
      <div class="dashboard-widget-value text-2xl font-black tracking-tight text-white">{{ card.value|default(constant('PHP_VERSION')) }}</div>
    </div>
  </div>
</div>
