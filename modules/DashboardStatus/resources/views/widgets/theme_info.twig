{% set card = card|default({}) %}
<div class="space-y-4">
  <div class="h-1.5 rounded-full bg-app-accent/70"></div>
  <div class="flex items-start gap-3">
    <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl border border-app-accent/20 bg-app-accent/10 text-app-accent">
      {% include 'components/icon.twig' with { name: 'palette', class: 'h-5 w-5' } only %}
    </span>
    <div class="space-y-1">
      <p class="dashboard-widget-label text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-app-muted">{{ card.label|default('Theme') }}</p>
      <div class="dashboard-widget-value text-2xl font-semibold tracking-tight text-app-text">{{ card.value|default('Admin') }}</div>
      {% if card.meta|default('') is not empty %}
        <p class="text-sm text-app-muted">{{ card.meta|default('') }}</p>
      {% endif %}
    </div>
  </div>
</div>
