{% set card = card|default({}) %}
<div class="space-y-4">
  <div class="h-1.5 rounded-full bg-gradient-to-r from-cyan-300 via-sky-300 to-cyan-300"></div>
  <div class="flex items-start gap-3">
    <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl border border-cyan-400/20 bg-cyan-400/10 text-cyan-100">
      {% include 'components/icon.twig' with { name: 'gauge', class: 'h-5 w-5' } only %}
    </span>
    <div class="space-y-1">
      <p class="dashboard-widget-label text-[0.65rem] font-extrabold uppercase tracking-[0.18em] text-cyan-100/75">{{ card.label|default('Load') }}</p>
      <div class="dashboard-widget-value text-2xl font-black tracking-tight text-white">{{ card.value|default('--') }}</div>
    </div>
  </div>
</div>
