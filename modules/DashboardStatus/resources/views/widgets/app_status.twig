{% set card = card|default({}) %}
<div class="space-y-4">
  <div class="h-1.5 rounded-full bg-app-success/70"></div>
  <div class="flex items-start justify-between gap-3">
    <div class="flex items-start gap-3">
      <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl border border-app-success/20 bg-app-success/10 text-app-success">
        {% include 'components/icon.twig' with { name: 'server', class: 'h-5 w-5' } only %}
      </span>
      <div class="space-y-1">
        <p class="dashboard-widget-label text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-app-muted">{{ card.label|default('Application') }}</p>
        <div class="dashboard-widget-value text-2xl font-semibold tracking-tight text-app-text">{{ card.value|default('MarwaPHP') }}</div>
        {% if card.meta|default('') is not empty %}
          <p class="text-sm text-app-muted">{{ card.meta|default('') }}</p>
        {% endif %}
      </div>
    </div>
    <span class="dashboard-widget-status inline-flex items-center rounded-lg border border-app-success/20 bg-app-success/10 px-2.5 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-app-success">
      {{ card.status|default('Active') }}
    </span>
  </div>
</div>
