{% extends '@auth/admin/layout.twig' %}

{% block admin_body %}
  <section class="panel">
    <table class="table">
      <thead>
        <tr>
          <th>User</th>
          <th>Email</th>
          <th>Status</th>
          <th>Roles</th>
        </tr>
      </thead>
      <tbody>
        {% for user in users %}
          <tr>
            <td>{{ user.getAttribute('name') }}</td>
            <td>{{ user.getAttribute('email') }}</td>
            <td>{{ user.getAttribute('status') ? 'Active' : 'Inactive' }}</td>
            <td>
              {% for role in user.getRelation('roles')|default([]) %}
                <span class="chip">{{ role.getAttribute('name') }}</span>
              {% else %}
                <span class="muted">None</span>
              {% endfor %}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>
{% endblock %}
