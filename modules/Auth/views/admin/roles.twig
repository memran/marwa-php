{% extends '@auth/admin/layout.twig' %}

{% block body %}
  <section class="panel">
    <p class="eyebrow">Access control</p>
    <h2 class="mt-2 text-2xl font-bold text-slate-950">Roles</h2>
    <p class="mt-2 text-sm leading-7 text-slate-600">
      Seeded roles provide a ready-made foundation for user permissions and policy checks.
    </p>
  </section>

  <section class="stats-grid">
    {% for role in roles %}
      <article class="stat-card">
        <span>{{ role.getAttribute('slug') }}</span>
        <strong>{{ role.getAttribute('name') }}</strong>
        <p>{{ role.getAttribute('description')|default('Starter role') }}</p>
      </article>
    {% else %}
      <article class="panel">
        <p class="muted">No roles have been seeded yet.</p>
      </article>
    {% endfor %}
  </section>
{% endblock %}
