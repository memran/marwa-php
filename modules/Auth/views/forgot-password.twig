{% extends '@auth/layout.twig' %}

{% block title %}Reset password{% endblock %}

{% block body %}
  <div class="card-heading">
    <p class="eyebrow">Password recovery</p>
    <h2>Send a reset link</h2>
    <p>The scaffold can mail a reset link when mail is configured, or reveal it locally for development.</p>
  </div>

  <form method="post" action="/auth/forgot-password" class="stack">
    <input type="hidden" name="_token" value="{{ csrf|default('') }}">

    <label class="field">
      <span>Email</span>
      <input type="email" name="email" value="{{ old('email')|default('') }}" autocomplete="email" required>
    </label>

    <div class="actions">
      <button type="submit" class="button button--primary">Send reset link</button>
      <a href="/auth/login" class="button button--ghost">Back to sign in</a>
    </div>
  </form>
{% endblock %}
