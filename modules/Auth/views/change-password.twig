{% extends '@auth/layout.twig' %}

{% block title %}Change password{% endblock %}

{% block body %}
  <div class="card-heading">
    <p class="eyebrow">Security</p>
    <h2>Change your password</h2>
    <p>Authenticated users can update their password from the admin starter.</p>
  </div>

  <form method="post" action="/admin/password/change" class="stack">
    <input type="hidden" name="_token" value="{{ csrf|default('') }}">

    <label class="field">
      <span>Current password</span>
      <input type="password" name="current_password" autocomplete="current-password" required>
    </label>

    <label class="field">
      <span>New password</span>
      <input type="password" name="password" autocomplete="new-password" required>
    </label>

    <label class="field">
      <span>Confirm password</span>
      <input type="password" name="password_confirmation" autocomplete="new-password" required>
    </label>

    <div class="actions">
      <button type="submit" class="button button--primary">Save password</button>
      <a href="/admin" class="button button--ghost">Back to dashboard</a>
    </div>
  </form>
{% endblock %}
