{% extends '@auth/layout.twig' %}

{% block title %}Reset password{% endblock %}

{% block body %}
  <div class="card-heading">
    <p class="eyebrow">Choose a new password</p>
    <h2>Reset your password</h2>
    <p>Use the token from the reset email or the local scaffold link.</p>
  </div>

  <form method="post" action="/auth/reset-password" class="stack">
    <input type="hidden" name="_token" value="{{ csrf|default('') }}">
    <input type="hidden" name="token" value="{{ token|default('') }}">

    <label class="field">
      <span>Email</span>
      <input type="email" name="email" value="{{ email|default(old('email')) }}" autocomplete="email" required>
    </label>

    <label class="field">
      <span>New password</span>
      <input type="password" name="password" autocomplete="new-password" required>
    </label>

    <label class="field">
      <span>Confirm password</span>
      <input type="password" name="password_confirmation" autocomplete="new-password" required>
    </label>

    <div class="actions">
      <button type="submit" class="button button--primary">Update password</button>
      <a href="/auth/login" class="button button--ghost">Back to sign in</a>
    </div>
  </form>
{% endblock %}
