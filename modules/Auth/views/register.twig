{% extends '@auth/layout.twig' %}

{% block title %}Create account{% endblock %}

{% block body %}
  <div class="card-heading">
    <p class="eyebrow">Join the platform</p>
    <h2>Create your account</h2>
    <p>Registration is ready out of the box and assigns the default starter role.</p>
  </div>

  <form method="post" action="/auth/register" class="stack">
    <input type="hidden" name="_token" value="{{ csrf|default('') }}">

    <label class="field">
      <span>Name</span>
      <input type="text" name="name" value="{{ old('name')|default('') }}" autocomplete="name" required>
    </label>

    <label class="field">
      <span>Email</span>
      <input type="email" name="email" value="{{ old('email')|default('') }}" autocomplete="email" required>
    </label>

    <label class="field">
      <span>Password</span>
      <input type="password" name="password" autocomplete="new-password" required>
    </label>

    <label class="field">
      <span>Confirm password</span>
      <input type="password" name="password_confirmation" autocomplete="new-password" required>
    </label>

    <div class="actions">
      <button type="submit" class="button button--primary">Create account</button>
      <a href="/auth/login" class="button button--ghost">Back to sign in</a>
    </div>
  </form>
{% endblock %}
