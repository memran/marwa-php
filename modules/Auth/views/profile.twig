{% extends '@auth/admin/layout.twig' %}

{% block title %}Your profile{% endblock %}

{% block body %}
  <section class="stats-grid">
    <article class="panel">
      <p class="eyebrow">Profile</p>
      <h2 class="mt-2 text-2xl font-bold text-slate-950">{{ user.getAttribute('name') }}</h2>
      <p class="mt-2 text-sm leading-7 text-slate-600">{{ user.getAttribute('email') }}</p>
    </article>

    <article class="panel">
      <p class="eyebrow">Account security</p>
      <h2 class="mt-2 text-2xl font-bold text-slate-950">Remembered access</h2>
      <p class="mt-2 text-sm leading-7 text-slate-600">
        Keep your session aligned with the starter auth module and rotate passwords when needed.
      </p>
    </article>
  </section>

  <section class="panel">
    <p class="eyebrow">Roles</p>
    <div class="chip-list mt-4">
      {% for role in roles %}
        <span class="chip">{{ role.getAttribute('name') }}</span>
      {% else %}
        <span class="muted">No roles assigned yet.</span>
      {% endfor %}
    </div>
  </section>

  <div class="actions">
    <a href="/admin/password/change" class="button button--primary">Change password</a>
    <form method="post" action="/admin/logout">
      <input type="hidden" name="_token" value="{{ csrf|default('') }}">
      <button type="submit" class="button button--ghost">Logout</button>
    </form>
  </div>
{% endblock %}
