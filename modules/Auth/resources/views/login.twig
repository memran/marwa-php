{% extends "layouts/auth.twig" %}

{% block title %}Sign in | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-full border px-5 py-3 text-sm font-semibold transition hover:-translate-y-0.5' %}
  {% set button_primary = button_base ~ ' w-full border-transparent bg-app-accent text-white hover:bg-app-accent-soft' %}

  <div class="space-y-3">
    <span class="inline-flex w-fit items-center rounded-full border border-app-accent/20 bg-app-accent/10 px-4 py-1.5 text-[0.7rem] font-extrabold uppercase tracking-[0.22em] text-app-accent">Secure login</span>
    <h2 class="text-2xl font-bold tracking-tight text-app-text sm:text-3xl">Sign in to continue.</h2>
    <p class="text-sm leading-6 text-app-muted">Enter your credentials to access the admin console.</p>
  </div>

  {% if _security_two_factor_enabled is defined and _security_two_factor_enabled %}
    <div class="mt-5 rounded-2xl border border-app-accent/20 bg-app-accent/10 p-4 text-app-accent">
      <p class="text-sm font-semibold">Two-factor authentication</p>
      <p class="mt-1 text-sm text-app-accent">2FA is enabled for the application settings.</p>
    </div>
  {% endif %}

  {% if notice is defined and notice %}
    <div class="mt-5 rounded-2xl border border-app-success/20 bg-app-success/10 p-4 text-app-success">
      <p class="text-sm font-semibold">Session update</p>
      <p class="mt-1 text-sm text-app-success">{{ notice }}</p>
    </div>
  {% endif %}

  {% if errors is defined and errors.email is defined %}
    <div class="mt-5 rounded-2xl border border-app-danger/20 bg-app-danger/10 p-4 text-app-danger">
      <p class="text-sm font-semibold">Unable to sign in</p>
      <p class="mt-1 text-sm text-app-danger">{{ errors.email|first }}</p>
    </div>
  {% endif %}

  <form class="mt-6 grid gap-5" method="post" action="/admin/login">
    {{ csrf_field() }}

    {% include "components/form-field.twig" with {
      id: 'email',
      label: 'Email address',
      type: 'email',
      autocomplete: 'email',
      placeholder: 'admin@marwa.test',
      value: old.email|default(''),
      error: errors.email|default([])|first
    } only %}

    {% include "components/form-field.twig" with {
      id: 'password',
      label: 'Password',
      type: 'password',
      autocomplete: 'current-password',
      placeholder: 'Enter your password',
      error: errors.password|default([])|first
    } only %}

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <label class="inline-flex items-center gap-3 text-sm text-app-muted">
        <input type="checkbox" name="remember" value="1" class="form-checkbox h-4 w-4 rounded border-app-border bg-app-surface text-app-accent focus:ring-app-accent/20" {% if old.remember|default(false) %}checked{% endif %}>
        <span>Remember me</span>
      </label>
      <a class="text-sm font-semibold text-app-accent transition hover:text-app-accent-soft" href="/admin/forgot-password">Forgot password?</a>
    </div>

    <button class="{{ button_primary }}" type="submit">Sign in</button>
  </form>
{% endblock %}
