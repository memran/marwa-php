{% extends "@auth/layout.twig" %}

{% block title %}Set new password | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-full border px-5 py-3 text-sm font-semibold transition hover:-translate-y-0.5' %}
  {% set button_primary = button_base ~ ' w-full border-transparent bg-white text-slate-950 hover:bg-cyan-200' %}

  <div class="space-y-3">
    <span class="inline-flex w-fit items-center rounded-full border border-cyan-300/20 bg-cyan-400/10 px-4 py-1.5 text-[0.7rem] font-extrabold uppercase tracking-[0.22em] text-cyan-100">Password reset</span>
    <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl">Set a new password.</h2>
    <p class="text-sm leading-6 text-slate-300">Use the recovery token to restore access and create a fresh session.</p>
  </div>

  {% if errors is defined and errors.token is defined %}
    <div class="mt-5 rounded-2xl border border-rose-400/20 bg-rose-500/10 p-4 text-rose-100">
      <p class="text-sm font-semibold">Invalid recovery token</p>
      <p class="mt-1 text-sm text-rose-100/80">{{ errors.token|first }}</p>
    </div>
  {% endif %}

  <form class="mt-6 grid gap-5" method="post" action="/admin/reset-password/{{ token }}">
    {% include "components/form-field.twig" with {
      id: 'token',
      label: 'Recovery token',
      value: token,
      disabled: true,
      hint: 'This token is bound to a single reset request.',
      error: errors.token|default([])|first
    } only %}

    {% include "components/form-field.twig" with {
      id: 'password',
      label: 'New password',
      type: 'password',
      autocomplete: 'new-password',
      placeholder: 'Choose a secure password',
      error: errors.password|default([])|first
    } only %}

    {% include "components/form-field.twig" with {
      id: 'password_confirmation',
      name: 'password_confirmation',
      label: 'Confirm password',
      type: 'password',
      autocomplete: 'new-password',
      placeholder: 'Repeat the new password'
    } only %}

    <button class="{{ button_primary }}" type="submit">Update password</button>
    <a class="text-sm font-semibold text-slate-300 transition hover:text-white" href="/admin/login">Back to sign in</a>
  </form>
{% endblock %}
