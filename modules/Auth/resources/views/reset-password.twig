{% extends "@auth/layout.twig" %}

{% block title %}Set new password | MarwaPHP Admin{% endblock %}

{% block content %}
  <div class="admin-auth-panel__header">
    <span class="admin-eyebrow">Password reset</span>
    <h2 class="admin-auth-panel__title">Set a new password.</h2>
    <p class="admin-auth-panel__body">Use the recovery token to restore access and create a fresh session.</p>
  </div>

  {% if errors is defined and errors.token is defined %}
    <div class="admin-alert admin-alert--danger">
      <p class="admin-alert__title">Invalid recovery token</p>
      <p class="admin-alert__body">{{ errors.token|first }}</p>
    </div>
  {% endif %}

  <form class="admin-auth-form" method="post" action="/admin/reset-password/{{ token }}">
    {% include "components/form-field.twig" with {
      id: 'token',
      label: 'Recovery token',
      value: token,
      disabled: true,
      hint: 'This token is bound to a single reset request.',
      error: errors.token|default([])|first
    } only %}

    {% include "components/form-field.twig" with {
      id: 'password',
      label: 'New password',
      type: 'password',
      autocomplete: 'new-password',
      placeholder: 'Choose a secure password',
      error: errors.password|default([])|first
    } only %}

    {% include "components/form-field.twig" with {
      id: 'password_confirmation',
      name: 'password_confirmation',
      label: 'Confirm password',
      type: 'password',
      autocomplete: 'new-password',
      placeholder: 'Repeat the new password'
    } only %}

    <button class="admin-btn admin-btn--primary admin-btn--full" type="submit">Update password</button>
    <a class="admin-link admin-link--muted" href="/admin/login">Back to sign in</a>
  </form>
{% endblock %}
