{% extends "@auth/layout.twig" %}

{% block title %}Reset password | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-full border px-5 py-3 text-sm font-semibold transition hover:-translate-y-0.5' %}
  {% set button_primary = button_base ~ ' w-full border-slate-900/10 bg-slate-900 text-white hover:bg-slate-800 dark:border-white/10 dark:bg-white dark:text-slate-950 dark:hover:bg-cyan-200' %}

  <div class="space-y-3">
    <span class="inline-flex w-fit items-center rounded-full border border-cyan-200 bg-cyan-50 px-4 py-1.5 text-[0.7rem] font-extrabold uppercase tracking-[0.22em] text-cyan-700 dark:border-cyan-300/20 dark:bg-cyan-400/10 dark:text-cyan-100">Account recovery</span>
    <h2 class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl dark:text-white">Request a recovery link.</h2>
    <p class="text-sm leading-6 text-slate-600 dark:text-slate-300">Generate a short-lived reset link for the matching admin account.</p>
  </div>

{% if notice is defined and notice %}
    <div class="mt-5 rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-emerald-800 dark:border-emerald-400/20 dark:bg-emerald-400/10 dark:text-emerald-100">
      <p class="text-sm font-semibold">Recovery link sent</p>
      <p class="mt-1 text-sm text-emerald-700/80 dark:text-emerald-100/80">{{ notice }}</p>
    </div>
  {% endif %}

  {% if errors is defined and errors.email is defined %}
    <div class="mt-5 rounded-2xl border border-rose-200 bg-rose-50 p-4 text-rose-800 dark:border-rose-400/20 dark:bg-rose-500/10 dark:text-rose-100">
      <p class="text-sm font-semibold">Unable to generate link</p>
      <p class="mt-1 text-sm text-rose-700/80 dark:text-rose-100/80">{{ errors.email|first }}</p>
    </div>
  {% endif %}

  <form class="mt-6 grid gap-5" method="post" action="/admin/forgot-password">
    {{ csrf_field() }}

    {% include "components/form-field.twig" with {
      id: 'email',
      label: 'Email address',
      type: 'email',
      autocomplete: 'email',
      placeholder: 'admin@marwa.test',
      value: old.email|default(''),
      error: errors.email|default([])|first,
      hint: 'The matching account receives a time-limited reset link.'
    } only %}

    <button class="{{ button_primary }}" type="submit">Send recovery link</button>
    <a class="text-sm font-semibold text-slate-600 transition hover:text-slate-900 dark:text-slate-300 dark:hover:text-white" href="/admin/login">Back to sign in</a>
  </form>
{% endblock %}
