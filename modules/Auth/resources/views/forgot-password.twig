{% extends "@auth/layout.twig" %}

{% block title %}Reset password | MarwaPHP Admin{% endblock %}

{% block content %}
  <div class="admin-auth-panel__header">
    <span class="admin-eyebrow">Account recovery</span>
    <h2 class="admin-auth-panel__title">Request a recovery link.</h2>
    <p class="admin-auth-panel__body">Generate a short-lived reset link for the matching admin account.</p>
  </div>

  {% if notice is defined and notice %}
    <div class="admin-alert admin-alert--success">
      <p class="admin-alert__title">Recovery link created</p>
      <p class="admin-alert__body">{{ notice }}</p>
    </div>
  {% endif %}

  {% if recovery_link is defined and recovery_link %}
    <div class="admin-alert admin-alert--info">
      <p class="admin-alert__title">Reset link</p>
      <p class="admin-alert__body">
        <a class="admin-link" href="{{ recovery_link }}">{{ recovery_link }}</a>
      </p>
    </div>
  {% endif %}

  {% if errors is defined and errors.email is defined %}
    <div class="admin-alert admin-alert--danger">
      <p class="admin-alert__title">Unable to generate link</p>
      <p class="admin-alert__body">{{ errors.email|first }}</p>
    </div>
  {% endif %}

  <form class="admin-auth-form" method="post" action="/admin/forgot-password">
    {% include "components/form-field.twig" with {
      id: 'email',
      label: 'Email address',
      type: 'email',
      autocomplete: 'email',
      placeholder: 'admin@marwa.test',
      value: old.email|default(''),
      error: errors.email|default([])|first,
      hint: 'The matching account receives a time-limited reset link.'
    } only %}

    <button class="admin-btn admin-btn--primary admin-btn--full" type="submit">Send recovery link</button>
    <a class="admin-link admin-link--muted" href="/admin/login">Back to sign in</a>
  </form>
{% endblock %}
