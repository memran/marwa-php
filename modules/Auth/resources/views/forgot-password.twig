{% extends "layouts/auth.twig" %}

{% block title %}Reset password | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-full border px-5 py-3 text-sm font-semibold transition hover:-translate-y-0.5' %}
  {% set button_primary = button_base ~ ' w-full border-transparent bg-app-accent text-white hover:bg-app-accent-soft' %}

  <div class="space-y-3">
    <span class="inline-flex w-fit items-center rounded-full border border-app-accent/20 bg-app-accent/10 px-4 py-1.5 text-[0.7rem] font-extrabold uppercase tracking-[0.22em] text-app-accent">Account recovery</span>
    <h2 class="text-2xl font-bold tracking-tight text-app-text sm:text-3xl">Request a recovery link.</h2>
    <p class="text-sm leading-6 text-app-muted">Generate a short-lived reset link for the matching admin account.</p>
  </div>

{% if notice is defined and notice %}
    <div class="mt-5 rounded-2xl border border-app-success/20 bg-app-success/10 p-4 text-app-success">
      <p class="text-sm font-semibold">Recovery link sent</p>
      <p class="mt-1 text-sm text-app-success">{{ notice }}</p>
    </div>
  {% endif %}

  {% if errors is defined and errors.email is defined %}
    <div class="mt-5 rounded-2xl border border-app-danger/20 bg-app-danger/10 p-4 text-app-danger">
      <p class="text-sm font-semibold">Unable to generate link</p>
      <p class="mt-1 text-sm text-app-danger">{{ errors.email|first }}</p>
    </div>
  {% endif %}

  <form class="mt-6 grid gap-5" method="post" action="/admin/forgot-password">
    {{ csrf_field() }}

    {% include "components/form-field.twig" with {
      id: 'email',
      label: 'Email address',
      type: 'email',
      autocomplete: 'email',
      placeholder: 'admin@marwa.test',
      value: old.email|default(''),
      error: errors.email|default([])|first,
      hint: 'The matching account receives a time-limited reset link.'
    } only %}

    <button class="{{ button_primary }}" type="submit">Send recovery link</button>
    <a class="text-sm font-semibold text-app-muted transition hover:text-app-text" href="/admin/login">Back to sign in</a>
  </form>
{% endblock %}
