{% extends "layout.twig" %}

{% block title %}Background Job{% endblock %}

{% block content %}
{% set job = job ?? {} %}
<div class="space-y-6">
    <section class="rounded-3xl border border-slate-200 bg-white px-6 py-5 shadow-sm ring-1 ring-slate-100 dark:border-slate-800 dark:bg-slate-900/60 dark:ring-white/5">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="space-y-2">
                <p class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500 dark:text-slate-400">Background Job</p>
                <h1 class="text-2xl font-semibold text-slate-900 dark:text-white">{{ job.title ?? job.name ?? 'Task' }}</h1>
                <p class="max-w-3xl text-sm text-slate-600 dark:text-slate-400">{{ job.description ?: 'No description available.' }}</p>
                <p class="text-xs uppercase tracking-[0.25em] text-slate-500 dark:text-slate-400">Database scheduler backed</p>
            </div>
            <div class="flex flex-wrap gap-3">
                <form method="post" action="/admin/background-jobs/{{ job.route_id|url_encode }}/run">
                    {{ csrf_field() }}
                    <button type="submit" class="inline-flex items-center rounded-xl bg-slate-950 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200">
                        Run Now
                    </button>
                </form>
                <a href="/admin/background-jobs" class="inline-flex items-center rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800">
                    Back
                </a>
            </div>
        </div>
        {% if notice %}
            <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 dark:border-slate-800 dark:bg-slate-950/60 dark:text-slate-300">
                {{ notice }}
            </div>
        {% endif %}
    </section>

    <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
            <div class="text-xs uppercase tracking-[0.25em] text-slate-500 dark:text-slate-400">Status</div>
            <div class="mt-2 inline-flex rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] ring-1 {{ job.status_class }}">{{ job.status }}</div>
            <div class="mt-2 inline-flex rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.2em] ring-1 {{ job.result_class }}">{{ job.result_label }}</div>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
            <div class="text-xs uppercase tracking-[0.25em] text-slate-500 dark:text-slate-400">Schedule</div>
            <div class="mt-2 text-base font-semibold text-slate-900 dark:text-white">{{ job.schedule }}</div>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
            <div class="text-xs uppercase tracking-[0.25em] text-slate-500 dark:text-slate-400">Last Updated</div>
            <div class="mt-2 text-base font-semibold text-slate-900 dark:text-white">{{ job.updated_at ?: 'Never' }}</div>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
            <div class="text-xs uppercase tracking-[0.25em] text-slate-500 dark:text-slate-400">Backend</div>
            <div class="mt-2 text-base font-semibold text-slate-900 dark:text-white">{{ job.type }}</div>
        </div>
    </section>

    <section class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
        <div class="border-b border-slate-200 px-6 py-4 dark:border-slate-800">
            <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Latest log</h2>
        </div>
        <div class="px-6 py-5 text-sm text-slate-600 dark:text-slate-300">
            {% if job.last_message %}
                <div class="rounded-2xl bg-slate-50 px-4 py-4 dark:bg-slate-950/60">
                    {{ job.last_message }}
                </div>
            {% else %}
                <p>No logs yet.</p>
            {% endif %}
        </div>
    </section>
</div>
{% endblock %}
