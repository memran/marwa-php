{% extends "layouts/admin.twig" %}

{% block title %}Background Job{% endblock %}

{% block content %}
{% set job = job ?? {} %}
<div class="space-y-6">
    <section class="rounded-3xl border border-app-border bg-app-surface px-6 py-5 shadow-sm">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="space-y-2">
                <p class="text-xs font-semibold uppercase tracking-[0.3em] text-app-muted">Background Job</p>
                <h1 class="text-2xl font-semibold text-app-text">{{ job.title ?? job.name ?? 'Task' }}</h1>
                <p class="max-w-3xl text-sm text-app-muted">{{ job.description ?: 'No description available.' }}</p>
                <p class="text-xs uppercase tracking-[0.25em] text-app-muted">Framework scheduler backed</p>
            </div>
            <div class="flex flex-wrap gap-3">
                <form method="post" action="/admin/background-jobs/{{ job.route_id }}/run">
                    {{ csrf_field() }}
                    <button type="submit" class="inline-flex items-center rounded-xl bg-app-accent px-4 py-2 text-sm font-semibold text-white transition hover:bg-app-accent-soft">
                        Run Now
                    </button>
                </form>
                <a href="/admin/background-jobs" class="inline-flex items-center rounded-xl border border-app-border px-4 py-2 text-sm font-semibold text-app-text transition hover:bg-app-surface-2/70">
                    Back
                </a>
            </div>
        </div>
    </section>

    <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-2xl border border-app-border bg-app-surface p-4 shadow-sm">
            <div class="text-xs uppercase tracking-[0.25em] text-app-muted">Status</div>
            <div class="mt-2 inline-flex rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] ring-1 {{ job.status_class }}">{{ job.status }}</div>
            <div class="mt-2 inline-flex rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.2em] ring-1 {{ job.result_class }}">{{ job.result_label }}</div>
        </div>
        <div class="rounded-2xl border border-app-border bg-app-surface p-4 shadow-sm">
            <div class="text-xs uppercase tracking-[0.25em] text-app-muted">Schedule</div>
            <div class="mt-2 text-base font-semibold text-app-text">{{ job.schedule }}</div>
        </div>
        <div class="rounded-2xl border border-app-border bg-app-surface p-4 shadow-sm">
            <div class="text-xs uppercase tracking-[0.25em] text-app-muted">Last Updated</div>
            <div class="mt-2 text-base font-semibold text-app-text">{{ job.updated_at ?: 'Never' }}</div>
        </div>
        <div class="rounded-2xl border border-app-border bg-app-surface p-4 shadow-sm">
            <div class="text-xs uppercase tracking-[0.25em] text-app-muted">Backend</div>
            <div class="mt-2 text-base font-semibold text-app-text">Framework scheduler</div>
        </div>
    </section>

    <section class="overflow-hidden rounded-3xl border border-app-border bg-app-surface shadow-sm">
        <div class="border-b border-app-border px-6 py-4">
            <h2 class="text-lg font-semibold text-app-text">Latest log</h2>
        </div>
        <div class="px-6 py-5 text-sm text-app-muted">
            {% if job.last_message %}
                <div class="rounded-2xl bg-app-surface-2/70 px-4 py-4 text-app-text">
                    {{ job.last_message }}
                </div>
            {% else %}
                <p>No logs yet.</p>
            {% endif %}
        </div>
    </section>
</div>
{% endblock %}
