{% set card = card|default({}) %}
{% set metricBars = card.metric_bars|default([]) %}
{% set status = card.status|default('Active') %}
{% set value = card.value|default('MarwaPHP') %}
{% set meta = card.meta|default('Production') %}
{% set metricWidth = card.metric_width|default('82%') %}

<div class="space-y-4">
  <div class="h-1.5 rounded-full bg-gradient-to-r from-cyan-300 via-emerald-300 to-cyan-300"></div>
  <div class="flex items-start justify-between gap-3">
    <div class="flex items-start gap-3">
      <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl border border-emerald-400/20 bg-emerald-400/10 text-emerald-100">
        {% include 'components/icon.twig' with { name: 'server', class: 'h-5 w-5' } only %}
      </span>
      <div class="space-y-1">
        <p class="text-[0.65rem] font-extrabold uppercase tracking-[0.18em] text-emerald-100/75">{{ card.label|default('Application') }}</p>
        <div class="text-2xl font-black tracking-tight text-white">{{ value }}</div>
      </div>
    </div>
    <span class="inline-flex items-center rounded-full border border-emerald-400/20 bg-emerald-400/10 px-2.5 py-1 text-[0.68rem] font-bold uppercase tracking-[0.14em] text-emerald-200">
      {{ status }}
    </span>
  </div>
  <div class="flex items-center justify-between gap-3 rounded-2xl border border-emerald-400/10 bg-emerald-400/5 px-3 py-2">
    <div class="flex items-center gap-2 text-xs text-slate-300">
      <span class="h-2 w-2 rounded-full bg-emerald-300"></span>
      <span>{{ meta }}</span>
    </div>
    <span class="text-[0.65rem] font-bold uppercase tracking-[0.18em] text-emerald-200/80">Live</span>
  </div>
  <div class="space-y-2">
    <div class="h-2 overflow-hidden rounded-full bg-white/10">
      <span class="block h-full rounded-full bg-gradient-to-r from-emerald-300 via-cyan-300 to-emerald-300" style="width: {{ metricWidth }};"></span>
    </div>
    <div class="flex flex-col gap-1">
      {% for bar in metricBars %}
        <div class="h-1.5 overflow-hidden rounded-full bg-white/10">
          <span class="block h-full rounded-full bg-emerald-300/80" style="width: {{ bar }};"></span>
        </div>
      {% else %}
        <div class="h-1.5 overflow-hidden rounded-full bg-white/10">
          <span class="block h-full w-full rounded-full bg-emerald-300/80"></span>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
