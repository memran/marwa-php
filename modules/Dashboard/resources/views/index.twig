{% extends "layout.twig" %}

{% block title %}Dashboard{% endblock %}

{% block content %}
<div 
  x-data="dashboardWidget()" 
  x-init="init()"
  data-widgets='{{ widgets|json_encode|escape }}'
  data-available='{{ available_widgets|json_encode|escape }}'
  data-sizes='{{ size_options|json_encode|escape }}'
>
  <div class="transition-[padding-right] duration-200" :class="editMode ? 'lg:pr-80' : ''">
    <div class="flex flex-col gap-4 mb-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-3xl space-y-2">
        <span class="inline-flex w-fit items-center rounded-full border border-cyan-300/20 bg-cyan-400/10 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.16em] text-cyan-100">
          Design workspace
        </span>
        <h1 class="text-2xl font-bold text-white sm:text-3xl">Dashboard</h1>
        <p class="mt-1 mb-4 text-sm text-slate-400">Welcome back! Here's your overview.</p>
      </div>
      <div class="flex items-center gap-2">
        <button 
          x-show="!editMode"
          @click="toggleEditMode()"
          class="inline-flex items-center gap-2 rounded-xl border border-cyan-400/20 bg-cyan-500/10 px-4 py-2 text-sm font-semibold text-cyan-100 transition hover:bg-cyan-500/20"
        >
          {% include 'components/icon.twig' with { name: 'palette', class: 'h-4 w-4' } only %}
          <span>Edit Dashboard</span>
        </button>
        <button 
          x-show="editMode"
          @click="toggleEditMode()"
          class="dashboard-edit-done inline-flex items-center gap-2 rounded-xl border border-slate-600 bg-slate-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-600"
        >
          {% include 'components/icon.twig' with { name: 'x', class: 'h-4 w-4' } only %}
          <span>Done</span>
        </button>
      </div>
    </div>

    <div 
      x-ref="widgetGrid"
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mt-4"
      @dragover.prevent
      @drop.prevent="dropOnGrid()"
    >
    {% for widget in widgets %}
      {% if widget.enabled %}
      <div 
        class="widget-item dashboard-widget relative overflow-hidden rounded-[1.4rem] border border-white/10 bg-white/5 p-5 shadow-[0_24px_70px_rgba(2,6,23,0.35)] backdrop-blur-xl transition duration-200 hover:-translate-y-0.5 hover:border-cyan-300/20 hover:bg-white/[0.07]"
        :class="[getWidthClass('{{ widget.width }}'), draggedWidgetId === '{{ widget.widget_id }}' ? 'opacity-50 ring-2 ring-cyan-300/40' : '']"
        data-widget-id="{{ widget.widget_id }}"
        data-position="{{ widget.position }}"
        :draggable="editMode"
        @dragstart="startDrag('{{ widget.widget_id }}')"
        @dragend="endDrag()"
        @dragover.prevent
        @drop.prevent="dropOnWidget('{{ widget.widget_id }}')"
      >
        <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cyan-300/30 to-transparent"></div>
        <div class="pointer-events-none absolute -right-8 -top-8 h-24 w-24 rounded-full bg-cyan-400/10 blur-3xl"></div>
        <div class="pointer-events-none absolute -bottom-12 -left-12 h-28 w-28 rounded-full bg-emerald-400/10 blur-3xl"></div>

        <div x-show="editMode" class="absolute top-3 right-3 flex items-center gap-1 z-10">
          <div class="drag-handle cursor-grab p-1.5 text-slate-400 hover:text-white rounded hover:bg-white/10" title="Drag to reorder">
            {% include 'components/icon.twig' with { name: 'grip-vertical', class: 'h-4 w-4' } only %}
          </div>
          <button 
            @click="removeWidget('{{ widget.widget_id }}')" 
            class="p-1.5 text-rose-400 hover:text-rose-300 rounded hover:bg-rose-500/20"
          >
            {% include 'components/icon.twig' with { name: 'trash-2', class: 'h-4 w-4' } only %}
          </button>
          <button 
            @click="refreshWidget('{{ widget.widget_id }}')" 
            class="p-1.5 text-slate-400 hover:text-white rounded hover:bg-white/10"
            title="Refresh widget"
          >
            {% include 'components/icon.twig' with { name: 'refresh-cw', class: 'h-3 w-3' } only %}
          </button>
        </div>

        <div class="flex items-start justify-between gap-3">
          <div class="space-y-1">
            <p class="dashboard-widget-kicker text-[0.65rem] font-extrabold uppercase tracking-[0.18em] text-cyan-100/70">Widget</p>
            <h3 class="text-sm font-semibold text-white">{{ widget.title }}</h3>
          </div>
          <button 
            x-show="!editMode"
            @click="refreshWidget('{{ widget.widget_id }}')" 
            class="rounded-lg border border-white/10 bg-white/5 p-1.5 text-slate-400 transition hover:border-cyan-300/20 hover:bg-cyan-400/10 hover:text-white"
            title="Refresh widget"
          >
            {% include 'components/icon.twig' with { name: 'refresh-cw', class: 'h-3 w-3' } only %}
          </button>
        </div>

        <div class="widget-content mt-4 rounded-[1rem] border border-white/10 bg-slate-950/20 p-4">
          {{ widget.content|raw }}
        </div>
      </div>
      {% endif %}
    {% endfor %}
    </div>
  </div>

  <div 
    x-show="editMode"
    x-cloak
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 z-40 bg-black/60 backdrop-blur-sm lg:hidden"
    @click="toggleEditMode()"
  ></div>

  <div 
    x-show="editMode"
    x-cloak
    class="fixed right-0 top-0 h-full w-80 max-w-full border-l border-slate-200 bg-white/95 p-4 overflow-y-auto z-50 backdrop-blur-xl shadow-2xl dark:border-white/10 dark:bg-slate-950/95"
  >
    <div class="flex items-center justify-between mb-4 pb-4 border-b border-slate-200 dark:border-white/10">
      <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Add Widgets</h3>
      <button @click="toggleEditMode()" class="rounded-lg border border-slate-200 bg-slate-50 p-1.5 text-slate-500 transition hover:border-cyan-300/20 hover:bg-white hover:text-slate-900 dark:border-white/10 dark:bg-white/5 dark:text-slate-400 dark:hover:border-cyan-300/20 dark:hover:bg-white/10 dark:hover:text-white">
        {% include 'components/icon.twig' with { name: 'x', class: 'h-5 w-5' } only %}
      </button>
    </div>

    <div class="space-y-2 mb-6">
      <template x-for="widget in availableWidgets" :key="widget.id">
        <div 
          class="rounded-xl border border-slate-200 bg-slate-50/90 p-4 cursor-pointer transition hover:border-cyan-300/30 hover:bg-cyan-50/70 dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
          @click="addWidget(widget.id)"
        >
          <div class="flex items-start justify-between gap-3">
            <div class="space-y-1">
              <span class="block text-sm font-medium text-slate-700 dark:text-slate-200" x-text="widget.name"></span>
              <span class="text-xs text-slate-500 dark:text-slate-500" x-text="widget.size"></span>
            </div>
            <button
              type="button"
              class="inline-flex shrink-0 items-center rounded-lg border border-cyan-300/30 bg-cyan-500/10 px-2.5 py-1 text-xs font-semibold text-cyan-700 transition hover:bg-cyan-500/20 dark:text-cyan-100"
              @click.stop="addWidget(widget.id)"
            >
              Add
            </button>
          </div>
          <p class="mt-1 text-xs text-slate-500 dark:text-slate-400" x-text="widget.description"></p>
        </div>
      </template>
    </div>

    <div class="mt-6 space-y-2 border-t border-slate-200 pt-6 dark:border-white/10">
      <button 
        @click="toggleEditMode()"
        class="w-full inline-flex items-center justify-center gap-2 rounded-xl border border-slate-300/40 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-cyan-300/30 hover:bg-cyan-50 hover:text-slate-900 dark:border-slate-300/20 dark:bg-white/5 dark:text-slate-100 dark:hover:bg-white/10"
      >
        {% include 'components/icon.twig' with { name: 'layout-dashboard', class: 'h-4 w-4' } only %}
        Back to normal mode
      </button>
      <button 
        @click="saveWidgets()"
        class="w-full inline-flex items-center justify-center gap-2 rounded-xl border border-cyan-400/20 bg-cyan-500/10 px-4 py-2.5 text-sm font-semibold text-cyan-700 transition hover:bg-cyan-500/20 dark:text-cyan-100"
      >
        {% include 'components/icon.twig' with { name: 'save', class: 'h-4 w-4' } only %}
        Save Changes
      </button>
      <button 
        @click="resetDashboard()"
        class="w-full inline-flex items-center justify-center gap-2 rounded-xl border border-rose-400/20 bg-rose-500/10 px-4 py-2.5 text-sm font-semibold text-rose-700 transition hover:bg-rose-500/20 dark:text-rose-100"
      >
        {% include 'components/icon.twig' with { name: 'refresh-cw', class: 'h-3 w-3' } only %}
        Reset to Default
      </button>
    </div>
  </div>
</div>

<style>
.dashboard-widget {
  min-height: 160px;
}
</style>
{% endblock %}
