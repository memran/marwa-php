{% extends "layouts/admin.twig" %}

{% block title %}Settings | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-xl border px-3.5 py-2 text-[0.82rem] font-semibold transition' %}
  {% set button_primary = button_base ~ ' border-transparent bg-app-accent text-white hover:bg-app-accent-soft' %}
  {% set button_secondary = button_base ~ ' border-app-border bg-app-surface/80 text-app-text hover:bg-app-surface-2/70' %}
  {% set form_card_shell = 'mt-8 w-full overflow-hidden rounded-[1.75rem] border border-app-border bg-app-surface/80 p-4 shadow-[0_30px_80px_rgba(2,6,23,0.45)] backdrop-blur-xl sm:p-5' %}
  {% set tab_items = [] %}

  {% for category, meta in categories %}
    {% set tab_items = tab_items|merge([{
      label: meta.label,
      target: 'category-' ~ category,
      active: loop.first,
      class: 'settings-tab'
    }]) %}
  {% endfor %}

  {% embed 'components/card.twig' with {
    shell_class: form_card_shell,
    body_class: 'grid gap-5'
  } %}
    {% block header %}
      <div class="flex flex-col gap-3 border-b border-app-border pb-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl space-y-2">
          <span class="inline-flex w-fit items-center rounded-xl border border-app-warning/20 bg-app-warning/10 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.16em] text-app-warning">Admin only</span>
          <h1 class="text-2xl font-black tracking-tight text-app-text sm:text-3xl">Settings</h1>
          <p class="max-w-2xl text-sm leading-6 text-app-muted">Update predefined starter settings only. Changes refresh the runtime cache immediately after save.</p>
        </div>

        <div class="flex flex-wrap gap-2">
          <a class="{{ button_secondary }}" href="/admin">Back to dashboard</a>
        </div>
      </div>
      <div class="mt-4 rounded-[1rem] border border-app-warning/20 bg-app-warning/10 p-4 text-app-warning">
        <p class="text-sm font-semibold">Operational caution</p>
        <p class="mt-1 text-sm text-app-warning/85">These values are loaded at bootstrap and can alter mail, cache, logging, theme, and other runtime behavior immediately after update.</p>
      </div>
      {% include 'components/tabs.twig' with {
        tabs: {
          shell_class: 'mt-6',
          items: tab_items
        }
      } only %}
    {% endblock %}

    {% block body %}
      <form class="grid gap-5" method="post" action="/admin/settings" enctype="multipart/form-data">
        {{ csrf_field() }}

        {% for category, meta in categories %}
          <section id="category-{{ category }}" class="settings-category grid gap-5">
            <div class="border-b border-app-border pb-4">
              <h2 class="text-lg font-bold tracking-tight text-app-text">{{ meta.label }}</h2>
              <p class="mt-1 text-sm text-app-muted">{{ meta.description }}</p>
            </div>

            <div class="grid gap-4 md:grid-cols-2 items-start">
              {% for key, field in meta.fields %}
                {% set field_id = category ~ '_' ~ key %}
                {% set field_name = 'settings[' ~ category ~ '][' ~ key ~ ']' %}
                {% set field_value = attribute(attribute(settings, category), key) %}
                {% set field_value = field_value is same as(null) ? field.default : field_value %}
                {% set field_error = errors[category ~ '.' ~ key]|default([])|first %}

                <div class="grid gap-2 {% if field.input == 'textarea' %}md:col-span-2{% endif %}">
                  <label class="text-[0.82rem] font-semibold text-app-text" for="{{ field_id }}">{{ field.label }}</label>

                  {% if field.input == 'textarea' %}
                    <textarea
                      class="admin-control w-full rounded-xl border border-app-border bg-app-surface-2/80 px-3 py-2 text-sm text-app-text placeholder:text-slate-400 dark:placeholder:text-slate-300 outline-none transition focus:border-app-accent focus:ring-2 focus:ring-app-accent/10"
                      id="{{ field_id }}"
                      name="{{ field_name }}"
                      rows="4"
                      placeholder="{{ field.help|default('') }}"
                    >{% if field.type == 'list' %}{{ field_value is iterable ? field_value|join("\n") : field_value }}{% else %}{{ field.sensitive|default(false) ? '' : field_value }}{% endif %}</textarea>
                  {% elseif field.input == 'select' %}
                    <select class="admin-control w-full rounded-xl border border-app-border bg-app-surface-2/80 px-3 py-2 text-sm text-app-text outline-none transition focus:border-app-accent focus:ring-2 focus:ring-app-accent/10" id="{{ field_id }}" name="{{ field_name }}">
                      {% for option_value, option_label in field.options %}
                        <option value="{{ option_value }}" {% if field_value == option_value %}selected{% endif %}>{{ option_label }}</option>
                      {% endfor %}
                    </select>
                  {% elseif field.input == 'checkbox' %}
                    <label class="inline-flex min-h-[2.5rem] items-center gap-3 rounded-xl border border-app-border bg-app-surface-2/80 px-3 py-1.5 text-sm text-app-text">
                      <input type="checkbox" id="{{ field_id }}" name="{{ field_name }}" value="1" {% if field_value %}checked{% endif %}>
                      <span>{{ field.label }}</span>
                    </label>
                  {% elseif field.input == 'file' %}
                    <div class="grid gap-3">
                      <input
                        class="admin-control w-full rounded-xl border border-app-border bg-app-surface-2/80 px-3 py-2 text-sm text-app-text outline-none transition file:mr-3 file:rounded-lg file:border-0 file:bg-app-accent file:px-3 file:py-1.5 file:text-xs file:font-semibold file:text-white hover:file:bg-app-accent-soft focus:border-app-accent focus:ring-2 focus:ring-app-accent/10"
                        id="{{ field_id }}"
                        name="settings_logo_url"
                        type="file"
                        {% if field.accept is defined %}accept="{{ field.accept }}"{% endif %}
                      >

                      {% set current_logo = field_value|default('')|trim %}
                      {% if current_logo %}
                        {% set logo_src = current_logo starts with('http') or current_logo starts with('/') ? current_logo : '/' ~ current_logo %}
                        <div class="flex items-center gap-3 rounded-xl border border-app-border bg-app-surface-2/60 px-3 py-2">
                          <img src="{{ logo_src }}" alt="Current logo" class="h-12 w-12 rounded-lg border border-app-border bg-app-surface object-contain p-1">
                          <div class="min-w-0">
                            <p class="text-sm font-semibold text-app-text">Current logo</p>
                            <p class="truncate text-xs text-app-muted">{{ current_logo }}</p>
                            <button
                              type="submit"
                              name="settings[ui][remove_logo]"
                              value="1"
                              class="mt-2 inline-flex items-center gap-1.5 rounded-lg border border-app-danger/20 bg-app-danger/10 px-2.5 py-1 text-[0.72rem] font-semibold text-app-danger transition hover:bg-app-danger/15"
                            >
                              {% include 'components/icon.twig' with { name: 'trash-2', class: 'h-3.5 w-3.5' } only %}
                              Remove current logo
                            </button>
                          </div>
                        </div>
                      {% endif %}
                    </div>
                  {% elseif field.input == 'action' %}
                    {% if key == 'purge_cache' %}
                    <button
                      type="submit"
                      formaction="/admin/settings/purge-cache"
                      formmethod="post"
                      class="inline-flex items-center justify-center gap-2 rounded-xl border border-app-danger/20 bg-app-danger/10 px-3.5 py-2 text-[0.82rem] font-semibold text-app-danger transition hover:bg-app-danger/20"
                    >
                      {% include 'components/icon.twig' with { name: 'trash-2', class: 'h-4 w-4' } only %}
                      Purge Cache
                    </button>
                    {% elseif key == 'clear_logs' %}
                    <button
                      type="submit"
                      formaction="/admin/settings/clear-logs"
                      formmethod="post"
                      class="inline-flex items-center justify-center gap-2 rounded-xl border border-app-danger/20 bg-app-danger/10 px-3.5 py-2 text-[0.82rem] font-semibold text-app-danger transition hover:bg-app-danger/20"
                    >
                      {% include 'components/icon.twig' with { name: 'file-x-2', class: 'h-4 w-4' } only %}
                      Clear Logs
                    </button>
                    {% endif %}
                  {% else %}
                    <input
                      class="admin-control w-full rounded-xl border border-app-border bg-app-surface-2/80 px-3 py-2 text-sm text-app-text placeholder:text-slate-400 dark:placeholder:text-slate-300 outline-none transition focus:border-app-accent focus:ring-2 focus:ring-app-accent/10"
                      id="{{ field_id }}"
                      name="{{ field_name }}"
                      type="{{ field.input }}"
                      value="{{ field.sensitive|default(false) ? '' : field_value }}"
                      {% if field.min is defined %}min="{{ field.min }}"{% endif %}
                      {% if field.step is defined %}step="{{ field.step }}"{% endif %}
                    >
                  {% endif %}

                  {% if field_error %}
                    <p class="text-sm text-app-danger">{{ field_error }}</p>
                  {% elseif field.help is defined %}
                    <p class="text-sm text-app-muted">{{ field.help }}</p>
                  {% endif %}
                </div>
              {% endfor %}
            </div>
          </section>
        {% endfor %}

        <div class="mt-8 flex flex-wrap justify-center gap-2">
          <button class="{{ button_primary }}" type="submit">Save settings</button>
          <a class="{{ button_secondary }}" href="/admin">Cancel</a>
        </div>
      </form>
    {% endblock %}
  {% endembed %}

  <script>
    (function() {
      const tabs = document.querySelectorAll('[data-tabs] [data-tab-target]');
      const categories = document.querySelectorAll('.settings-category');
      const activeClasses = ['bg-app-accent/10', 'border-app-accent/20', 'text-app-accent'];
      const inactiveClasses = ['border-app-border', 'bg-app-surface/60', 'text-app-text', 'hover:bg-app-surface-2/70'];

      function switchTab(targetId) {
        tabs.forEach(tab => {
          const isActive = tab.dataset.tabTarget === targetId;
          activeClasses.forEach(className => tab.classList.toggle(className, isActive));
          inactiveClasses.forEach(className => tab.classList.toggle(className, !isActive));
          tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });

        categories.forEach(cat => {
          const isVisible = cat.id === targetId;
          cat.style.display = isVisible ? 'block' : 'none';
        });
      }

      tabs.forEach(tab => {
        tab.addEventListener('click', function(e) {
          e.preventDefault();
          switchTab(this.dataset.tabTarget);
        });
      });

      const firstTab = tabs[0];
      if (firstTab) {
        switchTab(firstTab.dataset.tabTarget);
      }
    })();
  </script>
{% endblock %}
