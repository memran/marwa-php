{% extends "layouts/admin.twig" %}

{% block title %}{{ token.getAttribute('name') }} | MarwaPHP Admin{% endblock %}

{% block content %}
<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <a href="/admin/api-tokens" class="inline-flex items-center gap-1 text-sm font-semibold text-app-muted hover:text-app-text">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back
      </a>
      <h1 class="mt-2 text-2xl font-bold tracking-tight text-app-text">API Token Details</h1>
      <p class="mt-1 text-sm text-app-muted">View and manage your API token.</p>
    </div>
  </div>

  {% if success %}
  <div class="rounded-lg bg-app-success/10 p-4">
    <div class="flex">
      <svg class="h-5 w-5 text-app-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <div class="ml-3">
        <p class="text-sm font-medium text-app-success">{{ success }}</p>
      </div>
    </div>
  </div>
  {% endif %}

  {% if display_token %}
  <div class="rounded-lg border border-app-warning/20 bg-app-warning/10 p-4">
    <div class="flex items-start">
      <svg class="h-5 w-5 text-app-warning" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <div class="ml-3 w-full">
        <p class="text-sm font-medium text-app-warning">Make sure to copy your token now. You won't be able to see it again!</p>
        <div class="mt-2 flex items-center gap-2" x-data="{ copied: false, copyTimer: null, copy(token) { navigator.clipboard.writeText(token).then(() => { this.copied = true; clearTimeout(this.copyTimer); this.copyTimer = setTimeout(() => { this.copied = false; }, 1600); }); } }">
          <code class="flex-1 break-all rounded bg-app-surface px-3 py-2 text-sm font-mono text-app-text">{{ display_token }}</code>
          <button
            type="button"
            data-token="{{ display_token }}"
            @click="copy($el.dataset.token)"
            class="shrink-0 inline-flex items-center gap-1 rounded-full border border-app-warning/20 bg-app-warning/10 px-3 py-2 text-sm font-semibold text-app-warning hover:bg-app-warning/20"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
            <span x-text="copied ? 'Copied' : 'Copy'">Copy</span>
          </button>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  <div class="rounded-xl border border-app-border bg-app-surface">
    <div class="border-b border-app-border px-6 py-4">
      <h2 class="text-lg font-semibold text-app-text">Token Information</h2>
    </div>
    <div class="divide-y divide-app-border">
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <span class="text-sm font-medium text-app-muted">Name</span>
        <span class="col-span-2 text-sm text-app-text">{{ token.getAttribute('name') }}</span>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <span class="text-sm font-medium text-app-muted">Token</span>
        <code class="col-span-2 text-sm font-mono text-app-muted">{{ token.getTokenPrefix() }}...</code>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <span class="text-sm font-medium text-app-muted">Rate Limit</span>
        <span class="col-span-2 text-sm text-app-text">{{ token.getRateLimit() }} requests/minute</span>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <span class="text-sm font-medium text-app-muted">Allowed IPs</span>
        <span class="col-span-2 text-sm text-app-text">
          {% if token.hasIpRestriction() %}
            <code class="text-xs">{{ token.getAllowedIps()|join(', ') }}</code>
          {% else %}
            <span class="text-app-muted">Any IP address</span>
          {% endif %}
        </span>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <span class="text-sm font-medium text-app-muted">Status</span>
        <div class="col-span-2">
          {% if token.isActive() %}
            <span class="inline-flex items-center gap-1 rounded-full bg-app-success/10 px-2.5 py-0.5 text-xs font-medium text-app-success">
              <span class="h-1.5 w-1.5 rounded-full bg-app-success"></span>
              Active
            </span>
          {% else %}
            <span class="inline-flex items-center gap-1 rounded-full bg-app-danger/10 px-2.5 py-0.5 text-xs font-medium text-app-danger">
              <span class="h-1.5 w-1.5 rounded-full bg-app-danger"></span>
              Revoked
            </span>
          {% endif %}
        </div>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <span class="text-sm font-medium text-app-muted">Created</span>
        <span class="col-span-2 text-sm text-app-text">{{ token.getAttribute('created_at') }}</span>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <span class="text-sm font-medium text-app-muted">Last Used</span>
        <span class="col-span-2 text-sm text-app-text">
          {% if token.getAttribute('last_used_at') %}
            {{ token.getAttribute('last_used_at') }}
          {% else %}
            <span class="text-app-muted">Never</span>
          {% endif %}
        </span>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-between border-t border-app-border pt-6">
    <form method="post" action="/admin/api-tokens/show/{{ token.getKey() }}/toggle">
      {{ csrf_field() }}
      {% if token.isActive() %}
      <button type="submit" class="inline-flex items-center gap-2 rounded-full border border-app-danger/20 bg-app-surface px-5 py-3 text-sm font-semibold text-app-danger transition hover:bg-app-danger/10">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
        </svg>
        Revoke Token
      </button>
      {% else %}
      <button type="submit" class="inline-flex items-center gap-2 rounded-full border border-app-success/20 bg-app-surface px-5 py-3 text-sm font-semibold text-app-success transition hover:bg-app-success/10">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        Reactivate Token
      </button>
      {% endif %}
    </form>

    <a href="/admin/api-tokens" class="inline-flex items-center gap-2 rounded-full border border-app-border px-5 py-3 text-sm font-semibold text-app-text transition hover:bg-app-surface-2/70">
      Close
    </a>
  </div>
</div>
{% endblock %}
