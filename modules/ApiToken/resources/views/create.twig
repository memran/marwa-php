{% extends "layouts/admin.twig" %}

{% block title %}Create API Token | MarwaPHP Admin{% endblock %}

{% block content %}
<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <a href="/admin/api-tokens" class="inline-flex items-center gap-1 text-sm font-semibold text-app-muted hover:text-app-text">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back
      </a>
      <h1 class="mt-2 text-2xl font-bold tracking-tight text-app-text">Create API Token</h1>
      <p class="mt-1 text-sm text-app-muted">Generate a new API token for external service access.</p>
    </div>
  </div>

  <form method="post" action="/admin/api-tokens" class="max-w-2xl space-y-6">
    {{ csrf_field() }}

    <div class="rounded-xl border border-app-border bg-app-surface p-6">
      <h2 class="mb-4 text-lg font-semibold text-app-text">Token Details</h2>
      
      <div class="space-y-4">
        <div>
          <label for="name" class="block text-sm font-medium text-app-text">Token Name *</label>
          <input type="text" id="name" name="name" required
            value="{{ old.name|default('') }}"
            class="mt-1 block w-full rounded-lg border border-app-border bg-app-surface px-3 py-2 text-sm text-app-text focus:border-app-accent focus:outline-none focus:ring-1 focus:ring-app-accent"
            placeholder="e.g., Production API">
          {% if errors.name is defined %}
            <p class="mt-1 text-sm text-app-danger">{{ errors.name|first }}</p>
          {% endif %}
        </div>

        <div>
          <label for="rate_limit" class="block text-sm font-medium text-app-text">Rate Limit (per minute) *</label>
          <input type="number" id="rate_limit" name="rate_limit" required min="1" max="10000"
            value="{{ old.rate_limit|default(60) }}"
            class="mt-1 block w-full rounded-lg border border-app-border bg-app-surface px-3 py-2 text-sm text-app-text focus:border-app-accent focus:outline-none focus:ring-1 focus:ring-app-accent"
            placeholder="60">
          <p class="mt-1 text-xs text-app-muted">Maximum requests per minute. Range: 1-10000</p>
        </div>

        <div>
          <label for="allowed_ips" class="block text-sm font-medium text-app-text">Allowed IP Addresses</label>
          <textarea id="allowed_ips" name="allowed_ips" rows="4"
            class="mt-1 block w-full rounded-lg border border-app-border bg-app-surface px-3 py-2 text-sm text-app-text focus:border-app-accent focus:outline-none focus:ring-1 focus:ring-app-accent"
            placeholder="192.168.1.1&#10;10.0.0.0/24&#10;0.0.0.0/0">{{ old.allowed_ips|default('') }}</textarea>
          <p class="mt-1 text-xs text-app-muted">One IP address or CIDR per line. Leave empty to allow any IP address.</p>
        </div>
      </div>
    </div>

    <div class="flex items-center justify-end gap-3">
      <a href="/admin/api-tokens" class="inline-flex items-center gap-2 rounded-full border border-app-border px-5 py-3 text-sm font-semibold text-app-text transition hover:bg-app-surface-2/70">
        Cancel
      </a>
      <button type="submit" class="inline-flex items-center gap-2 rounded-full border border-transparent bg-app-accent px-5 py-3 text-sm font-semibold text-white transition hover:bg-app-accent-soft">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Create Token
      </button>
    </div>
  </form>
</div>
{% endblock %}
