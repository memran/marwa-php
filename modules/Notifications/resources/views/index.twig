{% extends "layouts/admin.twig" %}

{% block title %}Notifications | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-xl border px-3.5 py-2 text-[0.82rem] font-semibold transition' %}
  {% set button_secondary = button_base ~ ' border-app-border bg-app-surface/80 text-app-text hover:bg-app-surface-2/70' %}
  {% set current_filter = filter|default('all') %}
  {% set tab_base = 'inline-flex items-center gap-2 rounded-xl border px-4 py-2 text-sm font-semibold transition' %}
  {% set tab_active = tab_base ~ ' border-app-accent bg-app-accent/10 text-app-accent' %}
  {% set tab_inactive = tab_base ~ ' border-app-border bg-app-surface/70 text-app-muted hover:bg-app-surface-2/70 hover:text-app-text' %}

  <section class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-2">
      <span class="inline-flex w-fit items-center rounded-xl border border-app-accent/20 bg-app-accent/10 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.16em] text-app-accent">Notifications</span>
      <h1 class="text-2xl font-black tracking-tight text-app-text sm:text-3xl">Notifications</h1>
      <p class="max-w-2xl text-sm leading-6 text-app-muted">Stay informed with the latest updates and alerts.</p>
    </div>

    <div class="flex flex-wrap gap-2">
      <a class="{{ button_secondary }}" href="/admin">Back to dashboard</a>
    </div>
  </section>

  <section class="mt-5 rounded-2xl border border-app-border bg-app-surface p-4 shadow-sm">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div class="flex flex-wrap gap-2" aria-label="Notification filters">
        <a class="{{ current_filter == 'all' ? tab_active : tab_inactive }}" href="/admin/notifications?filter=all">All</a>
        <a class="{{ current_filter == 'unread' ? tab_active : tab_inactive }}" href="/admin/notifications?filter=unread">
          Unread
          {% if unread_count > 0 %}
            <span class="inline-flex items-center rounded-full bg-app-danger/10 px-2 py-0.5 text-xs font-semibold text-app-danger">{{ unread_count }}</span>
          {% endif %}
        </a>
        <a class="{{ current_filter == 'read' ? tab_active : tab_inactive }}" href="/admin/notifications?filter=read">Read</a>
      </div>

      {% if unread_count > 0 and is_admin %}
        <form method="post" action="/admin/notifications/read-all">
          {{ csrf_field() }}
          <button class="{{ button_secondary }}" type="submit">Mark all as read</button>
        </form>
      {% endif %}
    </div>
  </section>

  {% set has_notifications = false %}
  {% for group, items in notifications %}
    {% if items|length > 0 %}
      {% set has_notifications = true %}
    {% endif %}
  {% endfor %}

  {% if not has_notifications %}
    <div class="mt-6 flex flex-col items-center justify-center rounded-2xl border border-app-border bg-app-surface px-6 py-12 text-center shadow-sm">
      <div class="flex h-16 w-16 items-center justify-center rounded-2xl border border-app-border bg-app-surface-2/70">
        {% include 'components/icon.twig' with { name: 'bell-off', class: 'h-8 w-8 text-app-muted' } only %}
      </div>
      <h3 class="mt-4 text-lg font-semibold text-app-text">No notifications</h3>
      <p class="mt-1 text-sm text-app-muted">You're all caught up!</p>
    </div>
  {% else %}
    {% for group, items in notifications %}
      {% if items|length > 0 %}
        <section class="mt-6">
          {% set group_label = '' %}
          {% if group == 'today' %}{% set group_label = 'Today' %}
          {% elseif group == 'yesterday' %}{% set group_label = 'Yesterday' %}
          {% elseif group == 'last_7_days' %}{% set group_label = 'Last 7 Days' %}
          {% elseif group == 'last_30_days' %}{% set group_label = 'Last 30 Days' %}
          {% elseif group == 'older' %}{% set group_label = 'Older' %}
          {% endif %}
          
          <h2 class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-app-muted">{{ group_label }}</h2>
          
          <div class="space-y-3">
            {% for notification in items %}
              {% set type = notification.getAttribute('type') %}
              {% set is_read = notification.getAttribute('is_read') %}
              
              {% set type_colors = {
                'info': 'text-app-accent bg-app-accent/10 border-app-accent/20',
                'success': 'text-app-success bg-app-success/10 border-app-success/20',
                'warning': 'text-app-warning bg-app-warning/10 border-app-warning/20',
                'error': 'text-app-danger bg-app-danger/10 border-app-danger/20'
              } %}
              
              {% set type_icons = {
                'info': 'info',
                'success': 'check-circle',
                'warning': 'alert-triangle',
                'error': 'circle-x'
              } %}
              
              <article class="group relative flex items-start gap-4 rounded-2xl border border-app-border bg-app-surface p-4 shadow-sm transition hover:border-app-accent/30 hover:bg-app-surface-2/50 {% if not is_read %}ring-1 ring-app-accent/25{% endif %}">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border {{ type_colors[type]|default('text-app-muted bg-app-surface-2/70 border-app-border') }}">
                  {% include 'components/icon.twig' with { name: type_icons[type]|default('bell'), class: 'h-5 w-5' } only %}
                </div>
                
                <div class="min-w-0 flex-1">
                  <div class="flex items-center gap-2">
                    <h3 class="truncate text-sm font-semibold text-app-text">{{ notification.getAttribute('title') }}</h3>
                    {% if not is_read %}
                      <span class="inline-flex h-2 w-2 rounded-full bg-app-accent"></span>
                    {% endif %}
                  </div>
                  <p class="mt-1 text-sm text-app-muted">{{ notification.getAttribute('message') }}</p>
                  <p class="mt-2 text-xs font-medium text-app-muted">{{ notification.getAttribute('created_at')|date((_system_date_format|default('M d, Y')) ~ ' ' ~ (_system_time_format|default('g:i A'))) }}</p>
                  
                  {% if notification.getAttribute('action_url') %}
                    <a class="mt-2 inline-flex items-center gap-1 text-xs font-medium text-app-accent hover:text-app-accent-soft" href="{{ notification.getAttribute('action_url') }}">
                      View details
                      {% include 'components/icon.twig' with { name: 'arrow-right', class: 'h-3 w-3' } only %}
                    </a>
                  {% endif %}
                </div>
                
                <div class="flex shrink-0 gap-1 opacity-100 transition-opacity sm:opacity-0 sm:group-hover:opacity-100">
                  {% if not is_read %}
                    <form method="post" action="/admin/notifications/{{ notification.getKey() }}/read">
                      {{ csrf_field() }}
                      <button class="rounded-lg p-2 text-app-muted hover:bg-app-surface-2/70 hover:text-app-text" title="Mark as read">
                        {% include 'components/icon.twig' with { name: 'check', class: 'h-4 w-4' } only %}
                      </button>
                    </form>
                  {% endif %}
                  
                  {% if is_admin %}
                    <form method="post" action="/admin/notifications/{{ notification.getKey() }}/delete" onsubmit="return confirm('Delete this notification?');">
                      {{ csrf_field() }}
                      <button class="rounded-lg p-2 text-app-muted hover:bg-app-danger/10 hover:text-app-danger" title="Delete">
                        {% include 'components/icon.twig' with { name: 'trash-2', class: 'h-4 w-4' } only %}
                      </button>
                    </form>
                  {% endif %}
                </div>
              </article>
            {% endfor %}
          </div>
        </section>
      {% endif %}
    {% endfor %}
  {% endif %}

  {% if last_page > 1 %}
    {% include '@Shared/components/pagination.twig' with { pagination: pagination } only %}
  {% endif %}
{% endblock %}
