{% extends "layouts/admin.twig" %}

{% block title %}Database | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-xl border px-3.5 py-2 text-[0.82rem] font-semibold transition' %}
  {% set button_primary = button_base ~ ' border-transparent bg-app-accent text-white hover:bg-app-accent-soft' %}
  {% set button_ghost = button_base ~ ' border-app-border bg-app-surface/80 text-app-text hover:bg-app-surface-2/70' %}

  <section class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-2">
      <span class="inline-flex w-fit items-center rounded-xl border border-app-danger/20 bg-app-danger/10 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.16em] text-app-danger">High risk</span>
      <h1 class="text-2xl font-black tracking-tight text-app-text sm:text-3xl">Database Manager</h1>
      <p class="max-w-2xl text-sm leading-6 text-app-muted">Execute raw SQL against the configured application database. This tool can alter, corrupt, or permanently destroy production data.</p>
    </div>

    <div class="flex flex-wrap gap-2">
      <a class="{{ button_ghost }}" href="/admin">Back to dashboard</a>
    </div>
  </section>

  <div class="mt-4 rounded-[1rem] border border-app-danger/20 bg-app-danger/10 p-4 text-app-danger">
    <p class="text-sm font-semibold">Danger zone</p>
    <p class="mt-1 text-sm text-app-danger">Only execute queries you fully understand. UPDATE, DELETE, DROP, TRUNCATE, and similar statements can cause irreversible data loss.</p>
  </div>

  <section class="mt-6 overflow-hidden rounded-[1.25rem] border border-app-border bg-app-surface/80 p-4 shadow-sm backdrop-blur-xl sm:p-5">
    <div class="border-b border-app-border pb-4">
      <h2 class="text-xl font-bold tracking-tight text-app-text">Query editor</h2>
      <p class="mt-1 text-sm text-app-muted">One SQL statement per execution. Comments are blocked and queries run without the ORM.</p>
    </div>

    {% if error is defined and error %}
      <div class="mt-4 rounded-xl border border-app-danger/20 bg-app-danger/10 p-3.5 text-app-danger">
        <p class="text-sm font-semibold">Query error</p>
        <p class="mt-1 text-sm text-app-danger">{{ error }}</p>
      </div>
    {% endif %}

    <form class="mt-4 grid gap-4" method="post" action="/admin/database">
      {{ csrf_field() }}
      <div class="grid gap-2">
        <label class="text-[0.82rem] font-semibold text-app-text" for="query">SQL query</label>
        <textarea
          class="admin-control w-full rounded-xl border border-app-border bg-app-surface-2/80 px-3 py-2.5 text-sm text-app-text placeholder:text-app-muted outline-none transition focus:border-app-accent focus:ring-2 focus:ring-app-accent/10"
          id="query"
          name="query"
          rows="10"
          placeholder="SELECT * FROM users ORDER BY id DESC"
        >{{ query|default('') }}</textarea>
      </div>

      <label class="inline-flex items-start gap-3 text-sm text-app-muted">
        <input type="checkbox" id="confirm_destructive" name="confirm_destructive" value="1">
        <span>I understand that destructive queries can change or destroy data and should only be executed intentionally.</span>
      </label>

      <div class="flex flex-wrap gap-2">
        <button class="{{ button_primary }}" type="submit">Execute query</button>
      </div>
    </form>
  </section>

  {% if result is defined and result %}
    <section class="mt-6 overflow-hidden rounded-[1.25rem] border border-app-border bg-app-surface/80 p-4 shadow-sm backdrop-blur-xl sm:p-5">
      <div class="flex flex-col gap-2 border-b border-app-border pb-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 class="text-xl font-bold tracking-tight text-app-text">Query result</h2>
          <p class="mt-1 text-sm text-app-muted">Statement type: <span class="font-semibold text-app-text">{{ result.statement_type|upper }}</span></p>
        </div>

        {% if result.is_result_set %}
          <span class="inline-flex rounded-xl border border-app-accent/20 bg-app-accent/10 px-2.5 py-1 text-[0.68rem] font-bold uppercase tracking-[0.14em] text-app-accent">{{ result.total_rows }} rows</span>
        {% else %}
          <span class="inline-flex rounded-xl border border-app-success/20 bg-app-success/10 px-2.5 py-1 text-[0.68rem] font-bold uppercase tracking-[0.14em] text-app-success">{{ result.affected_rows }} affected</span>
        {% endif %}
      </div>

      {% if result.is_result_set %}
        {% if result.rows is empty %}
          <div class="mt-4 rounded-xl border border-app-accent/20 bg-app-accent/10 p-3.5 text-app-accent">
            <p class="text-sm font-semibold">No rows returned</p>
            <p class="mt-1 text-sm text-app-accent">The query ran successfully but returned an empty result set.</p>
          </div>
        {% else %}
          <div class="theme-table__wrap mt-4">
            <table class="theme-table">
              <thead>
                <tr>
                  {% for column in result.columns %}
                    <th>{{ column }}</th>
                  {% endfor %}
                </tr>
              </thead>
              <tbody>
                {% for row in result.rows %}
                  <tr class="align-top">
                    {% for column in result.columns %}
                      <td>{{ attribute(row, column)|default(null) is same as(null) ? 'NULL' : attribute(row, column) }}</td>
                    {% endfor %}
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>

          {% if pagination %}
            {% include '@Shared/components/pagination.twig' with { pagination: pagination } only %}
          {% endif %}
        {% endif %}
      {% else %}
        <div class="mt-4 rounded-xl border border-app-success/20 bg-app-success/10 p-3.5 text-app-success">
          <p class="text-sm font-semibold">Statement executed</p>
          <p class="mt-1 text-sm text-app-success">The query completed successfully.</p>
        </div>
      {% endif %}
    </section>
  {% endif %}
{% endblock %}
