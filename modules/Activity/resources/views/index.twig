{% extends "layouts/admin.twig" %}

{% block title %}Activity | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-full border px-5 py-3 text-sm font-semibold transition hover:-translate-y-0.5' %}
  {% set button_ghost = button_base ~ ' border-app-border bg-app-surface/80 text-app-text hover:bg-app-surface-2/70' %}
  {% set current_sort = sort|default('created_at') %}
  {% set current_direction = direction|default('desc') %}
  {% set current_filter = filter|default('all') %}
  {% set sort_base = 'q=' ~ query|default('')|url_encode ~ '&filter=' ~ current_filter|url_encode %}
  {% set time_direction = current_sort == 'created_at' and current_direction == 'asc' ? 'desc' : 'asc' %}
  {% set action_direction = current_sort == 'action' and current_direction == 'asc' ? 'desc' : 'asc' %}
  {% set actor_direction = current_sort == 'actor' and current_direction == 'asc' ? 'desc' : 'asc' %}

  <section class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-3">
      <span class="inline-flex w-fit items-center rounded-full border border-app-accent/20 bg-app-accent/10 px-4 py-1.5 text-[0.7rem] font-extrabold uppercase tracking-[0.22em] text-app-accent">Audit trail</span>
      <h1 class="text-3xl font-black tracking-tight text-app-text sm:text-4xl">Activity</h1>
      <p class="max-w-2xl text-sm leading-6 text-app-muted sm:text-base">Track sign-ins, user management, and other important admin actions.</p>
    </div>

    <div class="flex flex-wrap gap-3">
      <a class="{{ button_ghost }}" href="/admin">Back to dashboard</a>
    </div>
  </section>

  {% include 'components/activity-log.twig' with {
    title: 'Recent activity',
    description: 'Newest actions appear at the top.',
    rows: activities.data|default([]),
    pagination: pagination,
    compact: false,
    count_label: activities.total|default(0) ~ ' entries',
    empty_message: 'No activity yet'
  } only %}
{% endblock %}
