{% extends "layout.twig" %}

{% block title %}Queue Job{% endblock %}

{% block content %}
{% set job = job ?? {} %}
<div class="space-y-6">
    <section class="rounded-3xl border border-slate-200/70 bg-white px-6 py-5 shadow-sm ring-1 ring-slate-100 dark:border-slate-800 dark:bg-slate-900/60 dark:ring-white/5">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="space-y-2">
                <p class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500 dark:text-slate-400">Queue</p>
                <h1 class="text-2xl font-semibold text-slate-900 dark:text-white">{{ job.name ?? 'Job details' }}</h1>
                <p class="text-sm text-slate-600 dark:text-slate-400">{{ job.job_id ?? '' }}</p>
            </div>
        <div class="flex items-center gap-2">
            <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] ring-1 {{ job.status_class }}">
                {{ job.status ?? 'pending' }}
            </span>
            <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] ring-1 {{ job.notification_class }}">
                {{ job.notification_label ?? 'Waiting for notification' }}
            </span>
            {% if job.status == 'failed' %}
                <form method="post" action="/admin/queue/{{ job.job_id|url_encode }}/retry">
                    {{ csrf_field() }}
                    <button type="submit" class="inline-flex items-center rounded-full bg-sky-600 px-3 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-white transition hover:bg-sky-500">
                        Retry Job
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>
    </section>

    <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
            <div class="text-xs uppercase tracking-[0.25em] text-slate-500 dark:text-slate-400">Queue</div>
            <div class="mt-2 text-lg font-semibold text-slate-900 dark:text-white">{{ job.queue ?? 'default' }}</div>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
            <div class="text-xs uppercase tracking-[0.25em] text-slate-500 dark:text-slate-400">Attempts</div>
            <div class="mt-2 text-lg font-semibold text-slate-900 dark:text-white">{{ job.attempts ?? 0 }}</div>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
            <div class="text-xs uppercase tracking-[0.25em] text-slate-500 dark:text-slate-400">Available</div>
            <div class="mt-2 text-lg font-semibold text-slate-900 dark:text-white">{{ job.available_at ?? 'Now' }}</div>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
            <div class="text-xs uppercase tracking-[0.25em] text-slate-500 dark:text-slate-400">Updated</div>
            <div class="mt-2 text-lg font-semibold text-slate-900 dark:text-white">{{ job.updated_at ?? '-' }}</div>
        </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[minmax(0,1.4fr)_minmax(320px,0.8fr)]">
        <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
            <div class="border-b border-slate-200 px-6 py-4 dark:border-slate-800">
                <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Payload</h2>
            </div>
            <div class="p-6">
                <pre class="max-h-[540px] overflow-auto rounded-2xl bg-slate-950 p-5 text-sm text-slate-100"><code>{{ job.payload_json ?? '{}' }}</code></pre>
            </div>
        </div>

        <div class="space-y-6">
            <section class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
                <div class="border-b border-slate-200 px-6 py-4 dark:border-slate-800">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Timeline</h2>
                </div>
                <dl class="space-y-4 p-6 text-sm text-slate-600 dark:text-slate-300">
                    <div>
                        <dt class="text-xs uppercase tracking-[0.25em] text-slate-500 dark:text-slate-400">Reserved</dt>
                        <dd class="mt-1">{{ job.reserved_at ?: 'Never' }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs uppercase tracking-[0.25em] text-slate-500 dark:text-slate-400">Finished</dt>
                        <dd class="mt-1">{{ job.finished_at ?: 'Never' }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs uppercase tracking-[0.25em] text-slate-500 dark:text-slate-400">Failed</dt>
                        <dd class="mt-1">{{ job.failed_at ?: 'Never' }}</dd>
                    </div>
                </dl>
            </section>

            <section class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
                <div class="border-b border-slate-200 px-6 py-4 dark:border-slate-800">
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Log</h2>
                </div>
                <div class="p-6 text-sm text-slate-600 dark:text-slate-300">
                    {% if job.failure_reason %}
                        <div class="rounded-2xl bg-slate-50 px-4 py-3 dark:bg-slate-950/60">
                            {{ job.failure_reason }}
                        </div>
                    {% else %}
                        <span class="text-slate-400 dark:text-slate-500">No logs recorded for this job yet.</span>
                    {% endif %}
                </div>
            </section>
        </div>
    </section>
</div>
{% endblock %}
