{% extends "layouts/admin.twig" %}

{% block title %}Queue Job{% endblock %}

{% block content %}
{% set job = job ?? {} %}
<div class="space-y-6">
    <section class="rounded-3xl border border-app-border bg-app-surface px-6 py-5 shadow-sm">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="space-y-2">
                <p class="text-xs font-semibold uppercase tracking-[0.3em] text-app-muted">Queue</p>
                <h1 class="text-2xl font-semibold text-app-text">{{ job.name ?? 'Job details' }}</h1>
                <p class="text-sm text-app-muted">{{ job.job_id ?? '' }}</p>
            </div>
        <div class="flex items-center gap-2">
            <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] ring-1 {{ job.status_class }}">
                {{ job.status ?? 'pending' }}
            </span>
            <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] ring-1 {{ job.notification_class }}">
                {{ job.notification_label ?? 'Waiting for notification' }}
            </span>
            {% if job.status == 'failed' %}
                <form method="post" action="/admin/queue/{{ job.job_id|url_encode }}/retry">
                    {{ csrf_field() }}
                    <button type="submit" class="inline-flex items-center rounded-full bg-app-accent px-3 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-white transition hover:bg-app-accent-soft">
                        Retry Job
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>
    </section>

    <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-2xl border border-app-border bg-app-surface p-4 shadow-sm">
            <div class="text-xs uppercase tracking-[0.25em] text-app-muted">Queue</div>
            <div class="mt-2 text-lg font-semibold text-app-text">{{ job.queue ?? 'default' }}</div>
        </div>
        <div class="rounded-2xl border border-app-border bg-app-surface p-4 shadow-sm">
            <div class="text-xs uppercase tracking-[0.25em] text-app-muted">Attempts</div>
            <div class="mt-2 text-lg font-semibold text-app-text">{{ job.attempts ?? 0 }}</div>
        </div>
        <div class="rounded-2xl border border-app-border bg-app-surface p-4 shadow-sm">
            <div class="text-xs uppercase tracking-[0.25em] text-app-muted">Available</div>
            <div class="mt-2 text-lg font-semibold text-app-text">{{ job.available_at ?? 'Now' }}</div>
        </div>
        <div class="rounded-2xl border border-app-border bg-app-surface p-4 shadow-sm">
            <div class="text-xs uppercase tracking-[0.25em] text-app-muted">Updated</div>
            <div class="mt-2 text-lg font-semibold text-app-text">{{ job.updated_at ?? '-' }}</div>
        </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[minmax(0,1.4fr)_minmax(320px,0.8fr)]">
        <div class="overflow-hidden rounded-3xl border border-app-border bg-app-surface shadow-sm">
            <div class="border-b border-app-border px-6 py-4">
                <h2 class="text-lg font-semibold text-app-text">Payload</h2>
            </div>
            <div class="p-6">
                <pre class="max-h-[540px] overflow-auto rounded-2xl bg-app-surface-2/90 p-5 text-sm text-app-text"><code>{{ job.payload_json ?? '{}' }}</code></pre>
            </div>
        </div>

        <div class="space-y-6">
            <section class="overflow-hidden rounded-3xl border border-app-border bg-app-surface shadow-sm">
                <div class="border-b border-app-border px-6 py-4">
                    <h2 class="text-lg font-semibold text-app-text">Timeline</h2>
                </div>
                <dl class="space-y-4 p-6 text-sm text-app-text">
                    <div>
                        <dt class="text-xs uppercase tracking-[0.25em] text-app-muted">Reserved</dt>
                        <dd class="mt-1">{{ job.reserved_at ?: 'Never' }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs uppercase tracking-[0.25em] text-app-muted">Finished</dt>
                        <dd class="mt-1">{{ job.finished_at ?: 'Never' }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs uppercase tracking-[0.25em] text-app-muted">Failed</dt>
                        <dd class="mt-1">{{ job.failed_at ?: 'Never' }}</dd>
                    </div>
                </dl>
            </section>

            <section class="overflow-hidden rounded-3xl border border-app-border bg-app-surface shadow-sm">
                <div class="border-b border-app-border px-6 py-4">
                    <h2 class="text-lg font-semibold text-app-text">Log</h2>
                </div>
                <div class="p-6 text-sm text-app-muted">
                    {% if job.failure_reason %}
                        <div class="rounded-2xl bg-app-surface-2/70 px-4 py-3 text-app-text">
                            {{ job.failure_reason }}
                        </div>
                    {% else %}
                        <span class="text-app-muted">No logs recorded for this job yet.</span>
                    {% endif %}
                </div>
            </section>
        </div>
    </section>
</div>
{% endblock %}
