{% extends "layout.twig" %}

{% block title %}Queue{% endblock %}

{% block content %}
{% set overview = overview ?? {} %}
{% set stats = overview.stats ?? {} %}
{% set jobs = overview.jobs ?? [] %}
<div class="space-y-6">
    <section class="rounded-3xl border border-slate-200/70 bg-white px-6 py-5 shadow-sm ring-1 ring-slate-100 dark:border-slate-800 dark:bg-slate-900/60 dark:ring-white/5">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <div class="space-y-2">
                <p class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500 dark:text-slate-400">Operations</p>
                <h1 class="text-2xl font-semibold text-slate-900 dark:text-white">Queue</h1>
                <p class="max-w-3xl text-sm text-slate-600 dark:text-slate-400">
                    The queue is backed by the framework global driver. This screen shows the current backend state and the latest job logs.
                </p>
            </div>
            <div class="rounded-2xl bg-slate-950 px-4 py-3 text-sm text-slate-100 shadow-sm dark:bg-slate-900">
                <div class="text-[11px] uppercase tracking-[0.25em] text-slate-400">Worker</div>
                <div class="mt-1 font-mono text-xs sm:text-sm">{{ overview.cron ?? 'php marwa queue:work --for=60 --sleep=1' }}</div>
            </div>
        </div>
    </section>

    <section class="grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
        <div class="col-span-1 rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
            <div class="text-[11px] font-semibold uppercase tracking-[0.25em] text-slate-500 dark:text-slate-400">Total</div>
            <div class="mt-1 text-2xl font-semibold text-slate-900 dark:text-white">{{ stats.total ?? 0 }}</div>
        </div>
        <div class="col-span-1 rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
            <div class="text-[11px] font-semibold uppercase tracking-[0.25em] text-slate-500 dark:text-slate-400">Failed</div>
            <div class="mt-1 text-2xl font-semibold text-red-600 dark:text-red-400">{{ stats.failed ?? 0 }}</div>
        </div>
        <div class="col-span-1 rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
            <div class="text-[11px] font-semibold uppercase tracking-[0.25em] text-slate-500 dark:text-slate-400">Success</div>
            <div class="mt-1 text-2xl font-semibold text-emerald-600 dark:text-emerald-400">{{ stats.success ?? 0 }}</div>
        </div>
        <div class="col-span-1 rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
            <div class="text-[11px] font-semibold uppercase tracking-[0.25em] text-slate-500 dark:text-slate-400">Idle</div>
            <div class="mt-1 text-2xl font-semibold text-slate-900 dark:text-white">{{ stats.idle ?? 0 }}</div>
        </div>
        <div class="col-span-1 rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
            <div class="text-[11px] font-semibold uppercase tracking-[0.25em] text-slate-500 dark:text-slate-400">Running</div>
            <div class="mt-1 text-2xl font-semibold text-sky-600 dark:text-sky-400">{{ stats.running ?? 0 }}</div>
        </div>
    </section>

    <section class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
        <div class="border-b border-slate-200 px-6 py-4 dark:border-slate-800">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Job Status</h2>
                    <p class="text-sm text-slate-500 dark:text-slate-400">Backed by {{ overview.backend_label ?? 'the global queue' }}.</p>
                </div>
                <div class="text-sm text-slate-500 dark:text-slate-400">
                    {% if overview.driver == 'database' %}
                        Table: <span class="font-mono text-slate-700 dark:text-slate-300">{{ overview.table ?? 'queue_jobs' }}</span>
                    {% else %}
                        Path: <span class="font-mono text-slate-700 dark:text-slate-300">{{ overview.state_path ?? 'storage/queue' }}</span>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-800">
                <thead class="bg-slate-50 text-left text-xs uppercase tracking-[0.2em] text-slate-500 dark:bg-slate-950/40 dark:text-slate-400">
                    <tr>
                        <th class="px-6 py-3">Job</th>
                        <th class="px-6 py-3">Queue</th>
                        <th class="px-6 py-3">Status</th>
                        <th class="px-6 py-3">Updated</th>
                        <th class="px-6 py-3">Log</th>
                        <th class="px-6 py-3">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                    {% for job in jobs %}
                        <tr class="align-top">
                            <td class="px-6 py-4">
                                <a class="font-semibold text-slate-900 underline decoration-slate-300 underline-offset-4 hover:text-sky-700 dark:text-white dark:decoration-slate-700 dark:hover:text-sky-400" href="/admin/queue/{{ job.job_id|url_encode }}">{{ job.name }}</a>
                                <div class="mt-1 text-xs uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">{{ job.job_id }}</div>
                                <div class="mt-2 text-xs text-slate-500 dark:text-slate-400">Attempts: {{ job.attempts }}</div>
                            </td>
                            <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-300">
                                <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-slate-700 dark:bg-slate-800 dark:text-slate-200">
                                    {{ job.queue }}
                                </span>
                                <div class="mt-2 text-xs uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">{{ job.available_at ?: 'Ready now' }}</div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] ring-1 {{ job.status_class }}">
                                    {{ job.status }}
                                </span>
                                <div class="mt-2">
                                    <span class="inline-flex items-center rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.2em] ring-1 {{ job.notification_class }}">
                                        {{ job.notification_label }}
                                    </span>
                                </div>
                                <dl class="mt-3 space-y-1 text-xs text-slate-500 dark:text-slate-400">
                                    <div><dt class="inline font-semibold">Reserved:</dt> <dd class="inline">{{ job.reserved_at ?: 'Never' }}</dd></div>
                                    <div><dt class="inline font-semibold">Finished:</dt> <dd class="inline">{{ job.finished_at ?: 'Never' }}</dd></div>
                                    <div><dt class="inline font-semibold">Failed:</dt> <dd class="inline">{{ job.failed_at ?: 'Never' }}</dd></div>
                                </dl>
                            </td>
                            <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-300">
                                {{ job.updated_at ?: '-' }}
                            </td>
                            <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-300">
                                {% if job.failure_reason %}
                                    <div class="max-w-md rounded-2xl bg-slate-50 px-4 py-3 text-sm text-slate-700 dark:bg-slate-950/60 dark:text-slate-300">
                                        {{ job.failure_reason }}
                                    </div>
                                {% else %}
                                    <span class="text-slate-400 dark:text-slate-500">No logs yet.</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-300">
                                <div class="flex flex-wrap gap-2">
                                    <a href="/admin/queue/{{ job.job_id|url_encode }}" class="inline-flex items-center rounded-full border border-slate-200 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-slate-700 transition hover:border-sky-200 hover:text-sky-700 dark:border-slate-700 dark:text-slate-200 dark:hover:border-sky-500 dark:hover:text-sky-300">
                                        Open
                                    </a>
                                    {% if job.status == 'failed' %}
                                        <form method="post" action="/admin/queue/{{ job.job_id|url_encode }}/retry">
                                            {{ csrf_field() }}
                                            <button type="submit" class="inline-flex items-center rounded-full bg-sky-600 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-white transition hover:bg-sky-500">
                                                Retry
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="px-6 py-12 text-center text-sm text-slate-500 dark:text-slate-400">
                                No queue jobs found yet. Trigger a queued email or job to see it here.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
</div>
{% endblock %}
