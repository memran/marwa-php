{% extends "layouts/admin.twig" %}

{% block title %}Queue{% endblock %}

{% block content %}
{% set overview = overview ?? {} %}
{% set stats = overview.stats ?? {} %}
{% set jobs = overview.jobs ?? [] %}
<div class="space-y-6">
    <section class="rounded-3xl border border-app-border bg-app-surface px-6 py-5 shadow-sm">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <div class="space-y-2">
                <p class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500 dark:text-slate-400">Operations</p>
                <h1 class="text-2xl font-semibold text-app-text">Queue</h1>
                <p class="max-w-3xl text-sm text-app-muted">
                    The queue is backed by the framework global driver. This screen shows the current backend state and the latest job logs.
                </p>
            </div>
            <div class="rounded-2xl bg-app-surface-2/80 px-4 py-3 text-sm text-app-text shadow-sm">
                <div class="text-[11px] uppercase tracking-[0.25em] text-app-muted">Worker</div>
                <div class="mt-1 font-mono text-xs sm:text-sm">{{ overview.cron ?? 'php marwa queue:work --max-time=60 --sleep=1' }}</div>
            </div>
        </div>
    </section>

    <section class="grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
        <div class="col-span-1 rounded-2xl border border-app-border bg-app-surface px-4 py-3 shadow-sm">
            <div class="text-[11px] font-semibold uppercase tracking-[0.25em] text-app-muted">Total</div>
            <div class="mt-1 text-2xl font-semibold text-app-text">{{ stats.total ?? 0 }}</div>
        </div>
        <div class="col-span-1 rounded-2xl border border-app-border bg-app-surface px-4 py-3 shadow-sm">
            <div class="text-[11px] font-semibold uppercase tracking-[0.25em] text-app-muted">Failed</div>
            <div class="mt-1 text-2xl font-semibold text-app-danger">{{ stats.failed ?? 0 }}</div>
        </div>
        <div class="col-span-1 rounded-2xl border border-app-border bg-app-surface px-4 py-3 shadow-sm">
            <div class="text-[11px] font-semibold uppercase tracking-[0.25em] text-app-muted">Success</div>
            <div class="mt-1 text-2xl font-semibold text-app-success">{{ stats.success ?? 0 }}</div>
        </div>
        <div class="col-span-1 rounded-2xl border border-app-border bg-app-surface px-4 py-3 shadow-sm">
            <div class="text-[11px] font-semibold uppercase tracking-[0.25em] text-app-muted">Idle</div>
            <div class="mt-1 text-2xl font-semibold text-app-text">{{ stats.idle ?? 0 }}</div>
        </div>
        <div class="col-span-1 rounded-2xl border border-app-border bg-app-surface px-4 py-3 shadow-sm">
            <div class="text-[11px] font-semibold uppercase tracking-[0.25em] text-app-muted">Running</div>
            <div class="mt-1 text-2xl font-semibold text-app-accent">{{ stats.running ?? 0 }}</div>
        </div>
    </section>

    <section class="overflow-hidden rounded-3xl border border-app-border bg-app-surface shadow-sm">
        <div class="border-b border-app-border px-6 py-4">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h2 class="text-lg font-semibold text-app-text">Job Status</h2>
                    <p class="text-sm text-app-muted">Backed by {{ overview.backend_label ?? 'the global queue' }}.</p>
                </div>
                <div class="text-sm text-app-muted">
                    {% if overview.driver == 'database' %}
                        Table: <span class="font-mono text-app-text">{{ overview.table ?? 'queue_jobs' }}</span>
                    {% else %}
                        Path: <span class="font-mono text-app-text">{{ overview.state_path ?? 'storage/queue' }}</span>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-app-border">
                <thead class="bg-app-surface-2/60 text-left text-xs uppercase tracking-[0.2em] text-app-muted">
                    <tr>
                        <th class="px-6 py-3">Job</th>
                        <th class="px-6 py-3">Queue</th>
                        <th class="px-6 py-3">Status</th>
                        <th class="px-6 py-3">Updated</th>
                        <th class="px-6 py-3">Log</th>
                        <th class="px-6 py-3">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-app-border">
                    {% for job in jobs %}
                        <tr class="align-top">
                            <td class="px-6 py-4">
                                <a class="font-semibold text-app-text underline decoration-app-border underline-offset-4 hover:text-app-accent" href="/admin/queue/{{ job.job_id|url_encode }}">{{ job.name }}</a>
                                <div class="mt-1 text-xs uppercase tracking-[0.2em] text-app-muted">{{ job.job_id }}</div>
                                <div class="mt-2 text-xs text-app-muted">Attempts: {{ job.attempts }}</div>
                            </td>
                            <td class="px-6 py-4 text-sm text-app-muted">
                                <span class="inline-flex rounded-full bg-app-surface-2/70 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-app-text">
                                    {{ job.queue }}
                                </span>
                                <div class="mt-2 text-xs uppercase tracking-[0.2em] text-app-muted">{{ job.available_at ?: 'Ready now' }}</div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] ring-1 {{ job.status_class }}">
                                    {{ job.status }}
                                </span>
                                <div class="mt-2">
                                    <span class="inline-flex items-center rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.2em] ring-1 {{ job.notification_class }}">
                                        {{ job.notification_label }}
                                    </span>
                                </div>
                                <dl class="mt-3 space-y-1 text-xs text-app-muted">
                                    <div><dt class="inline font-semibold">Reserved:</dt> <dd class="inline">{{ job.reserved_at ?: 'Never' }}</dd></div>
                                    <div><dt class="inline font-semibold">Finished:</dt> <dd class="inline">{{ job.finished_at ?: 'Never' }}</dd></div>
                                    <div><dt class="inline font-semibold">Failed:</dt> <dd class="inline">{{ job.failed_at ?: 'Never' }}</dd></div>
                                </dl>
                            </td>
                            <td class="px-6 py-4 text-sm text-app-muted">
                                {{ job.updated_at ?: '-' }}
                            </td>
                            <td class="px-6 py-4 text-sm text-app-muted">
                                {% if job.failure_reason %}
                                    <div class="max-w-md rounded-2xl bg-app-surface-2/70 px-4 py-3 text-sm text-app-text">
                                        {{ job.failure_reason }}
                                    </div>
                                {% else %}
                                    <span class="text-app-muted">No logs yet.</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 text-sm text-app-muted">
                                <div class="flex flex-wrap gap-2">
                                    <a href="/admin/queue/{{ job.job_id|url_encode }}" class="inline-flex items-center rounded-full border border-app-border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-app-text transition hover:border-app-accent/30 hover:text-app-accent">
                                        Open
                                    </a>
                                    {% if job.status == 'failed' %}
                                        <form method="post" action="/admin/queue/{{ job.job_id|url_encode }}/retry">
                                            {{ csrf_field() }}
                                            <button type="submit" class="inline-flex items-center rounded-full bg-app-accent px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-white transition hover:bg-app-accent-soft">
                                                Retry
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="px-6 py-12 text-center text-sm text-app-muted">
                                No queue jobs found yet. Trigger a queued email or job to see it here.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
</div>
{% endblock %}
