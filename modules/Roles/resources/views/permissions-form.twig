{% extends "layouts/admin.twig" %}

{% block title %}{{ title }} | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2.5 whitespace-nowrap rounded-xl border px-5 py-2.5 text-sm font-semibold transition-all duration-200 ease-out' %}
  {% set button_primary = button_base ~ ' border-transparent bg-gradient-to-br from-cyan-400 to-sky-500 text-white shadow-lg shadow-cyan-500/20 hover:shadow-xl hover:shadow-cyan-500/30 hover:-translate-y-0.5 active:translate-y-0 active:shadow-md' %}
  {% set button_secondary = button_base ~ ' border-slate-600/40 bg-slate-800/30 text-slate-200 shadow-sm shadow-slate-900/30 backdrop-blur-xl hover:bg-slate-700/50 hover:border-slate-500/50 hover:shadow-md hover:-translate-y-0.5 active:translate-y-0' %}
  {% set button_danger = button_base ~ ' border-rose-500/20 bg-rose-500/10 text-rose-300 shadow-sm shadow-rose-500/5 backdrop-blur-xl hover:bg-rose-500/20 hover:border-rose-500/30 hover:shadow-md hover:shadow-rose-500/10 hover:-translate-y-0.5 active:translate-y-0' %}
  {% set permission = permission|default(null) %}
  {% set form = form|default({}) %}
  {% set back_url = back_url|default('/admin/permissions') %}

  <section class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-2">
      <span class="inline-flex w-fit items-center rounded-xl border border-app-accent/20 bg-app-accent/10 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.16em] text-app-accent">Permissions</span>
      <h1 class="text-2xl font-black tracking-tight text-app-text sm:text-3xl">{{ title }}</h1>
      <p class="max-w-2xl text-sm leading-6 text-app-muted">
        Permissions are reusable access rules. Updating one here changes every role that uses it.
      </p>
    </div>

    <div class="flex flex-wrap gap-2">
      <a class="{{ button_secondary }}" href="{{ back_url }}">Back to permissions</a>
    </div>
  </section>

  <form method="post" action="{{ action }}" class="mt-6">
    {{ csrf_field() }}

    <div class="grid gap-6 lg:grid-cols-2">
      <div class="rounded-[1.25rem] border border-app-border bg-app-surface/80 p-6 shadow-[0_30px_80px_rgba(2,6,23,0.45)] backdrop-blur-xl">
        <div class="mb-4 flex items-center justify-between gap-3">
          <h2 class="text-lg font-semibold text-app-text">Permission Details</h2>
          {% if permission is not null %}
            <span class="inline-flex items-center rounded-full border border-app-success/20 bg-app-success/10 px-2.5 py-1 text-xs font-semibold text-app-success">Editing</span>
          {% endif %}
        </div>

        <div class="space-y-5">
          {% include "components/form-field.twig" with {
            id: 'name',
            label: 'Name',
            value: form.name|default(''),
            placeholder: 'View Reports',
            error: errors.name|default([])|first
          } only %}

          {% include "components/form-field.twig" with {
            id: 'slug',
            label: 'Slug',
            value: form.slug|default(''),
            placeholder: 'reports.view',
            hint: 'Used by middleware and gate checks.',
            error: errors.slug|default([])|first
          } only %}

          {% set field_class = 'w-full rounded-xl border border-app-border bg-app-surface/60 px-3 py-2 text-sm text-app-text outline-none transition focus:border-app-accent focus:ring-2 focus:ring-app-accent/20' %}
          <div class="grid gap-2">
            <label class="text-[0.82rem] font-semibold text-app-text" for="group">Group</label>
            <select
              id="group"
              name="group"
              class="{{ field_class }}"
            >
              {% for group in groups %}
                <option value="{{ group }}" {% if form.group|default('') == group %}selected{% endif %}>{{ group }}</option>
              {% endfor %}
            </select>
            <p class="text-xs leading-5 text-app-muted">Permissions must use one of the existing groups.</p>
            {% if errors.group is defined and errors.group|first %}
              <p class="text-xs text-app-danger">{{ errors.group|first }}</p>
            {% endif %}
          </div>

          {% include "components/form-field.twig" with {
            id: 'description',
            label: 'Description',
            type: 'textarea',
            rows: 4,
            value: form.description|default(''),
            placeholder: 'Describe what this permission allows.',
            error: errors.description|default([])|first
          } only %}
        </div>
      </div>

      <div class="rounded-[1.25rem] border border-app-border bg-app-surface/80 p-6 shadow-[0_30px_80px_rgba(2,6,23,0.45)] backdrop-blur-xl">
        <div class="mb-4 flex items-center justify-between gap-3">
          <h2 class="text-lg font-semibold text-app-text">Permission Summary</h2>
        </div>

        <div class="space-y-3 rounded-2xl border border-app-border bg-app-surface-2/40 p-4 text-sm text-app-text">
          <div class="flex items-center justify-between gap-4">
            <span class="text-app-muted">Name</span>
            <span class="font-semibold">{{ form.name|default('') ?: 'Untitled permission' }}</span>
          </div>
          <div class="flex items-center justify-between gap-4">
            <span class="text-app-muted">Slug</span>
            <span class="font-semibold">{{ form.slug|default('') ?: 'custom.permission' }}</span>
          </div>
          <div class="flex items-center justify-between gap-4">
            <span class="text-app-muted">Group</span>
            <span class="font-semibold">{{ form.group|default('') ?: 'custom' }}</span>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-6 flex justify-end gap-3">
      <a href="{{ back_url }}" class="{{ button_secondary }}">Cancel</a>
      <button type="submit" class="{{ button_primary }}">{{ submit_label }}</button>
    </div>
  </form>
{% endblock %}
