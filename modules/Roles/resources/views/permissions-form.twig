{% extends "layout.twig" %}

{% block title %}{{ title }} | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-xl border px-3.5 py-2 text-[0.82rem] font-semibold transition' %}
  {% set button_primary = button_base ~ ' border-transparent bg-white text-slate-950 hover:bg-cyan-200' %}
  {% set button_secondary = button_base ~ ' border-white/10 bg-white/5 text-slate-100 hover:bg-white/10' %}
  {% set permission = permission|default(null) %}
  {% set form = form|default({}) %}

  <section class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-2">
      <span class="inline-flex w-fit items-center rounded-xl border border-cyan-300/20 bg-cyan-400/10 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.16em] text-cyan-100">Permissions</span>
      <h1 class="text-2xl font-black tracking-tight text-white sm:text-3xl">{{ title }}</h1>
      <p class="max-w-2xl text-sm leading-6 text-slate-300">
        Permissions are reusable access rules. Updating one here changes every role that uses it.
      </p>
    </div>

    <div class="flex flex-wrap gap-2">
      <a class="{{ button_secondary }}" href="/admin/permissions">Back to permissions</a>
    </div>
  </section>

  <form method="post" action="{{ action }}" class="mt-6">
    {{ csrf_field() }}

    <div class="grid gap-6 lg:grid-cols-2">
      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <div class="mb-4 flex items-center justify-between gap-3">
          <h2 class="text-lg font-semibold text-slate-100">Permission Details</h2>
        </div>

        <div class="space-y-4">
          {% include "components/form-field.twig" with {
            id: 'name',
            label: 'Name',
            value: form.name|default(''),
            placeholder: 'View Reports',
            error: errors.name|default([])|first
          } only %}

          {% include "components/form-field.twig" with {
            id: 'slug',
            label: 'Slug',
            value: form.slug|default(''),
            placeholder: 'reports.view',
            hint: 'Used by middleware and gate checks.',
            error: errors.slug|default([])|first
          } only %}

          <div class="grid gap-3">
            <label class="text-[0.82rem] font-semibold text-slate-200" for="group">Group</label>
            <select
              id="group"
              name="group"
              class="admin-control w-full rounded-xl border border-white/10 bg-white/5 px-3 py-2 text-sm text-slate-100 outline-none transition focus:border-cyan-400 focus:ring-2 focus:ring-cyan-400/10"
            >
              {% for group in groups %}
                <option value="{{ group }}" {% if form.group|default('') == group %}selected{% endif %}>{{ group }}</option>
              {% endfor %}
            </select>
            <p class="text-xs leading-5 text-slate-400">Permissions must use one of the existing groups.</p>
            {% if errors.group is defined and errors.group|first %}
              <p class="text-xs text-rose-300">{{ errors.group|first }}</p>
            {% endif %}
          </div>

          {% include "components/form-field.twig" with {
            id: 'description',
            label: 'Description',
            type: 'textarea',
            rows: 4,
            value: form.description|default(''),
            placeholder: 'Describe what this permission allows.',
            error: errors.description|default([])|first
          } only %}
        </div>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <div class="mb-4 flex items-center justify-between gap-3">
          <h2 class="text-lg font-semibold text-slate-100">Permission Summary</h2>
          {% if permission is not null %}
            <span class="inline-flex items-center rounded-full bg-emerald-400/10 px-2 py-0.5 text-xs font-medium text-emerald-200">Editing</span>
          {% endif %}
        </div>

        <div class="space-y-3 rounded-2xl border border-white/5 bg-white/[0.03] p-4 text-sm text-slate-300">
          <div class="flex items-center justify-between gap-4">
            <span class="text-slate-500">Name</span>
            <span class="font-semibold text-slate-100">{{ form.name|default('') ?: 'Untitled permission' }}</span>
          </div>
          <div class="flex items-center justify-between gap-4">
            <span class="text-slate-500">Slug</span>
            <span class="font-semibold text-slate-100">{{ form.slug|default('') ?: 'custom.permission' }}</span>
          </div>
          <div class="flex items-center justify-between gap-4">
            <span class="text-slate-500">Group</span>
            <span class="font-semibold text-slate-100">{{ form.group|default('') ?: 'custom' }}</span>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-6 flex justify-end gap-3">
      <a href="/admin/permissions" class="{{ button_secondary }}">Cancel</a>
      <button type="submit" class="{{ button_primary }}">{{ submit_label }}</button>
    </div>
  </form>
{% endblock %}
