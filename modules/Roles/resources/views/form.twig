{% extends "layouts/admin.twig" %}

{% block title %}{{ title }} | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2.5 whitespace-nowrap rounded-xl border px-5 py-2.5 text-sm font-semibold transition-all duration-200 ease-out' %}
  {% set button_primary = button_base ~ ' border-transparent bg-app-accent text-white shadow-sm hover:-translate-y-0.5 hover:bg-app-accent-soft active:translate-y-0' %}
  {% set button_secondary = button_base ~ ' border-app-border bg-app-surface/80 text-app-text shadow-sm hover:-translate-y-0.5 hover:bg-app-surface-2/70 active:translate-y-0' %}
  {% set button_danger = button_base ~ ' border-app-danger/20 bg-app-danger/10 text-app-danger shadow-sm hover:-translate-y-0.5 hover:bg-app-danger/20 active:translate-y-0' %}
  {% set role = role|default(null) %}
  {% set form = form|default({}) %}
  {% set permissions = permissions|default({}) %}
  {% set role_permission_ids = role_permission_ids|default([]) %}
  {% set is_system_role = role is not null and role.getAttribute('is_system') %}
  {% set back_url = back_url|default('/admin/roles') %}
  {% set field_class = 'w-full rounded-xl border border-app-border bg-app-surface px-3 py-2 text-sm text-app-text placeholder:text-app-muted outline-none transition focus:border-app-accent focus:ring-0 focus-visible:outline-none focus-visible:border-app-accent focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-app-accent/20 disabled:cursor-not-allowed disabled:opacity-60' %}

  <section class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-2">
      <span class="inline-flex w-fit items-center rounded-xl border border-app-accent/20 bg-app-accent/10 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.16em] text-app-accent">Roles & Permissions</span>
      <h1 class="text-2xl font-black tracking-tight text-app-text sm:text-3xl">{{ title }}</h1>
      <p class="max-w-2xl text-sm leading-6 text-app-muted">
        Create a new role or update permissions for an existing one. Role permissions apply immediately to every user assigned to that role.
      </p>
    </div>

    <div class="flex flex-wrap gap-2">
      <a class="{{ button_secondary }}" href="{{ back_url }}">Back to roles</a>
    </div>
  </section>

  <form method="post" action="{{ action }}" class="mt-6">
    {{ csrf_field() }}

    <div class="grid gap-6 lg:grid-cols-2">
      <div class="rounded-[1.25rem] border border-app-border bg-app-surface/80 p-6 shadow-[0_30px_80px_rgba(2,6,23,0.45)] backdrop-blur-xl">
        <div class="mb-5 flex items-center justify-between gap-3">
          <div class="flex items-center gap-2.5">
            <svg class="h-5 w-5 shrink-0 text-app-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
            </svg>
            <h2 class="text-lg font-semibold text-app-text">Role Details</h2>
          </div>
          {% if is_system_role %}
            <span class="inline-flex items-center rounded-full border border-app-warning/20 bg-app-warning/10 px-2.5 py-1 text-xs font-semibold text-app-warning">System role</span>
          {% endif %}
        </div>

        <div class="space-y-5">
          <div class="grid gap-2">
            <label class="text-[0.82rem] font-semibold text-app-text" for="name">Name</label>
            <input
              class="{{ field_class }}"
              id="name"
              name="name"
              type="text"
              value="{{ form.name|default('') }}"
              placeholder="Support Agent"
              {% if is_system_role %}readonly{% endif %}
              autocomplete="off"
            >
            {% if errors.name|default([])|length > 0 %}
              <p class="text-xs text-app-danger">{{ errors.name|default([])|first }}</p>
            {% endif %}
          </div>

          <div class="grid gap-2">
            <label class="text-[0.82rem] font-semibold text-app-text" for="slug">Slug</label>
            <p class="text-xs leading-5 text-app-muted">Used by permissions and middleware checks.</p>
            <input
              class="{{ field_class }}"
              id="slug"
              name="slug"
              type="text"
              value="{{ form.slug|default('') }}"
              placeholder="support_agent"
              {% if is_system_role %}readonly{% endif %}
              autocomplete="off"
            >
            {% if errors.slug|default([])|length > 0 %}
              <p class="text-xs text-app-danger">{{ errors.slug|default([])|first }}</p>
            {% endif %}
          </div>

          <div class="grid gap-2">
            <label class="text-[0.82rem] font-semibold text-app-text" for="level">Level</label>
            <p class="text-xs leading-5 text-app-muted">Higher levels can satisfy lower role checks.</p>
            <input
              class="{{ field_class }}"
              id="level"
              name="level"
              type="number"
              value="{{ form.level|default(1) }}"
              placeholder="1"
              {% if is_system_role %}readonly{% endif %}
            >
            {% if errors.level|default([])|length > 0 %}
              <p class="text-xs text-app-danger">{{ errors.level|default([])|first }}</p>
            {% endif %}
          </div>

          <div class="grid gap-2">
            <label class="text-[0.82rem] font-semibold text-app-text" for="description">Description</label>
            <textarea
              class="{{ field_class }}"
              id="description"
              name="description"
              rows="4"
              placeholder="Short note about the role purpose."
            >{{ form.description|default('') }}</textarea>
            {% if errors.description|default([])|length > 0 %}
              <p class="text-xs text-app-danger">{{ errors.description|default([])|first }}</p>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="rounded-[1.25rem] border border-app-border bg-app-surface/80 p-6 shadow-[0_30px_80px_rgba(2,6,23,0.45)] backdrop-blur-xl">
        <div class="mb-5 flex items-center justify-between gap-3">
          <div class="flex items-center gap-2.5">
            <svg class="h-5 w-5 shrink-0 text-app-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
            </svg>
            <h2 class="text-lg font-semibold text-app-text">Permissions</h2>
          </div>
          <span class="inline-flex items-center rounded-full border border-app-border bg-app-surface-2/70 px-2.5 py-1 text-xs font-semibold text-app-muted">{{ role_permission_ids|length }} assigned</span>
        </div>

        <p class="mb-4 text-sm text-app-muted">
          Checked permissions are saved to the selected role immediately, and every user with this role inherits them dynamically.
        </p>

        <div class="max-h-[30rem] space-y-4 overflow-y-auto pr-1">
          {% for group, perms in permissions %}
            <div class="rounded-2xl border border-app-border bg-app-surface-2/40 p-4">
              <h3 class="mb-3 text-xs font-extrabold uppercase tracking-[0.18em] text-app-muted">{{ group }}</h3>
              <div class="grid gap-2 sm:grid-cols-2">
                {% for perm in perms %}
                  <label class="flex cursor-pointer items-start gap-3 rounded-xl border border-app-border bg-app-surface/60 px-3 py-2 transition hover:border-app-accent/30 hover:bg-app-accent/5">
                    <input type="checkbox" name="permissions[]" value="{{ perm.getKey() }}" {% if perm.getKey() in role_permission_ids %}checked{% endif %} class="mt-1 h-4 w-4 rounded border-app-border bg-app-surface text-app-accent focus:ring-app-accent/20">
                    <span class="min-w-0">
                      <span class="block text-sm font-medium text-app-text">{{ perm.getAttribute('name') }}</span>
                      <span class="block text-xs text-app-muted">{{ perm.getAttribute('slug') }}</span>
                    </span>
                  </label>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="flex items-center justify-end gap-3 rounded-xl border border-app-border bg-app-surface/60 px-6 py-4">
      <a href="{{ back_url }}" class="{{ button_secondary }}">Cancel</a>
      <button type="submit" class="{{ button_primary }}">{{ submit_label }}</button>
    </div>
  </form>
{% endblock %}
