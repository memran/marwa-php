{% extends "layouts/admin.twig" %}

{% block title %}Permissions | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2.5 whitespace-nowrap rounded-xl border px-5 py-2.5 text-sm font-semibold transition-all duration-200 ease-out' %}
  {% set button_primary = button_base ~ ' border-transparent bg-app-accent text-white shadow-sm hover:-translate-y-0.5 hover:bg-app-accent-soft active:translate-y-0' %}
  {% set button_secondary = button_base ~ ' border-app-border bg-app-surface/80 text-app-text shadow-sm hover:-translate-y-0.5 hover:bg-app-surface-2/70 active:translate-y-0' %}

  <section class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-2">
      <span class="inline-flex w-fit items-center rounded-xl border border-app-accent/20 bg-app-accent/10 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.16em] text-app-accent">Roles & Permissions</span>
      <h1 class="text-2xl font-black tracking-tight text-app-text sm:text-3xl">Permissions</h1>
      <p class="max-w-2xl text-sm leading-6 text-app-muted">
        Permissions are assigned to roles dynamically. Updating a role here changes access for every user attached to that role.
      </p>
    </div>

    <div class="flex flex-wrap gap-2">
      {% if can('permissions.manage') %}
        <a class="{{ button_primary }}" href="/admin/permissions/create">Create permission</a>
      {% endif %}
      <a class="{{ button_secondary }}" href="/admin/roles">Back to roles</a>
    </div>
  </section>

  {% if notice is defined and notice %}
    <div class="mt-6 rounded-2xl border border-app-success/20 bg-app-success/10 px-4 py-3 text-sm font-semibold text-app-success">
      {{ notice }}
    </div>
  {% endif %}

  {% include '@Shared/components/data-table.twig' with { table: table } only %}
{% endblock %}
