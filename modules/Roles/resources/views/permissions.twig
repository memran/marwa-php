{% extends "layout.twig" %}

{% block title %}Permissions | MarwaPHP Admin{% endblock %}

{% block content %}
  {% set button_base = 'inline-flex items-center justify-center gap-2 rounded-xl border px-3.5 py-2 text-[0.82rem] font-semibold transition' %}
  {% set button_primary = button_base ~ ' border-transparent bg-white text-slate-950 hover:bg-cyan-200' %}
  {% set button_secondary = button_base ~ ' border-white/10 bg-white/5 text-slate-100 hover:bg-white/10' %}

  <section class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-2">
      <span class="inline-flex w-fit items-center rounded-xl border border-cyan-300/20 bg-cyan-400/10 px-3 py-1 text-[0.65rem] font-extrabold uppercase tracking-[0.16em] text-cyan-100">Roles & Permissions</span>
      <h1 class="text-2xl font-black tracking-tight text-white sm:text-3xl">Permissions</h1>
      <p class="max-w-2xl text-sm leading-6 text-slate-300">
        Permissions are assigned to roles dynamically. Updating a role here changes access for every user attached to that role.
      </p>
    </div>

    <div class="flex flex-wrap gap-2">
      <a class="{{ button_primary }}" href="{{ create_url|default('/admin/permissions/create') }}">Create permission</a>
      <a class="{{ button_secondary }}" href="/admin/roles">Back to roles</a>
    </div>
  </section>

  {% if notice|default(false) %}
    <div class="mt-4 rounded-lg border border-emerald-500/20 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-200">
      {{ notice }}
    </div>
  {% endif %}

  <div class="mt-6 grid gap-4 sm:grid-cols-3">
    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Total</p>
      <p class="mt-2 text-2xl font-black text-white">{{ total_permissions|default(0) }}</p>
      <p class="mt-1 text-sm text-slate-400">Permissions in the system.</p>
    </div>
    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Visible</p>
      <p class="mt-2 text-2xl font-black text-white">{{ visible_permissions|default(0) }}</p>
      <p class="mt-1 text-sm text-slate-400">Matched by the current filters.</p>
    </div>
    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Groups</p>
      <p class="mt-2 text-2xl font-black text-white">{{ group_count|default(0) }}</p>
      <p class="mt-1 text-sm text-slate-400">Groups shown in the current list.</p>
    </div>
  </div>

  <form method="get" action="/admin/permissions" class="mt-6 rounded-[1.5rem] border border-white/10 bg-white/5 p-4 shadow-[0_20px_60px_rgba(2,6,23,0.22)] backdrop-blur-xl">
    <div class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_220px_auto] lg:items-end">
      <div class="grid gap-2">
        <label class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" for="q">Search</label>
        <input
          id="q"
          name="q"
          type="search"
          value="{{ query|default('') }}"
          placeholder="Search by name, slug, group, or description"
          class="w-full rounded-2xl border border-white/10 bg-slate-950/30 px-4 py-3 text-sm text-slate-100 placeholder:text-slate-500 outline-none transition focus:border-cyan-400 focus:ring-4 focus:ring-cyan-400/10"
        >
      </div>

      <div class="grid gap-2">
        <label class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400" for="group">Group</label>
        <select
          id="group"
          name="group"
          class="w-full rounded-2xl border border-white/10 bg-slate-950/30 px-4 py-3 text-sm text-slate-100 outline-none transition focus:border-cyan-400 focus:ring-4 focus:ring-cyan-400/10"
        >
          <option value="">All groups</option>
          {% for option in group_options|default([]) %}
            <option value="{{ option }}" {% if group|default('') == option %}selected{% endif %}>{{ option|replace({'_': ' '})|capitalize }}</option>
          {% endfor %}
        </select>
      </div>

      <div class="flex flex-wrap gap-2 lg:justify-end">
        <button type="submit" class="{{ button_primary }}">Apply filters</button>
        {% if query|default('') or group|default('') %}
          <a href="/admin/permissions" class="{{ button_secondary }}">Reset</a>
        {% endif %}
      </div>
    </div>
  </form>

  {% if permissions is empty %}
    <div class="mt-8 flex flex-col items-center justify-center rounded-[1.75rem] border border-dashed border-white/10 bg-white/5 px-6 py-14 text-center">
      <div class="flex h-16 w-16 items-center justify-center rounded-full bg-white/5">
        {% include 'components/icon.twig' with { name: 'key-round', class: 'h-8 w-8 text-slate-500' } only %}
      </div>
      <h3 class="mt-4 text-lg font-semibold text-slate-200">
        {% if query|default('') or group|default('') %}
          No permissions match your filters
        {% else %}
          No permissions found
        {% endif %}
      </h3>
      <p class="mt-1 max-w-xl text-sm text-slate-400">
        {% if query|default('') or group|default('') %}
          Try a broader search term or clear the group filter to see the full catalog.
        {% else %}
          Permissions will appear here after seeding or creation.
        {% endif %}
      </p>
      {% if query|default('') or group|default('') %}
        <a href="/admin/permissions" class="{{ button_primary }} mt-5">Clear filters</a>
      {% endif %}
    </div>
  {% else %}
    <div class="mt-8 space-y-6">
      {% for group_name, perms in permissions %}
        <section class="overflow-hidden rounded-[1.75rem] border border-white/10 bg-white/5">
          <div class="flex flex-col gap-3 border-b border-white/10 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <h2 class="text-lg font-bold tracking-tight text-white">{{ group_name|replace({'_': ' '})|capitalize }}</h2>
              <p class="mt-1 text-sm text-slate-400">{{ perms|length }} permission{{ perms|length == 1 ? '' : 's' }}</p>
            </div>
            <span class="inline-flex w-fit items-center rounded-full border border-cyan-300/20 bg-cyan-400/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.2em] text-cyan-100">{{ group_name }}</span>
          </div>

          <div class="grid gap-4 p-5 md:grid-cols-2 xl:grid-cols-3">
            {% for perm in perms %}
              <article class="rounded-2xl border border-white/10 bg-slate-950/30 p-4 transition hover:border-cyan-300/20 hover:bg-slate-950/40">
                <div class="flex items-start justify-between gap-3">
                  <div class="min-w-0">
                    <h3 class="truncate text-base font-semibold text-slate-50">{{ perm.getAttribute('name') }}</h3>
                    <p class="mt-1 truncate text-xs text-slate-400">{{ perm.getAttribute('slug') }}</p>
                  </div>
                  <span class="inline-flex shrink-0 items-center rounded-full border border-white/10 bg-white/5 px-2.5 py-1 text-[0.65rem] font-bold uppercase tracking-[0.18em] text-slate-300">#{{ perm.getKey() }}</span>
                </div>

                <p class="mt-3 line-clamp-3 text-sm leading-6 text-slate-300">
                  {{ perm.getAttribute('description')|default('') ?: 'No description provided.' }}
                </p>

                <div class="mt-4 flex flex-wrap gap-2">
                  <a href="/admin/permissions/{{ perm.getKey() }}/edit" class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-3 py-2 text-xs font-semibold text-slate-100 transition hover:bg-white/10">
                    {% include 'components/icon.twig' with { name: 'pencil', class: 'h-3.5 w-3.5' } only %}
                    <span>Edit</span>
                  </a>
                  <form method="post" action="/admin/permissions/{{ perm.getKey() }}/delete" onsubmit="return confirm('Delete this permission?');">
                    {{ csrf_field() }}
                    <button type="submit" class="inline-flex items-center gap-2 rounded-xl border border-rose-400/20 bg-rose-500/10 px-3 py-2 text-xs font-semibold text-rose-100 transition hover:bg-rose-500/20">
                      {% include 'components/icon.twig' with { name: 'trash-2', class: 'h-3.5 w-3.5' } only %}
                      <span>Delete</span>
                    </button>
                  </form>
                </div>
              </article>
            {% endfor %}
          </div>
        </section>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
