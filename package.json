{
  "name": "marwa-php",
  "version": "1.0.0",
  "description": "![License](https://img.shields.io/badge/license-MIT-blue.svg) ![PHP](https://img.shields.io/badge/php-8.2%2B-orange) ![Build](https://img.shields.io/badge/build-passing-brightgreen)",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "icons:build:admin": "php scripts/build-admin-lucide-sprite.php",
    "css:dev": "tailwindcss -c tailwind.config.js -i ./resources/css/app.css -o ./public/assets/css/app.css --watch",
    "css:dev:admin": "npm run icons:build:admin && tailwindcss -c tailwind.config.js -i ./resources/views/themes/admin/assets/css/app.css -o ./public/themes/admin/assets/css/app.css --watch",
    "css:build:default": "tailwindcss -c tailwind.config.js -i ./resources/css/app.css -o ./public/assets/css/app.css --minify",
    "css:build:admin": "npm run icons:build:admin && tailwindcss -c tailwind.config.js -i ./resources/views/themes/admin/assets/css/app.css -o ./public/themes/admin/assets/css/app.css --minify",
    "css:build": "npm run css:build:default && npm run css:build:admin",
    "dev": "npm run css:dev",
    "build": "npm run css:build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memran/marwa-php.git"
  },
  "keywords": [
    "tailwindcss",
    "php",
    "starter"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/memran/marwa-php/issues"
  },
  "homepage": "https://github.com/memran/marwa-php#readme",
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "autoprefixer": "^10.4.21",
    "lucide-static": "^1.8.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  }
}
